# ===========================
# Xcode
# ===========================

# Build output
build/
DerivedData/

# Xcode user settings (per-developer, not shared)
*.xcuserstate
*.xcuserdatad/
xcuserdata/

# Xcode Scheme files — only ignore auto-managed ones
# If you manually create shared schemes, remove this line
*.xcscheme

# Xcode workspace generated by SPM — regenerated automatically
*.xcworkspace/xcshareddata/swiftpm

# Legacy Xcode project backups
*.moved-aside
*.pbxuser

# ===========================
# Swift Package Manager
# ===========================

# Resolved dependencies — commit this for apps, ignore for libraries
# For a framework repo, ignoring is standard practice so consumers
# resolve to the versions compatible with their project.
# The demo app's Package.resolved is also excluded for the same reason.
.build/
*.resolved

# ===========================
# macOS
# ===========================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
**/.DS_Store

# ===========================
# Xcode Previews
# ===========================

# Preview device support files
*.deviceinfo

# ===========================
# CocoaPods (not used, but just in case)
# ===========================

Pods/
Podfile.lock

# ===========================
# Fastlane (if added later)
# ===========================

fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# ===========================
# CI / Tooling
# ===========================

# Mint (Swift tool manager)
.mint/

# Sourcery, SwiftGen etc
# (none used in this project, included for completeness)