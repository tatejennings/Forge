{"abstract":[{"text":"Mock dependencies in tests using scoped overrides, container reset, and explicit test contracts.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/testingwithforge"]}],"metadata":{"roleHeading":"Article","title":"Testing with Forge","modules":[{"name":"Forge"}],"role":"article"},"kind":"article","sections":[],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Testing and Contracts","identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"],"generated":true,"anchor":"Testing-and-Contracts"}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order"},{"type":"text","text":" "},{"type":"text","text":"of preference. All examples use Swift Testing ("},{"type":"codeVoice","code":"@Test"},{"type":"text","text":", "},{"type":"codeVoice","code":"@Suite"},{"type":"text","text":", "},{"type":"codeVoice","code":"#expect"},{"type":"text","text":")."}],"type":"paragraph"},{"anchor":"Scoped-Overrides-with-withOverrides-Preferred","type":"heading","level":2,"text":"Scoped Overrides with withOverrides (Preferred)"},{"inlineContent":[{"code":"Container\/withOverrides(_:run:)-3qdpl","type":"codeVoice"},{"text":" registers overrides for the duration of a","type":"text"},{"text":" ","type":"text"},{"text":"closure, then automatically restores the previous state. No manual cleanup required:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\\.authService) { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled)","    }","}"]},{"inlineContent":[{"text":"Cleanup is guaranteed via ","type":"text"},{"code":"defer","type":"codeVoice"},{"text":" — even if the body throws, overrides are restored.","type":"text"},{"text":" ","type":"text"},{"text":"Both sync and async variants are available:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"Container\/withOverrides(_:run:)-3qdpl","type":"codeVoice"},{"text":" — synchronous","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Container\/withOverrides(_:run:)-4eui2"},{"type":"text","text":" — async (use when your test body contains "},{"type":"codeVoice","code":"await"},{"type":"text","text":")"}]}]}]},{"anchor":"Fresh-State-Between-Tests","type":"heading","level":2,"text":"Fresh State Between Tests"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer\/shared","isActive":true},{"type":"text","text":" is a stable "},{"type":"codeVoice","code":"let"},{"type":"text","text":" for the lifetime of the process — you"},{"type":"text","text":" "},{"type":"text","text":"don’t (and can’t) swap the instance. For test suites where every test needs a clean"},{"type":"text","text":" "},{"type":"text","text":"slate, reset the shared container in place with "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","isActive":true},{"type":"text","text":" in the"},{"type":"text","text":" "},{"type":"text","text":"suite’s "},{"type":"codeVoice","code":"init"},{"type":"text","text":". "},{"type":"codeVoice","code":"resetAll()"},{"type":"text","text":" clears all cached singletons, cached values, and"},{"type":"text","text":" "},{"type":"text","text":"registered overrides:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Suite(\"LoginViewModel behavior\", .serialized)","struct LoginViewModelTests {","","    init() {","        AuthContainer.shared.resetAll()","    }","","    @Test(\"Login calls the auth service\")","    func testLoginCallsService() async throws {","        let mock = MockAuthService()","","        try await AuthContainer.shared.withOverrides {","            $0.override(\\.authService) { mock }","        } run: {","            let vm = LoginViewModel()","            await vm.login(username: \"test\", password: \"pass\")","            #expect(mock.loginCalled)","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"Each test gets a fresh starting point with no leftover state from previous tests."},{"type":"text","text":" "},{"type":"text","text":"Mark such suites "},{"type":"codeVoice","code":".serialized"},{"type":"text","text":" so the in-place resets don’t race across tests."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Direct Overrides (Escape Hatch)","anchor":"Direct-Overrides-Escape-Hatch"},{"inlineContent":[{"text":"When ","type":"text"},{"code":"withOverrides","type":"codeVoice"},{"text":" closures are impractical, use ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"directly:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["init() {","    AuthContainer.shared.resetAll()","    AuthContainer.shared.override(\\.authService) { MockAuthService() }","}"]},{"inlineContent":[{"text":"This is the escape hatch — prefer ","type":"text"},{"type":"codeVoice","code":"withOverrides"},{"text":" wherever possible because direct","type":"text"},{"text":" ","type":"text"},{"text":"overrides require manual cleanup via ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/removeOverride(for:)"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"The TestContainer Pattern with unimplemented","anchor":"The-TestContainer-Pattern-with-unimplemented"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"},{"type":"text","text":" makes dependency contracts explicit — any dependency"},{"type":"text","text":" "},{"type":"text","text":"that isn’t overridden crashes immediately instead of silently running the wrong code."},{"type":"text","text":" "},{"type":"text","text":"This is valuable in tests (shown here) and in cross-module proxies (see"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use it to define a test container where every dependency fails loudly if called"},{"type":"text","text":" "},{"type":"text","text":"without being explicitly overridden:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["final class TestAuthContainer: AuthContainer {","    override var authService: any AuthServiceProtocol {","        provide { unimplemented(\"authService\") }","    }","","    override var networkClient: any NetworkClientProtocol {","        provide { unimplemented(\"networkClient\") }","    }","}"]},{"inlineContent":[{"type":"text","text":"Then in your tests, build the test container as an instance, override only what you"},{"type":"text","text":" "},{"type":"text","text":"need, and resolve through it explicitly with "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Test(\"Login success flow\")","func testLoginSuccess() async throws {","    let container = TestAuthContainer()","","    try await container.withOverrides {","        $0.override(\\.authService) {","            MockAuthService(shouldSucceed: true)","        }","        \/\/ networkClient is unimplemented — if login accidentally","        \/\/ calls it, the test fails loudly instead of silently","        \/\/ executing live code","    } run: {","        let authService = ContainerInject(container, \\.authService).wrappedValue","        let vm = LoginViewModel(authService: authService)","        await vm.login(username: \"user\", password: \"pass\")","    }","}"]},{"inlineContent":[{"type":"text","text":"This makes test contracts explicit — you declare exactly which dependencies a test"},{"type":"text","text":" "},{"type":"text","text":"exercises. Anything else is a bug."}],"type":"paragraph"},{"style":"tip","content":[{"inlineContent":[{"type":"text","text":"If you want the zero-argument "},{"type":"codeVoice","code":"@Inject(\\.x)"},{"type":"text","text":" to resolve from a test container"},{"type":"text","text":" "},{"type":"text","text":"without threading it through initializers, declare that container’s "},{"type":"codeVoice","code":"shared"},{"type":"text","text":" as a"},{"type":"text","text":" "},{"type":"codeVoice","code":"static var"},{"type":"text","text":" (the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer"},{"type":"text","text":" requirement is only "},{"type":"codeVoice","code":"{ get }"},{"type":"text","text":", so a "},{"type":"codeVoice","code":"var"},{"type":"text","text":" "},{"type":"text","text":"satisfies it) and assign it in a "},{"type":"codeVoice","code":".serialized"},{"type":"text","text":" suite’s "},{"type":"codeVoice","code":"init"},{"type":"text","text":". Forge permits this;"},{"type":"text","text":" "},{"type":"text","text":"it just isn’t the default — prefer the stable "},{"type":"codeVoice","code":"let"},{"type":"text","text":" plus "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"aside","name":"Tip"},{"anchor":"Best-Practices","text":"Best Practices","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Prefer ","type":"text"},{"type":"codeVoice","code":"withOverrides"}],"type":"strong"},{"text":" — automatic cleanup prevents test state leakage","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Call ","type":"text"},{"type":"codeVoice","code":"resetAll()"},{"text":" in suite ","type":"text"},{"type":"codeVoice","code":"init()"}],"type":"strong"},{"text":" — gives each test a fresh starting point","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Use ","type":"text"},{"code":"unimplemented","type":"codeVoice"},{"text":" for test containers","type":"text"}],"type":"strong"},{"type":"text","text":" — makes dependency boundaries explicit"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Use ","type":"text"},{"code":".serialized","type":"codeVoice"},{"text":" on suites","type":"text"}],"type":"strong"},{"type":"text","text":" that reset or mutate "},{"code":"shared","type":"codeVoice"},{"type":"text","text":" — prevents data races"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Use protocol return types","type":"text"}],"type":"strong"},{"text":" on container properties — this is what makes mocks","type":"text"},{"text":" ","type":"text"},{"text":"substitutable for live implementations","type":"text"}]}]}]}],"kind":"content"}],"references":{"doc://Forge/documentation/Forge/Container":{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","abstract":[{"text":"The base class for all dependency containers in Forge.","type":"text"}],"navigatorTitle":[{"text":"Container","kind":"identifier"}],"kind":"symbol","role":"symbol","url":"\/documentation\/forge\/container","title":"Container","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Container","kind":"identifier"}]},"doc://Forge/documentation/Forge/unimplemented(_:file:line:)":{"title":"unimplemented(_:file:line:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"unimplemented"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"file"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s12StaticStringV","kind":"typeIdentifier","text":"StaticString"},{"kind":"text","text":", "},{"kind":"externalParam","text":"line"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Su","kind":"typeIdentifier","text":"UInt"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"T"}],"role":"symbol","type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","kind":"symbol","abstract":[{"type":"text","text":"Returns a value of type "},{"type":"codeVoice","code":"T"},{"type":"text","text":" that will never actually be produced — calling this"},{"type":"text","text":" "},{"type":"text","text":"function always terminates via "},{"type":"codeVoice","code":"fatalError"},{"type":"text","text":"."}],"url":"\/documentation\/forge\/unimplemented(_:file:line:)"},"doc://Forge/documentation/Forge/ContainerInject":{"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","kind":"symbol","url":"\/documentation\/