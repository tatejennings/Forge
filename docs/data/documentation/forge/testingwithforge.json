{"metadata":{"roleHeading":"Article","modules":[{"name":"Forge"}],"role":"article","title":"Testing with Forge"},"abstract":[{"type":"text","text":"Mock dependencies in tests using scoped overrides, container reset, and explicit test contracts."}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order"},{"type":"text","text":" "},{"type":"text","text":"of preference. All examples use Swift Testing ("},{"type":"codeVoice","code":"@Test"},{"type":"text","text":", "},{"type":"codeVoice","code":"@Suite"},{"type":"text","text":", "},{"type":"codeVoice","code":"#expect"},{"type":"text","text":")."}]},{"type":"heading","level":2,"text":"Scoped Overrides with withOverrides (Preferred)","anchor":"Scoped-Overrides-with-withOverrides-Preferred"},{"type":"paragraph","inlineContent":[{"code":"Container\/withOverrides(_:run:)-3qdpl","type":"codeVoice"},{"text":" registers overrides for the duration of a","type":"text"},{"text":" ","type":"text"},{"text":"closure, then automatically restores the previous state. No manual cleanup required:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\\.authService) { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cleanup is guaranteed via "},{"type":"codeVoice","code":"defer"},{"type":"text","text":" — even if the body throws, overrides are restored."},{"type":"text","text":" "},{"type":"text","text":"Both sync and async variants are available:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"Container\/withOverrides(_:run:)-3qdpl","type":"codeVoice"},{"text":" — synchronous","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Container\/withOverrides(_:run:)-4eui2","type":"codeVoice"},{"type":"text","text":" — async (use when your test body contains "},{"code":"await","type":"codeVoice"},{"type":"text","text":")"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Fresh State Between Tests","anchor":"Fresh-State-Between-Tests"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer\/shared"},{"text":" is a stable ","type":"text"},{"type":"codeVoice","code":"let"},{"text":" for the lifetime of the process — you","type":"text"},{"text":" ","type":"text"},{"text":"don’t (and can’t) swap the instance. For test suites where every test needs a clean","type":"text"},{"text":" ","type":"text"},{"text":"slate, reset the shared container in place with ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()"},{"text":" in the","type":"text"},{"text":" ","type":"text"},{"text":"suite’s ","type":"text"},{"type":"codeVoice","code":"init"},{"text":". ","type":"text"},{"type":"codeVoice","code":"resetAll()"},{"text":" clears all cached singletons, cached values, and","type":"text"},{"text":" ","type":"text"},{"text":"registered overrides:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Suite(\"LoginViewModel behavior\", .serialized)","struct LoginViewModelTests {","","    init() {","        AuthContainer.shared.resetAll()","    }","","    @Test(\"Login calls the auth service\")","    func testLoginCallsService() async throws {","        let mock = MockAuthService()","","        try await AuthContainer.shared.withOverrides {","            $0.override(\\.authService) { mock }","        } run: {","            let vm = LoginViewModel()","            await vm.login(username: \"test\", password: \"pass\")","            #expect(mock.loginCalled)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each test gets a fresh starting point with no leftover state from previous tests."},{"type":"text","text":" "},{"type":"text","text":"Mark such suites "},{"type":"codeVoice","code":".serialized"},{"type":"text","text":" so the in-place resets don’t race across tests."}]},{"type":"heading","anchor":"Direct-Overrides-Escape-Hatch","level":2,"text":"Direct Overrides (Escape Hatch)"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"withOverrides","type":"codeVoice"},{"text":" closures are impractical, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)"},{"text":" ","type":"text"},{"text":"directly:","type":"text"}]},{"code":["init() {","    AuthContainer.shared.resetAll()","    AuthContainer.shared.override(\\.authService) { MockAuthService() }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This is the escape hatch — prefer ","type":"text"},{"type":"codeVoice","code":"withOverrides"},{"text":" wherever possible because direct","type":"text"},{"text":" ","type":"text"},{"text":"overrides require manual cleanup via ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/removeOverride(for:)","isActive":true,"type":"reference"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"heading","anchor":"The-TestContainer-Pattern-with-unimplemented","level":2,"text":"The TestContainer Pattern with unimplemented"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"},{"text":" makes dependency contracts explicit — any dependency","type":"text"},{"text":" ","type":"text"},{"text":"that isn’t overridden crashes immediately instead of silently running the wrong code.","type":"text"},{"text":" ","type":"text"},{"text":"This is valuable in tests (shown here) and in cross-module proxies (see","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use it to define a test container where every dependency fails loudly if called"},{"type":"text","text":" "},{"type":"text","text":"without being explicitly overridden:"}]},{"code":["final class TestAuthContainer: AuthContainer {","    override var authService: any AuthServiceProtocol {","        provide { unimplemented(\"authService\") }","    }","","    override var networkClient: any NetworkClientProtocol {","        provide { unimplemented(\"networkClient\") }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Then in your tests, build the test container as an instance, override only what you","type":"text"},{"text":" ","type":"text"},{"text":"need, and resolve through it explicitly with ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","isActive":true},{"text":":","type":"text"}]},{"code":["@Test(\"Login success flow\")","func testLoginSuccess() async throws {","    let container = TestAuthContainer()","","    try await container.withOverrides {","        $0.override(\\.authService) {","            MockAuthService(shouldSucceed: true)","        }","        \/\/ networkClient is unimplemented — if login accidentally","        \/\/ calls it, the test fails loudly instead of silently","        \/\/ executing live code","    } run: {","        let authService = ContainerInject(container, \\.authService).wrappedValue","        let vm = LoginViewModel(authService: authService)","        await vm.login(username: \"user\", password: \"pass\")","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"This makes test contracts explicit — you declare exactly which dependencies a test","type":"text"},{"text":" ","type":"text"},{"text":"exercises. Anything else is a bug.","type":"text"}],"type":"paragraph"},{"style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want the zero-argument "},{"code":"@Inject(\\.x)","type":"codeVoice"},{"type":"text","text":" to resolve from a test container"},{"type":"text","text":" "},{"type":"text","text":"without threading it through initializers, declare that container’s "},{"code":"shared","type":"codeVoice"},{"type":"text","text":" as a"},{"type":"text","text":" "},{"code":"static var","type":"codeVoice"},{"type":"text","text":" (the "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","type":"reference","isActive":true},{"type":"text","text":" requirement is only "},{"code":"{ get }","type":"codeVoice"},{"type":"text","text":", so a "},{"code":"var","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"satisfies it) and assign it in a "},{"code":".serialized","type":"codeVoice"},{"type":"text","text":" suite’s "},{"code":"init","type":"codeVoice"},{"type":"text","text":". Forge permits this;"},{"type":"text","text":" "},{"type":"text","text":"it just isn’t the default — prefer the stable "},{"code":"let","type":"codeVoice"},{"type":"text","text":" plus "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","type":"reference","isActive":true},{"type":"text","text":"."}]}],"type":"aside"},{"level":2,"anchor":"Best-Practices","text":"Best Practices","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Prefer ","type":"text"},{"code":"withOverrides","type":"codeVoice"}]},{"type":"text","text":" — automatic cleanup prevents test state leakage"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Call ","type":"text"},{"code":"resetAll()","type":"codeVoice"},{"text":" in suite ","type":"text"},{"code":"init()","type":"codeVoice"}],"type":"strong"},{"type":"text","text":" — gives each test a fresh starting point"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Use ","type":"text"},{"code":"unimplemented","type":"codeVoice"},{"text":" for test containers","type":"text"}],"type":"strong"},{"type":"text","text":" — makes dependency boundaries explicit"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".serialized"},{"type":"text","text":" on suites"}],"type":"strong"},{"text":" that reset or mutate ","type":"text"},{"code":"shared","type":"codeVoice"},{"text":" — prevents data races","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Use protocol return types"}],"type":"strong"},{"text":" on container properties — this is what makes mocks","type":"text"},{"text":" ","type":"text"},{"text":"substitutable for live implementations","type":"text"}]}]}],"type":"unorderedList"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge"},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"],"title":"Testing and Contracts","anchor":"Testing-and-Contracts"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/test