{"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","interfaceLanguage":"swift"},"metadata":{"title":"Testing with Forge","role":"article","roleHeading":"Article","modules":[{"name":"Forge"}]},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order","type":"text"},{"text":" ","type":"text"},{"text":"of preference. All examples use Swift Testing (","type":"text"},{"type":"codeVoice","code":"@Test"},{"text":", ","type":"text"},{"code":"@Suite","type":"codeVoice"},{"text":", ","type":"text"},{"code":"#expect","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"level":2,"text":"Scoped Overrides with withOverrides (Preferred)","anchor":"Scoped-Overrides-with-withOverrides-Preferred","type":"heading"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl"},{"type":"text","text":" registers overrides for the duration of a"},{"type":"text","text":" "},{"type":"text","text":"closure, then automatically restores the previous state. No manual cleanup required:"}],"type":"paragraph"},{"code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled)","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Cleanup is guaranteed via "},{"type":"codeVoice","code":"defer"},{"type":"text","text":" — even if the body throws, overrides are restored."},{"text":" ","type":"text"},{"text":"Both sync and async variants are available:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","type":"reference"},{"text":" — synchronous","type":"text"}]}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-4eui2","type":"reference"},{"type":"text","text":" — async (use when your test body contains "},{"type":"codeVoice","code":"await"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Container-Swap","level":2,"text":"Container Swap"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For test suites where every test needs a completely fresh container, swap"},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer\/shared","isActive":true,"type":"reference"},{"type":"text","text":" in the suite’s "},{"code":"init","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Suite(\"LoginViewModel behavior\", .serialized)","struct LoginViewModelTests {","","    init() {","        AuthContainer.shared = AuthContainer()","    }","","    @Test(\"Login calls the auth service\")","    func testLoginCallsService() async throws {","        let mock = MockAuthService()","","        try await AuthContainer.shared.withOverrides {","            $0.override(\"authService\") { mock }","        } run: {","            let vm = LoginViewModel()","            await vm.login(username: \"test\", password: \"pass\")","            #expect(mock.loginCalled)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Each test gets a fresh container with no leftover state from previous tests.","type":"text"}]},{"text":"Direct Overrides (Escape Hatch)","level":2,"anchor":"Direct-Overrides-Escape-Hatch","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"withOverrides"},{"type":"text","text":" closures are impractical, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)"},{"type":"text","text":" "},{"type":"text","text":"directly:"}]},{"type":"codeListing","code":["init() {","    AuthContainer.shared = AuthContainer()","    AuthContainer.shared.override(\"authService\") { MockAuthService() }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the escape hatch — prefer "},{"type":"codeVoice","code":"withOverrides"},{"type":"text","text":" wherever possible because direct"},{"type":"text","text":" "},{"text":"overrides require manual cleanup via ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/removeOverride(for:)"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"heading","text":"The TestContainer Pattern with unimplemented","level":2,"anchor":"The-TestContainer-Pattern-with-unimplemented"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"},{"type":"text","text":" to define a test container where every dependency"},{"type":"text","text":" "},{"type":"text","text":"fails loudly if called without being explicitly overridden:"}]},{"code":["final class TestAuthContainer: AuthContainer {","    override var authService: any AuthServiceProtocol {","        provide { unimplemented(\"authService\") }","    }","","    override var networkClient: any NetworkClientProtocol {","        provide { unimplemented(\"networkClient\") }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Then in your tests, swap to the test container and override only what you need:","type":"text"}]},{"type":"codeListing","code":["@Test(\"Login success flow\")","func testLoginSuccess() async throws {","    AuthContainer.shared = TestAuthContainer()","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") {","            MockAuthService(shouldSucceed: true)","        }","        \/\/ networkClient is unimplemented — if login accidentally","        \/\/ calls it, the test fails loudly instead of silently","        \/\/ executing live code","    } run: {","        let vm = LoginViewModel()","        await vm.login(username: \"user\", password: \"pass\")","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This makes test contracts explicit — you declare exactly which dependencies a test"},{"text":" ","type":"text"},{"text":"exercises. Anything else is a bug.","type":"text"}]},{"text":"DEBUG Warnings for Typos","anchor":"DEBUG-Warnings-for-Typos","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"In DEBUG builds, the container emits a runtime warning if an override key is registered"},{"type":"text","text":" "},{"text":"but never accessed during the override scope:","type":"text"}],"type":"paragraph"},{"code":["[Forge] Warning: Override registered for 'authServce' but never accessed.","Check for typos in the override key."],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"text":"This catches common mistakes like misspelling the property name in the override key","type":"text"},{"text":" ","type":"text"},{"text":"string.","type":"text"}]},{"level":2,"text":"Best Practices","type":"heading","anchor":"Best-Practices"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Prefer "},{"code":"withOverrides","type":"codeVoice"}],"type":"strong"},{"text":" — automatic cleanup prevents test sta