{"abstract":[{"type":"text","text":"Mock dependencies in tests using scoped overrides, container swap, and explicit test contracts."}],"seeAlsoSections":[{"title":"Testing","identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"],"generated":true,"anchor":"Testing"}],"variants":[{"paths":["\/documentation\/forge\/testingwithforge"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order"},{"type":"text","text":" "},{"type":"text","text":"of preference. All examples use Swift Testing ("},{"type":"codeVoice","code":"@Test"},{"type":"text","text":", "},{"code":"@Suite","type":"codeVoice"},{"text":", ","type":"text"},{"code":"#expect","type":"codeVoice"},{"type":"text","text":")."}]},{"level":2,"type":"heading","anchor":"Scoped-Overrides-with-withOverrides-Preferred","text":"Scoped Overrides with withOverrides (Preferred)"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","isActive":true,"type":"reference"},{"text":" registers overrides for the duration of a","type":"text"},{"text":" ","type":"text"},{"text":"closure, then automatically restores the previous state. No manual cleanup required:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled