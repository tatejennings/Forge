{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/testingwithforge"]}],"sections":[],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order"},{"type":"text","text":" "},{"type":"text","text":"of preference. All examples use Swift Testing ("},{"code":"@Test","type":"codeVoice"},{"type":"text","text":", "},{"code":"@Suite","type":"codeVoice"},{"type":"text","text":", "},{"code":"#expect","type":"codeVoice"},{"type":"text","text":")."}]},{"type":"heading","text":"Scoped Overrides with withOverrides (Preferred)","level":2,"anchor":"Scoped-Overrides-with-withOverrides-Preferred"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Container\/withOverrides(_:run:)-3qdpl"},{"text":" registers overrides for the duration of a","type":"text"},{"text":" ","type":"text"},{"text":"closure, then automatically restores the previous state. No manual cleanup required:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\\.authService) { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cleanup is guaranteed via "},{"code":"defer","type":"codeVoice"},{"type":"text","text":" — even if the body throws, overrides are restored."},{"type":"text","text":" "},{"type":"text","text":"Both sync and async variants are available:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"Container\/withOverrides(_:run:)-3qdpl"},{"type":"text","text":" — synchronous"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"Container\/withOverrides(_:run:)-4eui2","type":"codeVoice"},{"text":" — async (use when your test body contains ","type":"text"},{"code":"await","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Fresh State Between Tests","level":2,"anchor":"Fresh-State-Between-Tests"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer\/shared","isActive":true,"type":"reference"},{"text":" is a stable ","type":"text"},{"code":"let","type":"codeVoice"},{"text":" for the lifetime of the process — you","type":"text"},{"text":" ","type":"text"},{"text":"don’t (and can’t) swap the instance. For test suites where every test needs a clean","type":"text"},{"text":" ","type":"text"},{"text":"slate, reset the shared container in place with ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","isActive":true,"type":"reference"},{"text":" in the","type":"text"},{"text":" ","type":"text"},{"text":"suite’s ","type":"text"},{"code":"init","type":"codeVoice"},{"text":". ","type":"text"},{"code":"resetAll()","type":"codeVoice"},{"text":" clears all cached singletons, cached values, and","type":"text"},{"text":" ","type":"text"},{"text":"registered overrides:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Suite(\"LoginViewModel behavior\", .serialized)","struct LoginViewModelTests {","","    init() {","        AuthContainer.shared.resetAll()","    }","","    @Test(\"Login calls the auth service\")","    func testLoginCallsService() async throws {","        let mock = MockAuthService()","","        try await AuthContainer.shared.withOverrides {","            $0.override(\\.authService) { mock }","        } run: {","            let vm = LoginViewModel()","            await vm.login(username: \"test\", password: \"pass\")","            #expect(mock.loginCalled)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each test gets a fresh starting point with no leftover state from previous tests."},{"type":"text","text":" "},{"type":"text","text":"Mark such suites "},{"type":"codeVoice","code":".serialized"},{"type":"text","text":" so the in-place resets don’t race across tests."}]},{"type":"heading","text":"Direct Overrides (Escape Hatch)","level":2,"anchor":"Direct-Overrides-Escape-Hatch"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"withOverrides"},{"type":"text","text":" closures are impractical, use "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)","isActive":true},{"type":"text","text":" "},{"type":"text","text":"directly:"}]},{"type":"codeListing","syntax":"swift","code":["init() {","    AuthContainer.shared.resetAll()","    AuthContainer.shared.override(\\.authService) { MockAuthService() }","}"]},{"type":"paragraph","inlineContent":[{"text":"This is the escape hatch — prefer ","type":"text"},{"code":"withOverrides","type":"codeVoice"},{"text":" wherever possible because direct","type":"text"},{"text":" ","type":"text"},{"text":"overrides require manual cleanup via ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/removeOverride(for:)","type":"reference"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","type":"reference"},{"text":".","type":"text"}]},{"type":"heading","text":"The TestContainer Pattern with unimplemented","level":2,"anchor":"The-TestContainer-Pattern-with-unimplemented"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"},{"text":" makes dependency contracts explicit — any dependency","type":"text"},{"text":" ","type":"text"},{"text":"that isn’t overridden crashes immediately instead of silently running the wrong code.","type":"text"},{"text":" ","type":"text"},{"text":"This is valuable in tests (shown here) and in cross-module proxies (see","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use it to define a test container where every dependency fails loudly if called","type":"text"},{"text":" ","type":"text"},{"text":"without being explicitly overridden:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["final class TestAuthContainer: AuthContainer {","    override var authService: any AuthServiceProtocol {","        provide { unimplemented(\"authService\") }","    }","","    override var networkClient: any NetworkClientProtocol {","        provide { unimplemented(\"networkClient\") }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then in your tests, build the test container as an instance, override only what you"},{"type":"text","text":" "},{"type":"text","text":"need, and resolve through it explicitly with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["@Test(\"Login success flow\")","func testLoginSuccess() async throws {","    let container = TestAuthContainer()","","    try await container.withOverrides {","        $0.override(\\.authService) {","            MockAuthService(shouldSucceed: true)","        }","        \/\/ networkClient is unimplemented — if login accidentally","        \/\/ calls it, the test fails loudly instead of silently","        \/\/ executing live code","    } run: {","        let authService = ContainerInject(container, \\.authService).wrappedValue","        let vm = LoginViewModel(authService: authService)","        await vm.login(username: \"user\", password: \"pass\")","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This makes test contracts explicit — you declare exactly which dependencies a test","type":"text"},{"text":" ","type":"text"},{"text":"exercises. Anything else is a bug.","type":"text"}]},{"type":"aside","style":"tip","name":"Tip","content":[{"inlineContent":[{"text":"If you want the zero-argument ","type":"text"},{"code":"@Inject(\\.x)","type":"codeVoice"},{"text":" to resolve from a test container","type":"text"},{"text":" ","type":"text"},{"text":"without threading it through initializers, declare that container’s ","type":"text"},{"code":"shared","type":"codeVoice"},{"text":" as a","type":"text"},{"text":" ","type":"text"},{"code":"static var","type":"codeVoice"},{"text":" (the ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","type":"reference","isActive":true},{"text":" requirement is only ","type":"text"},{"code":"{ get }","type":"codeVoice"},{"text":", so a ","type":"text"},{"code":"var","type":"codeVoice"},{"text":" ","type":"text"},{"text":"satisfies it) and assign it in a ","type":"text"},{"code":".serialized","type":"codeVoice"},{"text":" suite’s ","type":"text"},{"code":"init","type":"codeVoice"},{"text":". Forge permits this;","type":"text"},{"text":" ","type":"text"},{"text":"it just isn’t the default — prefer the stable ","type":"text"},{"code":"let","type":"codeVoice"},{"text":" plus ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}]},{"type":"heading","text":"Best Practices","level":2,"anchor":"Best-Practices"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Prefer ","type":"text"},{"code":"withOverrides","type":"codeVoice"}],"type":"strong"},{"type":"text","text":" — automatic cleanup prevents test state leakage"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Call ","type":"text"},{"type":"codeVoice","code":"resetAll()"},{"text":" in suite ","type":"text"},{"type":"codeVoice","code":"init()"}],"type":"strong"},{"text":" — gives each test a fresh starting point","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"unimplemented"},{"text":" for test containers","type":"text"}]},{"type":"text","text":" — makes dependency boundaries explicit"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":".serialized"},{"text":" on suites","type":"text"}],"type":"strong"},{"type":"text","text":" that reset or mutate "},{"code":"shared","type":"codeVoice"},{"type":"text","text":" — prevents data races"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Use protocol return types"}],"type":"strong"},{"text":" on container properties — this is what makes mocks","type":"text"},{"text":" ","type":"text"},{"text":"substitutable for live implementations","type":"text"}],"type":"paragraph"}]}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"kind":"article","abstract":[{"type":"text","text":"Mock dependencies in tests using scoped overrides, container reset, and explicit test contracts."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge"},"metadata":{"roleHeading":"Article","role":"article","title":"Testing with Forge","modules":[{"name":"Forge"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"seeAlsoSections":[{"title":"Testing and Contracts","identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"],"generated":true,"anc