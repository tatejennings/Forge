{"abstract":[{"type":"text","text":"Mock dependencies in tests using scoped overrides, container swap, and explicit test contracts."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"seeAlsoSections":[{"anchor":"Testing-and-Contracts","identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"],"generated":true,"title":"Testing and Contracts"}],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order"},{"type":"text","text":" "},{"type":"text","text":"of preference. All examples use Swift Testing ("},{"type":"codeVoice","code":"@Test"},{"type":"text","text":", "},{"type":"codeVoice","code":"@Suite"},{"type":"text","text":", "},{"type":"codeVoice","code":"#expect"},{"type":"text","text":")."}]},{"type":"heading","text":"Scoped Overrides with withOverrides (Preferred)","level":2,"anchor":"Scoped-Overrides-with-withOverrides-Preferred"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","type":"reference","isActive":true},{"type":"text","text":" registers overrides for the duration of a"},{"type":"text","text":" "},{"type":"text","text":"closure, then automatically restores the previous state. No manual cleanup required:"}]},{"type":"codeListing","syntax":"swift","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled)","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Cleanup is guaranteed via ","type":"text"},{"code":"defer","type":"codeVoice"},{"text":" — even if the body throws, overrides are restored.","type":"text"},{"text":" ","type":"text"},{"text":"Both sync and async variants are available:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","isActive":true},{"text":" — synchronous","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-4eui2"},{"type":"text","text":" — async (use when your test body contains "},{"type":"codeVoice","code":"await"},{"type":"text","text":")"}]}]}]},{"type":"heading","text":"Container Swap","level":2,"anchor":"Container-Swap"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For test suites where every test needs a completely fresh container, swap"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer\/shared"},{"type":"text","text":" in the suite’s "},{"type":"codeVoice","code":"init"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["@Suite(\"LoginViewModel behavior\", .serialized)","struct LoginViewModelTests {","","    init() {","        AuthContainer.shared = AuthContainer()","    }","","    @Test(\"Login calls the auth service\")","    func testLoginCallsService() async throws {","        let mock = MockAuthService()","","        try await AuthContainer.shared.withOverrides {","            $0.override(\"authService\") { mock }","        } run: {","            let vm = LoginViewModel()","            await vm.login(username: \"test\", password: \"pass\")","            #expect(mock.loginCalled)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each test gets a fresh container with no leftover state from previous tests."}]},{"type":"heading","text":"Direct Overrides (Escape Hatch)","level":2,"anchor":"Direct-Overrides-Escape-Hatch"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"withOverrides"},{"type":"text","text":" closures are impractical, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)"},{"type":"text","text":" "},{"type":"text","text":"directly:"}]},{"type":"codeListing","syntax":"swift","code":["init() {","    AuthContainer.shared = AuthContainer()","    AuthContainer.shared.override(\"authService\") { MockAuthService() }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the escape hatch — prefer "},{"type":"codeVoice","code":"withOverrides"},{"type":"text","text":" wherever possible because direct"},{"type":"text","text":" "},{"type":"text","text":"overrides require manual cleanup via "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/removeOverride(for:)","isActive":true},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","isActive":true},{"type":"text","text":"."}]},{"type":"heading","text":"The TestContainer Pattern with unimplemented","level":2,"anchor":"The-TestContainer-Pattern-with-unimplemented"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true},{"type":"text","text":" makes dependency contracts explicit — any dependency"},{"type":"text","text":" "},{"type":"text","text":"that isn’t overridden crashes immediately instead of silently running the wrong code."},{"type":"text","text":" "},{"type":"text","text":"This is valuable in tests (shown here) and in cross-module proxies (see"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","isActive":true},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"text":"Use it to define a test container where every dependency fails loudly if called","type":"text"},{"text":" ","type":"text"},{"text":"without being explicitly overridden:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["final class TestAuthContainer: AuthContainer {","    override var authService: any AuthServiceProtocol {","        provide { unimplemented(\"authService\") }","    }","","    override var networkClient: any NetworkClientProtocol {","        provide { unimplemented(\"networkClient\") }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Then in your tests, swap to the test container and override only what you need:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Test(\"Login success flow\")","func testLoginSuccess() async throws {","    AuthContainer.shared = TestAuthContainer()","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") {","            MockAuthService(shouldSucceed: true)","        }","        \/\/ networkClient is unimplemented — if login accidentally","        \/\/ calls it, the test fails loudly instead of silently","        \/\/ executing live code","    } run: {","        let vm = LoginViewModel()","        await vm.login(username: \"user\", password: \"pass\")","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This makes test contracts explicit — you declare exactly which dependencies a test","type":"text"},{"text":" ","type":"text"},{"text":"exercises. Anything else is a bug.","type":"text"}]},{"type":"heading","text":"DEBUG Warnings for Typos","level":2,"anchor":"DEBUG-Warnings-for-Typos"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In DEBUG builds, the container emits a runtime warning if an override key is registered"},{"type":"text","text":" "},{"type":"text","text":"but never accessed during the override scope:"}]},{"type":"codeListing","syntax":null,"code":["[Forge] Warning: Override registered for 'authServce' but never accessed.","Check for typos in the override key."]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This catches common mistakes like misspelling the property name in the override key"},{"type":"text","text":" "},{"type":"text","text":"string."}]},{"type":"heading","text":"Best Practices","level":2,"anchor":"Best-Practices"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Prefer "},{"type":"codeVoice","code":"withOverrides"}],"type":"strong"},{"text":" — automatic cleanup prevents test state leakage","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Swap containers in suite "},{"code":"init()","type":"codeVoice"}],"type":"strong"},{"text":" — gives each test a fresh starting point","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Use ","type":"text"},{"code":"unimplemented","type":"codeVoice"},{"text":" for test containers","type":"text"}],"type":"strong"},{"type":"text","text":" — makes dependency boundaries explicit"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Use "},{"code":".serialized","type":"codeVoice"},{"type":"text","text":" on suites"}],"type":"strong"},{"text":" that swap ","type":"text"},{"code":"shared","type":"codeVoice"},{"text":" — prevents data races","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Override keys must match property names exactly"}],"type":"strong"},{"text":" — the key defaults to ","type":"text"},{"code":"#function","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which is the computed property name","type":"text"}]}