{"abstract":[{"type":"text","text":"Mock dependencies in tests using scoped overrides, container swap, and explicit test contracts."}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"],"anchor":"Testing","title":"Testing"}],"variants":[{"paths":["\/documentation\/forge\/testingwithforge"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of preference. All examples use Swift Testing ("},{"type":"codeVoice","code":"@Test"},{"type":"text","text":", "},{"type":"codeVoice","code":"@Suite"},{"type":"text","text":", "},{"type":"codeVoice","code":"#expect"},{"type":"text","text":")."}]},{"type":"heading","anchor":"Scoped-Overrides-with-withOverrides-Preferred","text":"Scoped Overrides with withOverrides (Preferred)","level":2},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","isActive":true},{"type":"text","text":" registers overrides for the duration of a"},{"type":"text","text":" "},{"type":"text","text":"closure, then automatically restores the previous state. No manual cleanup required:"}]},{"type":"codeListing","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Cleanup is guaranteed via ","type":"text"},{"code":"defer","type":"codeVoice"},{"text":" — even if the body throws, overrides are restored.","type":"text"},{"text":" ","type":"text"},{"text":"Both sync and async variants are available:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","isActive":true,"type":"reference"},{"text":" — synchronous","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-4eui2"},{"text":" — async (use when your test body contains ","type":"text"},{"code":"await","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Container Swap","anchor":"Container-Swap","type":"heading"},{"inlineContent":[{"text":"For test suites where every test needs a completely fresh container, swap","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer\/shared","isActive":true,"type":"reference"},{"text":" in the suite’s ","type":"text"},{"code":"init","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["@Suite(\"LoginViewModel behavior\", .serialized)","struct LoginViewModelTests {","","    init() {","        AuthContainer.shared = AuthContainer()","    }","","    @Test(\"Login calls the auth service\")","    func testLoginCallsService() async throws {","        let mock = MockAuthService()","","        try await AuthContainer.shared.withOverrides {","            $0.override(\"authService\") { mock }","        } run: {","            let vm = LoginViewModel()","            await vm.login(username: \"test\", password: \"pass\")","            #expect(mock.loginCalled)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Each test gets a fresh container with no leftover state from previous tests.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Direct Overrides (Escape Hatch)","anchor":"Direct-Overrides-Escape-Hatch","type":"heading"},{"inlineContent":[{"text":"When ","type":"text"},{"code":"withOverrides","type":"codeVoice"},{"text":" closures are impractical, use ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"directly:","type":"text"}],"type":"paragraph"},{"code":["init() {","    AuthContainer.shared = AuthContainer()","    AuthContainer.shared.override(\"authService\") { MockAuthService() }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This is the escape hatch — prefer ","type":"text"},{"code":"withOverrides","type":"codeVoice"},{"text":" wherever possible because direct","type":"text"},{"text":" ","type":"text"},{"text":"overrides require manual cleanup via ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/removeOverride(for:)","isActive":true,"type":"reference"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"The TestContainer Pattern with unimplemented","anchor":"The-TestContainer-Pattern-with-unimplemented","type":"heading"},{"inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true,"type":"reference"},{"text":" to define a test container where every dependency","type":"text"},{"text":" ","type":"text"},{"text":"fails loudly if called without being explicitly overridden:","type":"text"}],"type":"paragraph"},{"code":["final class TestAuthContainer: AuthContainer {","    override var authService: any AuthServiceProtocol {","        provide { unimplemented(\"authService\") }","    }","","    override var networkClient: any NetworkClientProtocol {","        provide { unimplemented(\"networkClient\") }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Then in your tests, swap to the test container and override only what you need:","type":"text"}],"type":"paragraph"},{"code":["@Test(\"Login success flow\")","func testLoginSuccess() async throws {","    AuthContainer.shared = TestAuthContainer()","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") {","            MockAuthService(shouldSucceed: true)","        }","        \/\/ networkClient is unimplemented — if login accidentally","        \/\/ calls it, the test fails loudly instead of silently","        \/\/ executing live code","    } run: {","        let vm = LoginViewModel()","        await vm.login(username: \"user\", password: \"pass\")","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This makes test contracts explicit — you declare exactly which dependencies a test","type":"text"},{"text":" ","type":"text"},{"text":"exercises. Anything else is a bug.","type":"text"}],"type":"paragraph"},{"level":2,"text":"DEBUG Warnings for Typos","anchor":"DEBUG-Warnings-for-Typos","type":"heading"},{"inlineContent":[{"text":"In DEBUG builds, the container emits a runtime warning if an override key is registered","type":"text"},{"text":" ","type":"text"},{"text":"but never accessed during the override scope:","type":"text"}],"type":"paragraph"},{"code":["[Forge] Warning: Override registered for 'authServce' but never accessed.","Check for typos in the override key."],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"This catches common mistakes like misspelling the 