{"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"inlineContent":[{"text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order","type":"text"},{"text":" ","type":"text"},{"text":"of preference. All examples use Swift Testing (","type":"text"},{"code":"@Test","type":"codeVoice"},{"text":", ","type":"text"},{"code":"@Suite","type":"codeVoice"},{"text":", ","type":"text"},{"code":"#expect","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Scoped-Overrides-with-withOverrides-Preferred","type":"heading","text":"Scoped Overrides with withOverrides (Preferred)"},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","type":"reference"},{"text":" registers overrides for the duration of a","type":"text"},{"text":" ","type":"text"},{"text":"closure, then automatically restores the previous state. No manual cleanup required:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled)","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Cleanup is guaranteed via ","type":"text"},{"code":"defer","type":"codeVoice"},{"text":" — even if the body throws, overrides are restored.","type":"text"},{"text":" ","type":"text"},{"text":"Both sync and async variants are available:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","isActive":true},{"type":"text","text":" — synchronous"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-4eui2"},{"type":"text","text":" — async (use when your test body contains "},{"code":"await","type":"codeVoice"},{"type":"text","text":")"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Container-Swap","type":"heading","text":"Container Swap"},{"inlineContent":[{"text":"For test suites where every test needs a completely fresh container, swap","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer\/shared","type":"reference"},{"text":" in the suite’s ","type":"text"},{"type":"codeVoice","code":"init"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@Suite(\"LoginViewModel behavior\", .serialized)","struct LoginViewModelTests {","","    init() {","        AuthContainer.shared = AuthContainer()","    }","","    @Test(\"Login calls the auth service\")","    func testLoginCallsService() async throws {","        let mock = MockAuthService()","","        try await AuthContainer.shared.withOverrides {","            $0.override(\"authService\") { mock }","        } run: {","            let vm = LoginViewModel()","            await vm.login(username: \"test\", password: \"pass\")","            #expect(mock.loginCalled)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Each test gets a fresh container with no leftover state from previous tests.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Direct Overrides (Escape Hatch)","type":"heading","anchor":"Direct-Overrides-Escape-Hatch"},{"inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"withOverrides"},{"type":"text","text":" closures are impractical, use "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"directly:"}],"type":"paragraph"},{"syntax":"swift","code":["init() {","    AuthContainer.shared = AuthContainer()","    AuthContainer.shared.override(\"authService\") { MockAuthService() }","}"],"type":"codeListing"},{"inlineContent":[{"text":"This is the escape hatch — prefer ","type":"text"},{"type":"codeVoice","code":"withOverrides"},{"text":" wherever possible because direct","type":"text"},{"text":" ","type":"text"},{"text":"overrides require manual cleanup via ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/removeOverride(for:)","isActive":true,"type":"reference"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"The TestContainer Pattern with unimplemented","type":"heading","anchor":"The-TestContainer-Pattern-with-unimplemented"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true},{"type":"text","text":" to define a test container where every dependency"},{"type":"text","text":" "},{"type":"text","text":"fails loudly if called without being explicitly overridden:"}],"type":"paragraph"},{"syntax":"swift","code":["final class TestAuthContainer: AuthContainer {","    override var authService: any AuthServiceProtocol {","        provide { unimplemented(\"authService\") }","    }","","    override var networkClient: any NetworkClientProtocol {","        provide { unimplemented(\"networkClient\") }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then in your tests, swap to the test container and override only what you need:"}],"type":"paragraph"},{"syntax":"swift","code":["@Test(\"Login success flow\")","func testLoginSuccess() async throws {","    AuthContainer.shared = TestAuthContainer()","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") {","            MockAuthService(shouldSucceed: true)","        }","        \/\/ networkClient is unimplemented — if login accidentally","        \/\/ calls it, the test fails loudly instead of silently","        \/\/ executing live code","    } run: {","        let vm = LoginViewModel()","        await vm.login(username: \"user\", password: \"pass\")","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This makes test contracts explicit — you declare exactly which dependencies a test"},{"type":"text","text":" "},{"type":"text","text":"exercises. Anything else is a bug."}],"type":"paragraph"},{"anchor":"DEBUG-Warnings-for-Typos","text":"DEBUG Warnings for Typos","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In DEBUG builds, the container emits a runtime warning if an override key is registered"},{"type":"text","text":" "},{"type":"text","text":"but never accessed during the override scope:"}]},{"syntax":null,"type":"codeListing","code":["[Forge] Warning: Override registered for 'authServce' but never accessed.","Check for typos in the override key."]},{"type":"paragraph","inlineContent":[{"text":"This catches common mistakes like misspelling the property name in the override key","type":"text"},{"text":" ","type":"text"},{"text":"string.","type":"text"}]},{"anchor":"Best-Practices","text":"Best Practices","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Prefer "},{"type":"codeVoice","code":"withOverrides"}]},{"text":" — automatic cleanup prevents test state leakage","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Swap containers in suite "},{"code":"init()","type":"codeVoice"}],"type":"strong"},{"type":"text","text":" — gives each test a fresh starting point"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"unimplemented"},{"text":" for test containers","type":"text"}],"type":"strong"},{"text":" — makes dependency boundaries explicit","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Use ","type":"text"},{"code":".serialized","type":"codeVoice"},{"text":" on suites","type":"text"}],"type":"strong"},{"text":" that swap ","type":"text"},{"code":"shared","type":"codeVoice"},{"text":" — prevents data races","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Override keys must match property names exactly","type":"text"}],"type":"strong"},{"text":" — the key defaults to ","type":"text"},{"code":"#function","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which is the computed property name","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Use protocol return types","type":"text"}]},{"type":"text","text":" on container properties — this is what makes mocks"},{"type":"text","text":" "},{"type":"text","text":"substitutable for live implementations"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/testingwithforge"]}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","interfaceLanguage":"swift"},"sections":[],"abstract":[{"type":"text","text":"Mock dependencies in tests using scoped overrides, container swap, and explicit test contracts."}],"kind":"article","seeAlsoSections":[{"anchor":"Testing","title":"Testing","identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/uni