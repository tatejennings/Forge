{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order"},{"type":"text","text":" "},{"type":"text","text":"of preference. All examples use Swift Testing ("},{"code":"@Test","type":"codeVoice"},{"type":"text","text":", "},{"code":"@Suite","type":"codeVoice"},{"type":"text","text":", "},{"code":"#expect","type":"codeVoice"},{"type":"text","text":")."}]},{"type":"heading","anchor":"Scoped-Overrides-with-withOverrides-Preferred","level":2,"text":"Scoped Overrides with withOverrides (Preferred)"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Container\/withOverrides(_:run:)-3qdpl"},{"type":"text","text":" registers overrides for the duration of a"},{"type":"text","text":" "},{"type":"text","text":"closure, then automatically restores the previous state. No manual cleanup required:"}]},{"syntax":"swift","type":"codeListing","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\\.authService) { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cleanup is guaranteed via "},{"type":"codeVoice","code":"defer"},{"type":"text","text":" — even if the body throws, overrides are restored."},{"type":"text","text":" "},{"type":"text","text":"Both sync and async variants are available:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"Container\/withOverrides(_:run:)-3qdpl","type":"codeVoice"},{"type":"text","text":" — synchronous"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Container\/withOverrides(_:run:)-4eui2"},{"type":"text","text":" — async (use when your test body contains "},{"type":"codeVoice","code":"await"},{"type":"text","text":")"}]}]}]},{"type":"heading","anchor":"Container-Swap","level":2,"text":"Container Swap"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For test suites where every test needs a completely fresh container, swap"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer\/shared","isActive":true},{"type":"text","text":" in the suite’s "},{"type":"codeVoice","code":"init"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["@Suite(\"LoginViewModel behavior\", .serialized)","struct LoginViewModelTests {","","    init() {","        AuthContainer.shared = AuthContainer()","    }","","    @Test(\"Login calls the auth service\")","    func testLoginCallsService() async throws {","        let mock = MockAuthService()","","        try await AuthContainer.shared.withOverrides {","            $0.override(\\.authService) { mock }","        } run: {","            let vm = LoginViewModel()","            await vm.login(username: \"test\", password: \"pass\")","            #expect(mock.loginCalled)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Each test gets a fresh container with no leftover state from previous tests.","type":"text"}]},{"type":"heading","anchor":"Direct-Overrides-Escape-Hatch","level":2,"text":"Direct Overrides (Escape Hatch)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"withOverrides"},{"type":"text","text":" closures are impractical, use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)"},{"type":"text","text":" "},{"type":"text","text":"directly:"}]},{"syntax":"swift","type":"codeListing","code":["init() {","    AuthContainer.shared = AuthContainer()","    AuthContainer.shared.override(\\.authService) { MockAuthService() }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the escape hatch — prefer "},{"code":"withOverrides","type":"codeVoice"},{"type":"text","text":" wherever possible because direct"},{"type":"text","text":" "},{"type":"text","text":"overrides require manual cleanup via "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/removeOverride(for:)","isActive":true,"type":"reference"},{"type":"text","text":" or"},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"type":"heading","anchor":"The-TestContainer-Pattern-with-unimplemented","level":2,"text":"The TestContainer Pattern with unimplemented"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true},{"text":" makes dependency contracts explicit — any dependency","type":"text"},{"text":" ","type":"text"},{"text":"that isn’t overridden crashes immediately instead of silently running the wrong code.","type":"text"},{"text":" ","type":"text"},{"text":"This is valuable in tests (shown here) and in cross-module proxies (see","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","isActive":true},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use it to define a test container where every dependency fails loudly if called","type":"text"},{"text":" ","type":"text"},{"text":"without being explicitly overridden:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["final class TestAuthContainer: AuthContainer {","    override var authService: any AuthServiceProtocol {","        provide { unimplemented(\"authService\") }","    }","","    override var networkClient: any NetworkClientProtocol {","        provide { unimplemented(\"networkClient\") }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then in your tests, swap to the test container and override only what you need:"}]},{"syntax":"swift","type":"codeListing","code":["@Test(\"Login success flow\")","func testLoginSuccess() async throws {","    AuthContainer.shared = TestAuthContainer()","","    try await AuthContainer.shared.withOverrides {","        $0.override(\\.authService) {","            MockAuthService(shouldSucceed: true)","        }","        \/\/ networkClient is unimplemented — if login accidentally","        \/\/ calls it, the test fails loudly instead of silently","        \/\/ executing live code","    } run: {","        let vm = LoginViewModel()","        await vm.login(username: \"user\", password: \"pass\")","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This makes test contracts explicit — you declare exactly which dependencies a test","type":"text"},{"text":" ","type":"text"},{"text":"exercises. Anything else is a bug.","type":"text"}]},{"type":"heading","anchor":"Best-Practices","level":2,"text":"Best Practices"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Prefer ","type":"text"},{"code":"withOverrides","type":"codeVoice"}]},{"type":"text","text":" — automatic cleanup prevents test state leakage"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Swap containers in suite "},{"type":"codeVoice","code":"init()"}],"type":"strong"},{"type":"text","text":" — gives each test a fresh starting point"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"unimplemented"},{"type":"text","text":" for test containers"}]},{"text":" — makes dependency boundaries explicit","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Use ","type":"text"},{"code":".serialized","type":"codeVoice"},{"text":" on suites","type":"text"}],"type":"strong"},{"type":"text","text":" that swap "},{"code":"shared","type":"codeVoice"},{"type":"text","text":" — prevents data races"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Use protocol return types","type":"text"}],"type":"strong"},{"type":"text","text":" on container properties — this is what makes mocks"},{"type":"text","text":" "},{"type":"text","text":"substitutable for live implementations"}]}]}]}],"kind":"content"}],"abstract":[{"text":"Mock dependencies in tests using scoped overrides, container swap, and explicit test contracts.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/testingwithforge"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge"},"seeAlsoSections":[{"generated":true,"title":"Testing and Contracts","identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"],"anchor":"Testing-and-Contracts"}],"kind":"article","metadata":{"modules":[{"name":"Forge"}],"roleHeading":"Article","role":"article","title":"Testing with Forge"},"references":{"doc://Forge/documentation/Forge/Container/override(_:with:)":{"kind":"symbol","url":"\/documentation\/forge\/container\/override(_:with:)","type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)","role":"symbol","title":"override(_:with:)","abstract":[{"text":"Overrides the dependency at the given KeyPath with the provided factory.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"override","kind":"identi