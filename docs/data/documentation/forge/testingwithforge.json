{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/testingwithforge"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge"},"seeAlsoSections":[{"anchor":"Testing-and-Contracts","generated":true,"identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"],"title":"Testing and Contracts"}],"sections":[],"abstract":[{"text":"Mock dependencies in tests using scoped overrides, container reset, and explicit test contracts.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"article","metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"Forge"}],"title":"Testing with Forge"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order","type":"text"},{"text":" ","type":"text"},{"text":"of preference. All examples use Swift Testing (","type":"text"},{"type":"codeVoice","code":"@Test"},{"text":", ","type":"text"},{"type":"codeVoice","code":"@Suite"},{"text":", ","type":"text"},{"type":"codeVoice","code":"#expect"},{"text":").","type":"text"}]},{"type":"heading","text":"Scoped Overrides with withOverrides (Preferred)","level":2,"anchor":"Scoped-Overrides-with-withOverrides-Preferred"},{"type":"paragraph","inlineContent":[{"code":"Container\/withOverrides(_:run:)-3qdpl","type":"codeVoice"},{"text":" registers overrides for the duration of a","type":"text"},{"text":" ","type":"text"},{"text":"closure, then automatically restores the previous state. No manual cleanup required:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async t