{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Forge provides three mechanisms for overriding dependencies in tests, listed in order","type":"text"},{"text":" ","type":"text"},{"text":"of preference. All examples use Swift Testing (","type":"text"},{"code":"@Test","type":"codeVoice"},{"text":", ","type":"text"},{"code":"@Suite","type":"codeVoice"},{"text":", ","type":"text"},{"code":"#expect","type":"codeVoice"},{"text":").","type":"text"}]},{"type":"heading","text":"Scoped Overrides with withOverrides (Preferred)","anchor":"Scoped-Overrides-with-withOverrides-Preferred","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","type":"reference"},{"text":" registers overrides for the duration of a","type":"text"},{"text":" ","type":"text"},{"text":"closure, then automatically restores the previous state. No manual cleanup required:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Test(\"Login succeeds with valid credentials\")","func testLoginSuccess() async throws {","    let mock = MockAuthService(shouldSucceed: true)","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") { mock }","    } run: {","        let viewModel = LoginViewModel()","        await viewModel.login(username: \"user\", password: \"pass\")","        #expect(mock.loginCalled)","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Cleanup is guaranteed via ","type":"text"},{"code":"defer","type":"codeVoice"},{"text":" — even if the body throws, overrides are restored.","type":"text"},{"text":" ","type":"text"},{"text":"Both sync and async variants are available:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","type":"reference","isActive":true},{"text":" — synchronous","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-4eui2","type":"reference","isActive":true},{"text":" — async (use when your test body contains ","type":"text"},{"code":"await","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Container Swap","anchor":"Container-Swap","level":2},{"type":"paragraph","inlineContent":[{"text":"For test suites where every test needs a completely fresh container, swap","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer\/shared","type":"reference"},{"text":" in the suite’s ","type":"text"},{"code":"init","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Suite(\"LoginViewModel behavior\", .serialized)","struct LoginViewModelTests {","","    init() {","        AuthContainer.shared = AuthContainer()","    }","","    @Test(\"Login calls the auth service\")","    func testLoginCallsService() async throws {","        let mock = MockAuthService()","","        try await AuthContainer.shared.withOverrides {","            $0.override(\"authService\") { mock }","        } run: {","            let vm = LoginViewModel()","            await vm.login(username: \"test\", password: \"pass\")","            #expect(mock.loginCalled)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Each test gets a fresh container with no leftover state from previous tests.","type":"text"}]},{"type":"heading","text":"Direct Overrides (Escape Hatch)","anchor":"Direct-Overrides-Escape-Hatch","level":2},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"withOverrides","type":"codeVoice"},{"text":" closures are impractical, use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/override(_:with:)","type":"reference"},{"text":" ","type":"text"},{"text":"directly:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["init() {","    AuthContainer.shared = AuthContainer()","    AuthContainer.shared.override(\"authService\") { MockAuthService() }","}"]},{"type":"paragraph","inlineContent":[{"text":"This is the escape hatch — prefer ","type":"text"},{"code":"withOverrides","type":"codeVoice"},{"text":" wherever possible because direct","type":"text"},{"text":" ","type":"text"},{"text":"overrides require manual cleanup via ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/removeOverride(for:)","type":"reference"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetAll()","type":"reference"},{"text":".","type":"text"}]},{"type":"heading","text":"The TestContainer Pattern with unimplemented","anchor":"The-TestContainer-Pattern-with-unimplemented","level":2},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","type":"reference"},{"text":" to define a test container where every dependency","type":"text"},{"text":" ","type":"text"},{"text":"fails loudly if called without being explicitly overridden:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["final class TestAuthContainer: AuthContainer {","    override var authService: any AuthServiceProtocol {","        provide { unimplemented(\"authService\") }","    }","","    override var networkClient: any NetworkClientProtocol {","        provide { unimplemented(\"networkClient\") }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Then in your tests, swap to the test container and override only what you need:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Test(\"Login success flow\")","func testLoginSuccess() async throws {","    AuthContainer.shared = TestAuthContainer()","","    try await AuthContainer.shared.withOverrides {","        $0.override(\"authService\") {","            MockAuthService(shouldSucceed: true)","        }","        \/\/ networkClient is unimplemented — if login accidentally","        \/\/ calls it, the test fails loudly instead of silently","        \/\/ executing live code","    } run: {","        let vm = LoginViewModel()","        await vm.login(username: \"user\", password: \"pass\")","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This makes test contracts explicit — you declare exactly which dependencies a test","type":"text"},{"text":" ","type":"text"},{"text":"exercises. Anything else is a bug.","type":"text"}]},{"type":"heading","text":"DEBUG Warnings for Typos","anchor":"DEBUG-Warnings-for-Typos","level":2},{"type":"paragraph","inlineContent":[{"text":"In DEBUG builds, the container emits a runtime warning if an override key is registered","type":"text"},{"text":" ","type":"text"},{"text":"but never accessed during the override scope:","type":"text"}]},{"type":"codeListing","syntax":null,"code":["[Forge] Warning: Override registered for 'authServce' but never accessed.","Check for typos in the override key."]},{"type":"paragraph","inlineContent":[{"text":"This catches common mistakes like misspelling the property name in the override key","type":"text"},{"text":" ","type":"text"},{"text":"string.","type":"text"}]},{"type":"heading","text":"Best Practices","anchor":"Best-Practices","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Prefer ","type":"text"},{"type":"codeVoice","code":"withOverrides"}],"type":"strong"},{"type":"text","text":" — automatic cleanup prevents test state leakage"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Swap containers in suite ","type":"text"},{"code":"init()","type":"codeVoice"}],"type":"strong"},{"text":" — gives each test a fresh starting point","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"unimplemented"},{"text":" for test containers","type":"text"}],"type":"strong"},{"text":" — makes dependency boundaries explicit","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":".serialized"},{"text":" on suites","type":"text"}],"type":"strong"},{"text":" that swap ","type":"text"},{"code":"shared","type":"codeVoice"},{"text":" — prevents data races","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Override keys must match property names exactly","type":"text"}],"type":"strong"},{"text":" — the key defaults to ","type":"text"},{"type":"codeVoice","code":"#function"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which is the computed property name","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Use protocol return types","type":"text"}],"type":"strong"},{"text":" on container properties — this is what makes mocks","type":"text"},{"text":" ","type":"text"},{"text":"substitutable for live implementations","type":"text"}],"type":"paragraph"}]}]}]}],"sections":[],"seeAlsoSections":[{"generated":true,"anchor":"Testing","title":"Testing","identifiers":["doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"Forge"}],"roleHeading":"Article","title":"Testing with Forge","role":"article"},"kind":"article","abstract":[{"type":"text","text":"Mo