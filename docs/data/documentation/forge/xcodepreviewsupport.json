{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"},"sections":[],"kind":"article","abstract":[{"type":"text","text":"Provide preview-safe mock factories that activate automatically in Xcode Previews."}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Dependencies that hit the network, access the file system, or perform heavy"},{"type":"text","text":" "},{"type":"text","text":"computation are problematic in Xcode Previews. Forge lets you provide a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" "},{"type":"text","text":"factory that is used automatically when running inside a preview — no conditional"},{"type":"text","text":" "},{"type":"text","text":"checks needed in your view code."}]},{"type":"heading","level":2,"text":"The preview Parameter","anchor":"The-preview-Parameter"},{"type":"paragraph","inlineContent":[{"text":"Pass a ","type":"text"},{"code":"preview","type":"codeVoice"},{"text":" closure to ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","isActive":true,"type":"reference"},{"text":" alongside the","type":"text"},{"text":" ","type":"text"},{"text":"normal factory:","type":"text"}]},{"type":"codeListing","code":["public var authService: any AuthServiceProtocol {","    provide(.singleton) {","        AuthService(network: self.networkClient)","    } preview: {","        MockAuthService()","    }","}","","public var networkClient: any NetworkClientProtocol {","    provide(.singleton) {","        URLSessionNetworkClient()","    } preview: {","        MockNetworkClient()","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the code runs inside an Xcode Preview, "},{"type":"codeVoice","code":"MockAuthService()"},{"type":"text","text":" is returned. In"},{"type":"text","text":" "},{"type":"text","text":"production, "},{"type":"codeVoice","code":"AuthService(network:)"},{"type":"text","text":" is returned."}]},{"type":"heading","level":2,"text":"How Preview Detection Works","anchor":"How-Preview-Detection-Works"},{"type":"paragraph","inlineContent":[{"text":"Forge detects the preview environment by checking for the ","type":"text"},{"type":"codeVoice","code":"XCODE_RUNNING_FOR_PREVIEWS"},{"text":" ","type":"text"},{"text":"environment variable, which Xcode sets to ","type":"text"},{"type":"codeVoice","code":"\"1\""},{"text":" when rendering previews. This is the","type":"text"},{"text":" ","type":"text"},{"text":"standard detection mechanism used across the Swift community.","type":"text"}]},{"type":"heading","level":3,"text":"Resolution Precedence","anchor":"Resolution-Precedence"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","isActive":true},{"text":" is called, resolution follows this order:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Overrides","type":"text"}]},{"type":"text","text":" — always checked first (test overrides take priority)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Preview factory"}],"type":"strong"},{"type":"text","text":" — used if running in a preview and a "},{"code":"preview","type":"codeVoice"},{"type":"text","text":" closure was provided"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Normal factory"}]},{"type":"text","text":" — the default production path"}],"type":"paragraph"}]}]},{"level":2,"text":"Preview Values Are Never Cached","type":"heading","anchor":"Preview-Values-Are-Never-Cached"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Preview factories are called fresh on every resolution, regardless of the declared"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"type":"text","text":". Even if a dependency is registered as "},{"type":"codeVoice","code":".singleton"},{"type":"text","text":", the preview factory"},{"type":"text","text":" "},{"type":"text","text":"runs every time in a preview context. This ensures previews always reflect the latest"},{"type":"text","text":" "},{"type":"text","text":"mock state."}]},{"level":2,"text":"When to Provide a Preview Factory","type":"heading","anchor":"When-to-Provide-a-Preview-Factory"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Provide one for:","type":"text"}],"type":"strong"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Network clients and API services"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Database and file system access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Analytics and logging services","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Any dependency that performs I\/O or has side effects","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Skip it for:"}]}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Pure in-memory services (formatters, validators, parsers)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Simple value types or data transformations","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dependencies that already work correctly without network access"}]}]}],"type":"unorderedList"},{"level":2,"text":"Multiple Preview Variants","type":"heading","anchor":"Multiple-Preview-Variants"},{"type":"paragraph","inlineContent":[{"text":"Use different overrides within ","type":"text"},{"code":"#Preview","type":"codeVoice"},{"text":" blocks to show different states:","type":"text"}]},{"code":["#Preview(\"Logged In\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: true)","    }","    return ProfileView()","}","","#Preview(\"Logged Out\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: false)","    }","    return ProfileView()","}","","#Preview(\"Error State\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(shouldFail: true)","    }","    return ProfileView()","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"This lets you preview the same view in multiple states without changing any production","type":"text"},{"text":" ","type":"text"},{"text":"code.","type":"text"}]},{"anchor":"Testing-Preview-Behavior","text":"Testing Preview Behavior","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The framework includes an internal ","type":"text"},{"type":"codeVoice","code":"_isPreviewOverride"},{"text":" property (accessible via","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"@testable import"},{"text":") that lets tests simulate the preview environment:","type":"text"}]},{"code":["@testable import Forge","","PreviewContext._isPreviewOverride = true","defer { PreviewContext._isPreviewOverride = nil }","","\/\/ Dependencies now use their preview factories","let service = MyContainer.shared.authService","\/\/ service is MockAuthService"],"type":"codeListing","syntax":"swift"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Tests using ","type":"text"},{"type":"codeVoice","code":"_isPreviewOverride"},{"text":" must be marked ","type":"text"},{"type":"codeVoice","code":".serialized"},{"text":" to prevent","type":"text"},{"text":" ","type":"text"},{"text":"data races, since this is a global mutable state.","type":"text"}]}]}]}],"metadata":{"role":"article","modules":[{"name":"Forge"}],"roleHeading":"Article","title":"Xcode Preview Support"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/xcodepreviewsupport"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"generated":true,"anchor":"Architecture-and-Best-Practices","title":"Architecture and Best Practices","identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"]}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"references":{"doc://Forge/documentation/Forge/Container":{"title":"Container","role":"symbol","navigatorTitle":[{"text":"Container","kind":"identifier"}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Container","kind":"identifier"}],"type":"topic","url":"\/documentation\/forge\/container","abstract":[{"text":"The base class for all dependency containers in Forge.","type":"text"}]},"doc://Forge/documentation/Forge/SOLIDPrinciples":{"kind":"article","role":"article","type":"topic","title":"SOLID Principles with Forge","identifier":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","url":"\/documentation\/forge\/solidprinciples","abstract":[{"type":"text","text":"How each SOLID principle maps to Forge usage, with practical Swift examples."}]},"doc://Forge/documentation/Forge":{"kind":"symbol","abstract":[{"text":"A lightweight dependency injection framework for Swift — compile-time-safe at the call site, with loud, fail-fast runtime checks underneath.","type":"text"}],"type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge","title":"Forge","role":"collection","url":"\/documentation\/forge"},"doc://Forge/documentation/Forge/Scope":{"role":"symbol","abstract":[{"type":"text","text":"Defines the lifecycle of a dep