production path","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Preview-Values-Are-Never-Cached","text":"Preview Values Are Never Cached","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Preview factories are called fresh on every resolution, regardless of the declared"},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","type":"reference","isActive":true},{"type":"text","text":". Even if a dependency is registered as "},{"type":"codeVoice","code":".singleton"},{"type":"text","text":", the preview factory"},{"type":"text","text":" "},{"text":"runs every time in a preview context. This ensures previews always reflect the latest","type":"text"},{"type":"text","text":" "},{"type":"text","text":"mock state."}],"type":"paragraph"},{"anchor":"When-to-Provide-a-Preview-Factory","type":"heading","text":"When to Provide a Preview Factory","level":2},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Provide one for:"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network clients and API services"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Database and file system access"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Analytics and logging services"}]}]},{"content":[{"inlineContent":[{"text":"Any dependency that performs I\/O or has side effects","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Skip it for:"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Pure in-memory services (formatters, validators, parsers)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Simple value types or data transformations","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Dependencies that already work correctly without network access","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Multiple Preview Variants","anchor":"Multiple-Preview-Variants"},{"inlineContent":[{"type":"text","text":"Use different overrides within "},{"type":"codeVoice","code":"#Preview"},{"type":"text","text":" blocks to show different states:"}],"type":"paragraph"},{"type":"codeListing","code":["#Preview(\"Logged In\") {","    AuthContainer.shared.override(\"authService\") {","        MockAuthService(isLoggedIn: true)","    }","    return ProfileView()","}","","#Preview(\"Logged Out\") {","    AuthContainer.shared.override(\"authService\") {","        MockAuthService(isLoggedIn: false)","    }","    return ProfileView()","}","","#Preview(\"Error State\") {","    AuthContainer.shared.override(\"authService\") {","        MockAuthService(shouldFail: true)","    }","    return ProfileView()","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This lets you preview the same view in multiple states without changing any production","type":"text"},{"text":" ","type":"text"},{"text":"code.","type":"text"}]},{"level":2,"text":"Testing Preview Behavior","type":"heading","anchor":"Testing-Preview-Behavior"},{"inlineContent":[{"type":"text","text":"The framework includes an internal "},{"code":"_isPreviewOverride","type":"codeVoice"},{"text":" property (accessible via","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"@testable import"},{"text":") that lets tests simulate the preview environment:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["@testable import Forge","","PreviewContext._isPreviewOverride = true","defer { PreviewContext._isPreviewOverride = nil }","","\/\/ Dependencies now use their preview factories","let service = MyContainer.shared.authService","\/\/ service is MockAuthService"],"syntax":"swift"},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"Tests using ","type":"tex