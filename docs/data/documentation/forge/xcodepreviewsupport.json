{"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"],"generated":true,"title":"Architecture and Best Practices","anchor":"Architecture-and-Best-Practices"}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/xcodepreviewsupport"]}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Dependencies that hit the network, access the file system, or perform heavy"},{"type":"text","text":" "},{"type":"text","text":"computation are problematic in Xcode Previews. Forge lets you provide a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" "},{"type":"text","text":"factory that is used automatically when running inside a preview — no conditional"},{"type":"text","text":" "},{"type":"text","text":"checks needed in your view code."}],"type":"paragraph"},{"level":2,"text":"The preview Parameter","type":"heading","anchor":"The-preview-Parameter"},{"inlineContent":[{"type":"text","text":"Pass a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" closure to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)"},{"type":"text","text":" alongside the"},{"type":"text","text":" "},{"type":"text","text":"normal factory:"}],"type":"paragraph"},{"code":["public var authService: any AuthServiceProtocol {","    provide(.singleton) {","        AuthService(network: self.networkClient)","    } preview: {","        MockAuthService()","    }","}","","public var networkClient: any NetworkClientProtocol {","    provide(.singleton) {","        URLSessionNetworkClient()","    } preview: {","        MockNetworkClient()","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"When the code runs inside an Xcode Preview, "},{"code":"MockAuthService()","type":"codeVoice"},{"type":"text","text":" is returned. In"},{"type":"text","text":" "},{"type":"text","text":"production, "},{"code":"AuthService(network:)","type":"codeVoice"},{"type":"text","text":" is returned."}],"type":"paragraph"},{"level":2,"text":"How Preview Detection Works","type":"heading","anchor":"How-Preview-Detection-Works"},{"inlineContent":[{"type":"text","text":"Forge detects the preview environment by checking for the "},{"type":"codeVoice","code":"XCODE_RUNNING_FOR_PREVIEWS"},{"type":"text","text":" "},{"type":"text","text":"environment variable, which Xcode sets to "},{"type":"codeVoice","code":"\"1\""},{"type":"text","text":" when rendering previews. This is the"},{"type":"text","text":" "},{"type":"text","text":"standard detection mechanism used across the Swift community."}],"type":"paragraph"},{"level":3,"text":"Resolution Precedence","type":"heading","anchor":"Resolution-Precedence"},{"inlineContent":[{"text":"When ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","type":"reference","isActive":true},{"text":" is called, resolution follows this order:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Overrides"}],"type":"strong"},{"text":" — always checked first (test overrides take priority)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Preview factory"}]},{"text":" — used if running in a preview and a ","type":"text"},{"code":"preview","type":"codeVoice"},{"text":" closure was provided","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Normal factory"}]},{"type":"text","text":" — the default production path"}],"type":"paragraph"}]}],"type":"orderedList"},{"level":2,"text":"Preview Values Are Never Cached","type":"heading","anchor":"Preview-Values-Are-Never-Cached"},{"inlineContent":[{"type":"text","text":"Preview factories are called fresh on every resolution, regardless of the declared"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","isActive":true},{"type":"text","text":". Even if a dependency is registered as "},{"type":"codeVoice","code":".singleton"},{"type":"text","text":", the preview factory"},{"type":"text","text":" "},{"type":"text","text":"runs every time in a preview context. This ensures previews always reflect the latest"},{"type":"text","text":" "},{"type":"text","text":"mock state."}],"type":"paragraph"},{"level":2,"text":"When to Provide a Preview Factory","type":"heading","anchor":"When-to-Provide-a-Preview-Factory"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Provide one for:"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network clients and API services"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Database and file system access","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Analytics and logging services"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Any dependency that performs I\/O or has side effects"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Skip it for:"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Pure in-memory services (formatters, validators, parsers)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Simple value types or data transformations"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Dependencies that already work correctly without network access","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"text":"Multiple Preview Variants","type":"heading","anchor":"Multiple-Preview-Variants"},{"inlineContent":[{"type":"text","text":"Use different overrides within "},{"code":"#Preview","type":"codeVoice"},{"type":"text","text":" blocks to show different states:"}],"type":"paragraph"},{"code":["#Preview(\"Logged In\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: true)","    }","    return ProfileView()","}","","#Preview(\"Logged Out\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: false)","    }","    return ProfileView()","}","","#Preview(\"Error State\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(shouldFail: true)","    }","    return ProfileView()","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"This lets you preview the same view in multiple states without changing any production"},{"type":"text","text":" "},{"type":"text","text":"code."}],"type":"paragraph"},{"level":2,"text":"Testing Preview Behavior","type":"heading","anchor":"Testing-Preview-Behavior"},{"inlineContent":[{"type":"text","text":"The framework includes an internal "},{"code":"_isPreviewOverride","type":"codeVoice"},{"type":"text","text":" property (accessible via"},{"type":"text","text":" "},{"code":"@testable import","type":"codeVoice"},{"type":"text","text":") that lets tests simulate the preview environment:"}],"type":"paragraph"},{"code":["@testable import Forge","","PreviewContext._isPreviewOverride = true","defer { PreviewContext._isPreviewOverride = nil }","","\/\/ Dependencies now use their preview factories","let service = MyContainer.shared.authService","\/\/ service is MockAuthService"],"type":"codeListing","syntax":"swift"},{"name":"Note","content":[{"inlineContent":[{"text":"Tests using ","type":"text"},{"code":"_isPreviewOverride","type":"codeVoice"},{"text":" must be marked ","type":"text"},{"code":".serialized","type":"codeVoice"},{"text":" to prevent","type":"text"},{"text":" ","type":"text"},{"text":"data races, since this is a global mutable state.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"}],"kind":"content"}],"abstract":[{"type":"text","text":"Provide preview-safe mock factories that activate automatically in Xcode Previews."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","interfaceLanguage":"swift"},"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"Forge"}],"title":"Xcode Preview Support"},"references":{"doc://Forge/documentation/Forge/Container/provide(_:key:_:preview:)":{"url":"\/documentation\/forge\/container\/provide(_:key:_:preview:)","abstract":[{"text":"Resolves a dependency using the given scope and factory.","type":"text"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"provide"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"preciseIdentifier":"s:5Forge5ScopeO","kind":"typeIdentifier","text":"Scope"},{"kind":"text","text":", "},{"kind":"externalParam","text":"key"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":", () -> ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":", ","kind":"text"},{"text":"preview","kind":"externalParam"},{"text":": (() -> ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":")?) -> ","kind":"text"},{"text":"T","kind":"typeIdentifier"}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","kind":"symbol","type":"topic","title":"provide(_:key:_:preview:)","role":"symbol"},"doc://Forge/documentation/Forge/Scope":{"url":"\/documentation\/forge\/scope","kind":"symbol","title":"Scope","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Sco