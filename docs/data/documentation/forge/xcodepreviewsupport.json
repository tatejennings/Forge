{"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"Forge"}],"title":"Xcode Preview Support"},"kind":"article","sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"],"anchor":"Architecture-and-Best-Practices","title":"Architecture and Best Practices"}],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","interfaceLanguage":"swift"},"abstract":[{"text":"Provide preview-safe mock factories that activate automatically in Xcode Previews.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Dependencies that hit the network, access the file system, or perform heavy"},{"type":"text","text":" "},{"type":"text","text":"computation are problematic in Xcode Previews. Forge lets you provide a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" "},{"type":"text","text":"factory that is used automatically when running inside a preview — no conditional"},{"type":"text","text":" "},{"type":"text","text":"checks needed in your view code."}],"type":"paragraph"},{"anchor":"The-preview-Parameter","text":"The preview Parameter","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Pass a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" closure to "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:preview:key:_:)","isActive":true},{"type":"text","text":" alongside the"},{"type":"text","text":" "},{"type":"text","text":"normal factory:"}],"type":"paragraph"},{"syntax":"swift","code":["public var authService: any AuthServiceProtocol {","    provide(.singleton, preview: { MockAuthService() }) {","        AuthService(network: self.networkClient)","    }","}","","public var networkClient: any NetworkClientProtocol {","    provide(.singleton, preview: { MockNetworkClient() }) {","        URLSessionNetworkClient()","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"When the code runs inside an Xcode Preview, "},{"type":"codeVoice","code":"MockAuthService()"},{"type":"text","text":" is returned. In"},{"type":"text","text":" "},{"type":"text","text":"production, "},{"type":"codeVoice","code":"AuthService(network:)"},{"type":"text","text":" is returned."}],"type":"paragraph"},{"anchor":"How-Preview-Detection-Works","text":"How Preview Detection Works","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Forge detects the preview environment by checking for the "},{"type":"codeVoice","code":"XCODE_RUNNING_FOR_PREVIEWS"},{"type":"text","text":" "},{"type":"text","text":"environment variable, which Xcode sets to "},{"type":"codeVoice","code":"\"1\""},{"type":"text","text":" when rendering previews. This is the"},{"type":"text","text":" "},{"type":"text","text":"standard detection mechanism used across the Swift community."}],"type":"paragraph"},{"anchor":"Resolution-Precedence","text":"Resolution Precedence","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"When "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:preview:key:_:)","isActive":true},{"type":"text","text":" is called, resolution follows this order:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Overrides"}]},{"type":"text","text":" — always checked first (test overrides take priority)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Preview factory"}]},{"type":"text","text":" — used if running in a preview and a "},{"code":"preview","type":"codeVoice"},{"type":"text","text":" closure was provided"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Normal factory"}]},{"type":"text","text":" — the default production path"}]}]}],"type":"orderedList"},{"anchor":"Preview-Values-Are-Never-Cached","text":"Preview Values Are Never Cached","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Preview factories are called fresh on every resolution, regardless of the declared"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","isActive":true},{"type":"text","text":". Even if a dependency is registered as "},{"type":"codeVoice","code":".singleton"},{"type":"text","text":", the preview factory"},{"type":"text","text":" "},{"type":"text","text":"runs every time in a preview context. This ensures previews always reflect the latest"},{"type":"text","text":" "},{"type":"text","text":"mock state."}],"type":"paragraph"},{"anchor":"When-to-Provide-a-Preview-Factory","text":"When to Provide a Preview Factory","level":2,"type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Provide one for:","type":"text"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network clients and API services"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Database and file system access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Analytics and logging services"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any dependency that performs I\/O or has side effects"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Skip it for:","type":"text"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pure in-memory services (formatters, validators, parsers)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Simple value types or data transformations"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dependencies that already work correctly without network access"}]}]}],"type":"unorderedList"},{"anchor":"Multiple-Preview-Variants","text":"Multiple Preview Variants","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use different overrides within "},{"type":"codeVoice","code":"#Preview"},{"type":"text","text":" blocks to show different states:"}],"type":"paragraph"},{"syntax":"swift","code":["#Preview(\"Logged In\") {","    AuthContainer.shared.override(\"authService\") {","        MockAuthService(isLoggedIn: true)","    }","    return ProfileView()","}","","#Preview(\"Logged Out\") {","    AuthContainer.shared.override(\"authService\") {","        MockAuthService(isLoggedIn: false)","    }","    return ProfileView()","}","","#Preview(\"Error State\") {","    AuthContainer.shared.override(\"authService\") {","        MockAuthService(shouldFail: true)","    }","    return ProfileView()","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This lets you preview the same view in multiple states without changing any production"},{"type":"text","text":" "},{"type":"text","text":"code."}],"type":"paragraph"},{"anchor":"Testing-Preview-Behavior","text":"Testing Preview Behavior","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The framework includes an internal "},{"type":"codeVoice","code":"_isPreviewOverride"},{"type":"text","text":" property (accessible via"},{"type":"text","text":" "},{"type":"codeVoice","code":"@testable import"},{"type":"text","text":") that lets tests simulate the preview environment:"}],"type":"paragraph"},{"syntax":"swift","code":["@testable import Forge","","PreviewContext._isPreviewOverride = true","defer { PreviewContext._isPreviewOverride = nil }","","\/\/ Dependencies now use their preview factories","let service = MyContainer.shared.authService","\/\/ service is MockAuthService"],"type":"codeListing"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Tests using ","type":"text"},{"type":"codeVoice","code":"_isPreviewOverride"},{"text":" must be marked ","type":"text"},{"type":"codeVoice","code":".serialized"},{"text":" to prevent","type":"text"},{"text":" ","type":"text"},{"text":"data races, since this is a global mutable state.","type":"text"}]}],"style":"note","type":"aside"}]}],"variants":[{"paths":["\/documentation\/forge\/xcodepreviewsupport"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"references":{"doc://Forge/documentation/Forge/ModularArchitecture":{"identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","abstract":[{"text":"Organize dependency injection across multiple Swift Package Manager modules.","type":"text"}],"url":"\/documentation\/forge\/modulararchitecture","title":"Modular Architecture","type":"topic","role":"article","kind":"article"},"doc://Forge/documentation/Forge/Scope":{"navigatorTitle":[{"kind":"identifier","text":"Scope"}],"kind":"symbol","type":"topic","title":"Scope","url":"\/documentation\/forge\/scope","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","abstract":[{"text":"Defines the lifecycle of a dependency managed by a ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference","isActive":true},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Scope"}],"role":"symbol"},"doc://Forge/documentation/Forge/Container":{"title":"Container","kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","url":"\/documentation\/forge\/container","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Container","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Container"}],"abstract":[{"text":"The base class for all dependency containers in Forge.","type":"text"}]},"doc://Forge/documentation/Forge/SOLIDPrinciples":{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","type":"topic","title":"SOLID Principles with Forge","url":"\/documentation\/forge\/solidprinciples","role":"article","abstract":[{"text":"How each SOLID principle maps to Forge usage, with practical Swift examples.","type":"text"}],"kind":"article"},"doc://Forge/documentation/Forge":{"url":"\/documentation\/forge","identifier":"doc:\/\/Forge\/documentation\/Forge","kind":"symbol","abstract":[{"text":"A lightweight, compile-time safe dependency injection framework for Swift.","type":"text"}],"role":"collection","type":"topic","title":"Forge"},"doc://Forge/documentation/Forge/Container/provide(_:preview:key:_:)":{"title":"provide(_:preview:key:_:)","kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:preview:key:_:)","url":"\/documentation\/forge\/container\/provide(_:preview:key:_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"provide","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:5Forge5ScopeO","text":"Scope","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"preview","kind":"externalParam"},{"text":": (() -> ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":")?, ","kind":"text"},{"text":"key","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", () -> ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":") -> ","kind":"text"},{"text":"T","kind":"typeIdentifier"}],"abstract":[{"text":"Resolves a dependency using the given scope and factory.","type":"text"}]}}}