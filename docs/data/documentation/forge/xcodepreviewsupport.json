{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"sections":[],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"Dependencies that hit the network, access the file system, or perform heavy"},{"type":"text","text":" "},{"type":"text","text":"computation are problematic in Xcode Previews. Forge lets you provide a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" "},{"type":"text","text":"factory that is used automatically when running inside a preview — no conditional"},{"type":"text","text":" "},{"type":"text","text":"checks needed in your view code."}],"type":"paragraph"},{"anchor":"The-preview-Parameter","level":2,"type":"heading","text":"The preview Parameter"},{"inlineContent":[{"type":"text","text":"Pass a "},{"code":"preview","type":"codeVoice"},{"type":"text","text":" closure to "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","isActive":true},{"type":"text","text":" alongside the"},{"type":"text","text":" "},{"type":"text","text":"normal factory:"}],"type":"paragraph"},{"syntax":"swift","code":["public var authService: any AuthServiceProtocol {","    provide(.singleton) {","        AuthService(network: self.networkClient)","    } preview: {","        MockAuthService()","    }","}","","public var networkClient: any NetworkClientProtocol {","    provide(.singleton) {","        URLSessionNetworkClient()","    } preview: {","        MockNetworkClient()","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"When the code runs inside an Xcode Preview, ","type":"text"},{"type":"codeVoice","code":"MockAuthService()"},{"text":" is returned. In","type":"text"},{"text":" ","type":"text"},{"text":"production, ","type":"text"},{"type":"codeVoice","code":"AuthService(network:)"},{"text":" is returned.","type":"text"}],"type":"paragraph"},{"anchor":"How-Preview-Detection-Works","level":2,"type":"heading","text":"How Preview Detection Works"},{"inlineContent":[{"type":"text","text":"Forge detects the preview environment by checking for the "},{"code":"XCODE_RUNNING_FOR_PREVIEWS","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"environment variable, which Xcode sets to "},{"code":"\"1\"","type":"codeVoice"},{"type":"text","text":" when rendering previews. This is the"},{"type":"text","text":" "},{"type":"text","text":"standard detection mechanism used across the Swift community."}],"type":"paragraph"},{"anchor":"Resolution-Precedence","level":3,"type":"heading","text":"Resolution Precedence"},{"inlineContent":[{"type":"text","text":"When "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","isActive":true},{"type":"text","text":" is called, resolution follows this order:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Overrides","type":"text"}]},{"type":"text","text":" — always checked first (test overrides take priority)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Preview factory"}]},{"type":"text","text":" — used if running in a preview and a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" closure was provided"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Normal factory"}],"type":"strong"},{"text":" — the default production path","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"Preview Values Are Never Cached","level":2,"anchor":"Preview-Values-Are-Never-Cached","type":"heading"},{"inlineContent":[{"text":"Preview factories are called fresh on every resolution, regardless of the declared","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"text":". Even if a dependency is registered as ","type":"text"},{"code":".singleton","type":"codeVoice"},{"text":", the preview factory","type":"text"},{"text":" ","type":"text"},{"text":"runs every time in a preview context. This ensures previews always reflect the latest","type":"text"},{"text":" ","type":"text"},{"text":"mock state.","type":"text"}],"type":"paragraph"},{"text":"When to Provide a Preview Factory","level":2,"anchor":"When-to-Provide-a-Preview-Factory","type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Provide one for:"}]}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Network clients and API services"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Database and file system access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Analytics and logging services"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any dependency that performs I\/O or has side effects"}]}]}],"type":"unorderedList"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Skip it for:"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Pure in-memory services (formatters, validators, parsers)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Simple value types or data transformations","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Dependencies that already work correctly without network access","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Multiple Preview Variants","level":2,"anchor":"Multiple-Preview-Variants","type":"heading"},{"inlineContent":[{"text":"Use different overrides within ","type":"text"},{"code":"#Preview","type":"codeVoice"},{"text":" blocks to show different states:","type":"text"}],"type":"paragraph"},{"code":["#Preview(\"Logged In\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: true)","    }","    return ProfileView()","}","","#Preview(\"Logged Out\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: false)","    }","    return ProfileView()","}","","#Preview(\"Error State\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(shouldFail: true)","    }","    return ProfileView()","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"This lets you preview the same view in multiple states without changing any production","type":"text"},{"text":" ","type":"text"},{"text":"code.","type":"text"}]},{"anchor":"Testing-Preview-Behavior","text":"Testing Preview Behavior","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The framework includes an internal "},{"code":"_isPreviewOverride","type":"codeVoice"},{"type":"text","text":" property (accessible via"},{"type":"text","text":" "},{"code":"@testable import","type":"codeVoice"},{"type":"text","text":") that lets tests simulate the preview environment:"}]},{"code":["@testable import Forge","","PreviewContext._isPreviewOverride = true","defer { PreviewContext._isPreviewOverride = nil }","","\/\/ Dependencies now use their preview factories","let service = MyContainer.shared.authService","\/\/ service is MockAuthService"],"type":"codeListing","syntax":"swift"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Tests using "},{"type":"codeVoice","code":"_isPreviewOverride"},{"type":"text","text":" must be marked "},{"type":"codeVoice","code":".serialized"},{"type":"text","text":" to prevent"},{"type":"text","text":" "},{"type":"text","text":"data races, since this is a global mutable state."}]}],"type":"aside","style":"note","name":"Note"}],"kind":"content"}],"metadata":{"title":"Xcode Preview Support","modules":[{"name":"Forge"}],"role":"article","roleHeading":"Article"},"seeAlsoSections":[{"title":"Architecture and Best Practices","identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"],"generated":true,"anchor":"Architecture-and-Best-Practices"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/xcodepreviewsupport"]}],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","interfaceLanguage":"swift"},"kind":"article","abstract":[{"text":"Provide preview-safe mock factories that activate automatically in Xcode Previews.","type":"text"}],"references":{"doc://Forge/documentation/Forge/Scope":{"kind":"symbol","abstract":[{"type":"text","text":"Defines the lifecycle of a dependency managed by a "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Scope"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Scope"}],"title":"Scope","type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","url":"\/documentation\/forge\/scope"},"doc://Forge/documentation/Forge/SOLIDPrinciples":{"url":"\/documentation\/forge\/solidprinciples","kind":"article","abstract":[{"type":"text","text":"How each SOLID principle maps to Forge usage, with practical Swift examples."}],"role":"article","type":"topic","title":"SOLID Principles with Forge","identifier":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"},"doc://Forge/documentation/Forge/ModularArchitecture":{"type":"topic","url":"\/documentation\/forge\/modulararchitecture","kind":"article","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","title":"Modular Architecture","role":"article","abstract":[{"text":"Organize dependency injection across multiple Swift Package Manager modules.","type":"text"}]},"doc://Forge/