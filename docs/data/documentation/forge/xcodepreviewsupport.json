{"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/xcodepreviewsupport"]}],"kind":"article","abstract":[{"type":"text","text":"Provide preview-safe mock factories that activate automatically in Xcode Previews."}],"sections":[],"metadata":{"modules":[{"name":"Forge"}],"role":"article","roleHeading":"Article","title":"Xcode Preview Support"},"seeAlsoSections":[{"anchor":"Architecture-and-Best-Practices","generated":true,"identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"],"title":"Architecture and Best Practices"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Dependencies that hit the network, access the file system, or perform heavy","type":"text"},{"text":" ","type":"text"},{"text":"computation are problematic in Xcode Previews. Forge lets you provide a ","type":"text"},{"type":"codeVoice","code":"preview"},{"text":" ","type":"text"},{"text":"factory that is used automatically when running inside a preview — no conditional","type":"text"},{"text":" ","type":"text"},{"text":"checks needed in your view code.","type":"text"}]},{"type":"heading","level":2,"text":"The preview Parameter","anchor":"The-preview-Parameter"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" closure to "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","isActive":true},{"type":"text","text":" alongside the"},{"type":"text","text":" "},{"type":"text","text":"normal factory:"}]},{"type":"codeListing","code":["public var authService: any AuthServiceProtocol {","    provide(.singleton) {","        AuthService(network: self.networkClient)","    } preview: {","        MockAuthService()","    }","}","","public var networkClient: any NetworkClientProtocol {","    provide(.singleton) {","        URLSessionNetworkClient()","    } preview: {","        MockNetworkClient()","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the code runs inside an Xcode Preview, "},{"type":"codeVoice","code":"MockAuthService()"},{"type":"text","text":" is returned. In"},{"type":"text","text":" "},{"type":"text","text":"production, "},{"type":"codeVoice","code":"AuthService(network:)"},{"type":"text","text":" is returned."}]},{"type":"heading","level":2,"text":"How Preview Detection Works","anchor":"How-Preview-Detection-Works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge detects the preview environment by checking for the "},{"code":"XCODE_RUNNING_FOR_PREVIEWS","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"environment variable, which Xcode sets to "},{"code":"\"1\"","type":"codeVoice"},{"type":"text","text":" when rendering previews. This is the"},{"type":"text","text":" "},{"type":"text","text":"standard detection mechanism used across the Swift community."}]},{"type":"heading","level":3,"text":"Resolution Precedence","anchor":"Resolution-Precedence"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)"},{"type":"text","text":" is called, resolution follows this order:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Overrides","type":"text"}]},{"type":"text","text":" — always checked first (test overrides take priority)"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Preview factory"}],"type":"strong"},{"type":"text","text":" — used if running in a preview and a "},{"code":"preview","type":"codeVoice"},{"type":"text","text":" closure was provided"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Normal factory"}],"type":"strong"},{"text":" — the default production path","type":"text"}]}]}]},{"level":2,"text":"Preview Values Are Never Cached","anchor":"Preview-Values-Are-Never-Cached","type":"heading"},{"inlineContent":[{"type":"text","text":"Preview factories are called fresh on every resolution, regardless of the declared"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"type":"text","text":". Even if a dependency is registered as "},{"type":"codeVoice","code":".singleton"},{"type":"text","text":", the preview factory"},{"type":"text","text":" "},{"type":"text","text":"runs every time in a preview context. This ensures previews always reflect the latest"},{"type":"text","text":" "},{"type":"text","text":"mock state."}],"type":"paragraph"},{"level":2,"text":"When to Provide a Preview Factory","anchor":"When-to-Provide-a-Preview-Factory","type":"heading"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Provide one for:"}],"type":"strong"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Network clients and API services","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Database and file system access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Analytics and logging services"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any dependency that performs I\/O or has side effects"}]}]}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Skip it for:"}]}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Pure in-memory services (formatters, validators, parsers)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Simple value types or data transformations","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Dependencies that already work correctly without network access","type":"text"}],"type":"paragraph"}]}]},{"level":2,"text":"Multiple Preview Variants","anchor":"Multiple-Preview-Variants","type":"heading"},{"inlineContent":[{"text":"Use different overrides within ","type":"text"},{"code":"#Preview","type":"codeVoice"},{"text":" blocks to show different states:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["#Preview(\"Logged In\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: true)","    }","    return ProfileView()","}","","#Preview(\"Logged Out\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: false)","    }","    return ProfileView()","}","","#Preview(\"Error State\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(shouldFail: true)","    }","    return ProfileView()","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This lets you preview the same view in multiple states without changing any production","type":"text"},{"text":" ","type":"text"},{"text":"code.","type":"text"}]},{"level":2,"type":"heading","anchor":"Testing-Preview-Behavior","text":"Testing Preview Behavior"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The framework includes an internal "},{"code":"_isPreviewOverride","type":"codeVoice"},{"type":"text","text":" property (accessible via"},{"type":"text","text":" "},{"code":"@testable import","type":"codeVoice"},{"type":"text","text":") that lets tests simulate the preview environment:"}]},{"type":"codeListing","code":["@testable import Forge","","PreviewContext._isPreviewOverride = true","defer { PreviewContext._isPreviewOverride = nil }","","\/\/ Dependencies now use their preview factories","let service = MyConta