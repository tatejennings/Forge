{"abstract":[{"type":"text","text":"Provide preview-safe mock factories that activate automatically in Xcode Previews."}],"metadata":{"modules":[{"name":"Forge"}],"role":"article","roleHeading":"Article","title":"Xcode Preview Support"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Dependencies that hit the network, access the file system, or perform heavy","type":"text"},{"text":" ","type":"text"},{"text":"computation are problematic in Xcode Previews. Forge lets you provide a ","type":"text"},{"code":"preview","type":"codeVoice"},{"text":" ","type":"text"},{"text":"factory that is used automatically when running inside a preview — no conditional","type":"text"},{"text":" ","type":"text"},{"text":"checks needed in your view code.","type":"text"}]},{"type":"heading","anchor":"The-preview-Parameter","level":2,"text":"The preview Parameter"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" closure to "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","type":"reference","isActive":true},{"type":"text","text":" alongside the"},{"type":"text","text":" "},{"type":"text","text":"normal factory:"}]},{"type":"codeListing","code":["public var authService: any AuthServiceProtocol {","    provide(.singleton) {","        AuthService(network: self.networkClient)","    } preview: {","        MockAuthService()","    }","}","","public var networkClient: any NetworkClientProtocol {","    provide(.singleton) {","        URLSessionNetworkClient()","    } preview: {","        MockNetworkClient()","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the code runs inside an Xcode Preview, "},{"type":"codeVoice","code":"MockAuthService()"},{"type":"text","text":" is returned. In"},{"type":"text","text":" "},{"type":"text","text":"production, "},{"type":"codeVoice","code":"AuthService(network:)"},{"type":"text","text":" is returned."}]},{"type":"heading","anchor":"How-Preview-Detection-Works","level":2,"text":"How Preview Detection Works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge detects the preview environment by checking for the "},{"type":"codeVoice","code":"XCODE_RUNNING_FOR_PREVIEWS"},{"type":"text","text":" "},{"type":"text","text":"environment variable, which Xcode sets to "},{"type":"codeVoice","code":"\"1\""},{"type":"text","text":" when rendering previews. This is the"},{"type":"text","text":" "},{"type":"text","text":"standard detection mechanism used across the Swift community."}]},{"type":"heading","anchor":"Resolution-Precedence","level":3,"text":"Resolution Precedence"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","isActive":true,"type":"reference"},{"text":" is called, resolution follows this order:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Overrides","type":"text"}]},{"type":"text","text":" — always checked first (test overrides take priority)"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Preview factory"}]},{"type":"text","text":" — used if running in a preview and a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" closure was provided"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Normal factory"}]},{"type":"text","text":" — the default production path"}],"type":"paragraph"}]}]},{"text":"Preview Values Are Never Cached","type":"heading","anchor":"Preview-Values-Are-Never-Cached","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Preview factories are called fresh on every resolution, regardless of the declared"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"type":"text","text":". Even if a dependency is registered as "},{"type":"codeVoice","code":".singleton"},{"type":"text","text":", the preview factory"},{"type":"text","text":" "},{"type":"text","text":"runs every time in a preview context. This ensures previews always reflect the latest"},{"type":"text","text":" "},{"type":"text","text":"mock state."}]},{"text":"When to Provide a Preview Factory","type":"heading","anchor":"When-to-Provide-a-Preview-Factory","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Provide one for:","type":"text"}]}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Network clients and API services","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Database and file system access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Analytics and logging services"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Any dependency that performs I\/O or has side effects"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Skip it for:"}]}]},{"items":[{"content":[{"inlineContent":[{"text":"Pure in-memory services (formatters, validators, parsers)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Simple value types or data transformations","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dependencies that already work correctly without network access"}]}]}],"type":"unorderedList"},{"text":"Multiple Preview Variants","type":"heading","anchor":"Multiple-Preview-Variants","level":2},{"type":"paragraph","inlineContent":[{"text":"Use different overrides within ","type":"text"},{"code":"#Preview","type":"codeVoice"},{"text":" blocks to show different states:","type":"text"}]},{"syntax":"swift","code":["#Preview(\"Logged In\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: true)","    }","    return ProfileView()","}","","#Preview(\"Logged Out\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(isLoggedIn: false)","    }","    return ProfileView()","}","","#Preview(\"Error State\") {","    AuthContainer.shared.override(\\.authService) {","        MockAuthService(shouldFail: true)","    }","    return ProfileView()","}"],"type":"codeListing"},{"inlineContent":[{"text":"This lets you preview the same view in multiple states without changing any production","type":"text"},{"text":" ","type":"text"},{"text":"code.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Testing-Preview-Behavior","type":"heading","text":"Testing Preview Behavior"},{"inlineContent":[{"text":"The framework includes an internal ","type":"text"},{"code":"_isPreviewOverride","type":"codeVoice"},{"text":" property (accessible via","type":"text"},{"text":" ","type":"text"},{"code":"@testable import","type":"codeVoice"},{"text":") that lets tests simulate the preview environment:","type":"text"}],"type":"paragraph"},{"code":["@testable import Forge","","PreviewContext._isPreviewOverride = true","defer { PreviewContext._isPreviewOverride = nil }","","\/\/ Dependencies now use their preview factories","let service = MyContainer.shared.authService","\/\/ service is MockAuthService"],"type":"codeListing","syntax":"swift"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Tests using "},{"code":"_isPreviewOverride","type":"codeVoice"},{"type":"text","text":" must be marked "},{"code":".serialized","type":"codeVoice"},{"type":"text","text":" to prevent"},{"type":"text","text":" "},{"type":"text","text":"data races, since this is a global mutable state."}]}],"name":"Note"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"],"title":"Architecture and Best Practices","generated":true,"anchor":"Architecture-and-Best-Practices"}],"sections":[],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/xcodepreviewsupport"]}],"kind":"article","references":{"doc://Forge/documentation/Forge/Scope":{"navigatorTitle":[{"kind":"identifier","text":"Scope"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Scope"}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","abstract":[{"text":"Defines the lifecycle of a dependency managed by a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"text":".","type":"text"}],"title":"Scope","type":"topic","role":"symbol","url":"\/documentation\/forge\/scope"},"doc://Forge/documentation/Forge/Container":{"role":"symbol","type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Container","kind":"identifier"}],"navigatorTitle":[{"text":"Container","kind":"identifier"}],"abstract":[{"type":"text","text":"The base class for all dependency containers in Forge."}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","title":"Container","url":"\/documentation\/forge\/container"},"doc://Forge/documentation/Forge/Container/provide(_:key:_:preview:)":{"kind":"symbol","type":"topic","url":"\/documentation\/forge\/container\/provide(_:key:_:preview:)","role":"symbol","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview