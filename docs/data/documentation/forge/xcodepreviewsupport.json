{"metadata":{"role":"article","modules":[{"name":"Forge"}],"roleHeading":"Article","title":"Xcode Preview Support"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Provide preview-safe mock factories that activate automatically in Xcode Previews."}],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Dependencies that hit the network, access the file system, or perform heavy"},{"type":"text","text":" "},{"type":"text","text":"computation are problematic in Xcode Previews. Forge lets you provide a "},{"type":"codeVoice","code":"preview"},{"type":"text","text":" "},{"type":"text","text":"factory that is used automatically when running inside a preview — no conditional"},{"type":"text","text":" "},{"type":"text","text":"checks needed in your view code."}]},{"anchor":"The-preview-Parameter","type":"heading","text":"The preview Parameter","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass a "},{"code":"preview","type":"codeVoice"},{"type":"text","text":" closure to "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:key:_:preview:)","type":"reference","isActive":true},{"type":"text","text":" alongside the"},{"type":"text","text":" "},{"type":"text","text":"normal factory:"}]},{"code":["public var authService: any AuthServiceProtocol {","    provide(.singleton) {","        AuthService(network: self.networkClient)","    } preview: {","        MockAuthService()","    }","}","","public var networkClient: any NetworkClientProtocol {","    provide(.singleton) {","        URLSessionNetworkClient()","    } preview: {","        MockNetworkClient()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When 