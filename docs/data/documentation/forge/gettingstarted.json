module with a local typealias.","type":"text"},{"text":" ","type":"text"},{"text":"Best for multi-module SPM architectures.","type":"text"}],"type":"paragraph"}]}]},{"text":"Installation","type":"heading","anchor":"Installation","level":2},{"inlineContent":[{"text":"Add Forge to your project via Swift Package Manager. In your ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/tatejennings\/forge.git\", from: \"0.1.0\")","]"]},{"inlineContent":[{"text":"Then add ","type":"text"},{"type":"codeVoice","code":"Forge"},{"text":" to your target’s dependencies:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":[".target(name: \"MyApp\", dependencies: [\"Forge\"])"]},{"inlineContent":[{"text":"Or add it via Xcode: ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"File > Add Packages"}]},{"text":", enter the repository URL, and add","type":"text"},{"text":" ","type":"text"},{"code":"Forge","type":"codeVoice"},{"text":" to your target.","type":"text"}],"type":"paragraph"},{"text":"Simple Setup","type":"heading","anchor":"Simple-Setup","level":2},{"inlineContent":[{"type":"text","text":"Extend the built-in "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true},{"type":"text","text":" with your dependencies. The framework-provided"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":" typealias lets you inject them anywhere — no container class to write,"},{"type":"text","text":" "},{"type":"text","text":"no typealias to define, no setup code at all:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import Forge","","extension AppContainer {","    var networkClient: any NetworkClientProtocol {","  