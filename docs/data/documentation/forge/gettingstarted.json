ation","type":"text"},{"text":" ","type":"text"},{"text":"(common in tests) are picked up correctly.","type":"text"}]},{"anchor":"In-SwiftUI-views","text":"In SwiftUI views","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"type":"text","text":" uses a "},{"code":"mutating get","type":"codeVoice"},{"type":"text","text":", which doesn’t work directly in SwiftUI"},{"type":"text","text":" "},{"type":"text","text":"view structs. Instead, resolve directly from the container:"}]},{"syntax":"swift","type":"codeListing","code":["struct LoginView: View {","    @State private var viewModel = AppContainer.shared.loginViewModel","","    var body: some View {","        \/\/ use viewModel...","    }","}"]},{"anchor":"Inline-resolution","text":"Inline resolution","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also resolve dependencies directly without the property wrapper:"}]},{"syntax":"swift","type":"codeListing","code":["let service = AppContainer.shared.authService"]},{"anchor":"Next-Steps","text":"Next Steps","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","isActive":true},{"text":" — organize containers across multiple modules","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","type":"reference"},{"type":"text","text":" — mock dependencies in tests"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","type":"reference","isActive":true},{"text":" — provide preview-safe factories","type":"text"}]}]}],"type":"unorderedList"}]}],"variants":[{"paths":["\/documentation\/forge\/gettingstarted"],"traits":[{"int