"}]}],[{"type":"paragraph","inlineContent":[{"text":"One instance for the container’s lifetime","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".cached","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"One instance until ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetCached()","isActive":true,"type":"reference"},{"text":" is called","type":"text"}]}]]],"header":"row","type":"table"},{"code":["var logger: any LoggerProtocol {","    provide(.transient) { ConsoleLogger() }   \/\/ Fresh each time","}","","var database: any DatabaseProtocol {","    provide(.singleton) { SQLiteDatabase() }  \/\/ Lives forever","}","","var session: any SessionProtocol {","    provide(.cached) { UserSession() }        \/\/ Resettable","}"],"syntax":"swift","type":"codeListing"},{"text":"Inject Dependencies","anchor":"Inject-Dependencies","type":"heading","level":2},{"text":"In classes (ViewModels, services)","anchor":"In-classes-ViewModels-services","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"@Inject","type":"codeVoice"},{"type":"text","text":" with a key path to the container property:"}]},{"code":["final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    @Inject(\\.tokenStorage) private var tokens","","    func login(username: String, password: String) async {","        let user = try? await authService.login(","            username: username,","            password: password","        )","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolution is "},{"type":"strong","inlineContent":[{"type":"text","text":"lazy"}]},{"type":"text","text":" — the dependency is resolved on first access of the property,"},{"type":"text","text":" "},{"type":"text","text":"not when the object is created. This ensures overrides set after initialization"},{"type":