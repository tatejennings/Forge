orage: any TokenStorageProtocol {","        provide { KeychainTokenStorage() }","    }","}"]},{"text":"The Module-Local Typealias","type":"heading","anchor":"The-Module-Local-Typealias","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"code":"typealias Inject<T> = ContainerInject<AuthContainer, T>","type":"codeVoice"},{"text":" line is placed ","type":"text"},{"inlineContent":[{"type":"text","text":"in the"},{"type":"text","text":" "},{"type":"text","text":"container file itself"}],"type":"strong"},{"text":" — not in a separate file. This typealias shadows the framework’s","type":"text"},{"text":" ","type":"text"},{"text":"built-in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference"},{"text":" within this module, so ","type":"text"},{"code":"@Inject(\\.authService)","type":"codeVoice"},{"text":" resolves from","type":"text"},{"text":" ","type":"text"},{"code":"AuthContainer","type":"codeVoice"},{"text":" instead of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Inject(\\.authService) private var auth"]},{"inlineContent":[{"text":"If you later rename or refactor the container, only the typealias needs updating.","type":"text"}],"type":"paragraph"},{"text":"Choose a Scope","type":"heading","anchor":"Choose-a-Scope","level":2},{"inlineContent":[{"text":"Every dependency has a lifecycle controlled by ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Scope","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Behavior"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".transient"}]}],[{"type":"p