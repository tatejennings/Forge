{"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge is a lightweight dependency injection framework for Swift. This guide walks you"},{"type":"text","text":" "},{"type":"text","text":"through installation, creating your first container, and injecting dependencies into"},{"text":" ","type":"text"},{"text":"your code.","type":"text"}]},{"level":2,"text":"Installation","type":"heading","anchor":"Installation"},{"inlineContent":[{"type":"text","text":"Add Forge to your project via Swift Package Manager. In your "},{"code":"Package.swift","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/tatejennings\/forge.git\", from: \"0.1.0\")","]"]},{"type":"paragraph","inlineContent":[{"text":"Then add ","type":"text"},{"type":"codeVoice","code":"Forge"},{"text":" to your target’s dependencies:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":[".target(name: \"MyApp\", dependencies: [\"Forge\"])"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or add it via Xcode: "},{"type":"strong","inlineContent":[{"type":"text","text":"File > Add Packages"}]},{"type":"text","text":", enter the repository URL, and add"},{"type":"text","text":" "},{"code":"Forge","type":"codeVoice"},{"text":" to your target.","type":"text"}]},{"anchor":"Define-a-Container","type":"heading","text":"Define a Container","level":2},{"inlineContent":[{"type":"text","text":"Create a container by subclassing "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"type":"text","text":" and conforming to "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Register dependencies as computed properties that call "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/provide(_:preview:key:_:)","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import Forge","","\/\/ The module-local typealias goes in the container file","typealias Inject<T> = ContainerInject<AppContainer, T>","","final class AppContainer: Container, SharedContainer {","    static var shared = AppContainer()","","    var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","","    var authService: any AuthServiceProtocol {","        provide(.singleton, preview: { MockAuthService() }) {","            AuthService(network: self.networkClient)","        }","    }","","    var tokenStorage: any TokenStorageProtocol {","        provide { KeychainTokenStorage() }","    }","}"]},{"anchor":"The-Module-Local-Typealias","type":"heading","text":"The Module-Local Typealias","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"code":"typealias Inject<T> = ContainerInject<AppContainer, T>","type":"codeVoice"},{"text":" line is placed ","type":"text"},{"type":"strong","inlineContent":[{"text":"in the","type":"text"},{"text":" ","type":"text"},{"text":"container file itself","type":"text"}]},{"text":" — not in a separate file. This typealias is the only place","type":"text"},{"text":" ","type":"text"},{"text":"where your container type name appears at injection call sites, keeping them clean:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Inject(\\.authService) private var auth"]},{"inlineContent":[{"type":"text","text":"If you later rename or refactor the container, only the typealias needs updating."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Choose a Scope","anchor":"Choose-a-Scope"},{"type":"paragraph","inlineContent":[{"text":"Every dependency has a lifecycle controlled by ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Scope","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Behavior"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".transient","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"New instance every time (default)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".singleton"}],"type":"paragraph"}],[{"inlineContent":[{"text":"One instance for the container’s lifetime","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".cached"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"One instance until "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetCached()","isActive":true},{"type":"text","text":" is called"}],"type":"paragraph"}]]]},{"type":"codeListing","syntax":"swift","code":["var logger: any LoggerProtocol {","    provide(.transient) { ConsoleLogger() }   \/\/ Fresh each time","}","","var database: any DatabaseProtocol {","    provide(.singleton) { SQLiteDatabase() }  \/\/ Lives forever","}","","var session: any SessionProtocol {","    provide(.cached) { UserSession() }        \/\/ Resettable","}"]},{"type":"heading","level":2,"text":"Inject Dependencies","anchor":"Inject-Dependencies"},{"level":3,"text":"In classes (ViewModels, services)","anchor":"In-classes-ViewModels-services","type":"heading"},{"inlineContent":[{"type":"text","text":"Use "},{"code":"@Inject","type":"codeVoice"},{"type":"text","text":" with a key path to the container property:"}],"type":"paragraph"},{"syntax":"swift","code":["final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    @Inject(\\.tokenStorage) private var tokens","","    func login(username: String, password: String) async {","        let user = try? await authService.login(","            username: username,","            password: password","        )","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Resolution is "},{"inlineContent":[{"text":"lazy","type":"text"}],"type":"strong"},{"type":"text","text":" — the dependency is resolved on first access of the property,"},{"text":" ","type":"text"},{"text":"not when the object is created. This ensures overrides set after initialization","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(common in tests) are picked up correctly."}],"type":"paragraph"},{"level":3,"text":"In SwiftUI views","anchor":"In-SwiftUI-views","type":"heading"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","isActive":true},{"text":" uses a ","type":"text"},{"type":"codeVoice","code":"mutating get"},{"text":", which doesn’t work directly in SwiftUI","type":"text"},{"type":"text","text":" "},{"type":"text","text":"view structs. Instead, resolve directly from the container:"}],"type":"paragraph"},{"code":["struct LoginView: View {","    @State private var viewModel = AppContainer.shared.loginViewModel","","    var body: some View {","        \/\/ use viewModel...","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"Inline resolution","level":3,"type":"heading","anchor":"Inline-resolution"},{"inlineContent":[{"text":"You can also resolve dependencies directly without the property wrapper:","type":"text"}],"type":"paragraph"},{"code":["let service = AppContainer.shared.authService"],"type":"codeListing","syntax":"swift"},{"text":"Next Steps","level":2,"type":"heading","anchor":"Next-Steps"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","type":"reference","isActive":true},{"type":"text","text":" — organize containers across multiple modules"}]}]},{"content":[{"t