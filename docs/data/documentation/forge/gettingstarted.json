xt"},{"text":"not when the object is created. This ensures overrides set after initialization","type":"text"},{"text":" ","type":"text"},{"text":"(common in tests) are picked up correctly.","type":"text"}],"type":"paragraph"},{"text":"In SwiftUI views","type":"heading","anchor":"In-SwiftUI-views","level":3},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"text":" uses a ","type":"text"},{"code":"mutating get","type":"codeVoice"},{"text":", which doesn’t work directly in SwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"view structs. Instead, resolve directly from the container:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct LoginView: View {","    @State private var viewModel = AppContainer.shared.loginViewModel","","    var body: some View {","        \/\/ use viewModel...","    }","}"]},{"text":"Inline resolution","type":"heading","anchor":"Inline-resolution","level":3},{"inlineContent":[{"text":"You can also resolve dependencies directly without the property wrapper:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let service = AppContainer.shared.authService"]},{"text":"Next Steps","type":"heading","anchor":"Next-Steps","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture"},{"text":" — organize containers across multiple modules","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","isActive":true},{"type":"text","text":" — mock dependencies in tests"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"},{"type":"text","text":" — provide previe