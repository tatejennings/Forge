{"abstract":[{"text":"Install Forge and register your first dependencies.","type":"text"}],"kind":"article","metadata":{"role":"article","title":"Getting Started with Forge","roleHeading":"Article","modules":[{"name":"Forge"}]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"seeAlsoSections":[{"title":"Essentials","generated":true,"anchor":"Essentials","identifiers":["doc:\/\/Forge\/documentation\/Forge\/AppContainer","doc:\/\/Forge\/documentation\/Forge\/Forge","doc:\/\/Forge\/documentation\/Forge\/Container","doc:\/\/Forge\/documentation\/Forge\/Scope"]}],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/GettingStarted","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Forge is a lightweight dependency injection framework for Swift. This guide walks you","type":"text"},{"text":" ","type":"text"},{"text":"through installation and registering your first dependencies. Forge offers two paths:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Simple Setup"}],"type":"strong"},{"type":"text","text":" — extend the built-in "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","type":"reference","isActive":true},{"type":"text","text":" and use "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference","isActive":true},{"type":"text","text":" immediately."},{"type":"text","text":" "},{"type":"text","text":"Best for single-target apps and getting started quickly."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Modular Setup","type":"text"}]},{"text":" — create your own container per module with a local typealias.","type":"text"},{"text":" ","type":"text"},{"text":"Best for multi-module SPM architectures.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Installation","text":"Installation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Add Forge to your project via Swift Package Manager. In your ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/tatejennings\/forge.git\", from: \"0.1.0\")","]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then add "},{"type":"codeVoice","code":"Forge"},{"type":"text","text":" to your target’s dependencies:"}]},{"syntax":"swift","type":"codeListing","code":[".target(name: \"MyApp\", dependencies: [\"Forge\"])"]},{"type":"paragraph","inlineContent":[{"text":"Or add it via Xcode: ","type":"text"},{"inlineContent":[{"text":"File > Add Packages","type":"text"}],"type":"strong"},{"text":", enter the repository URL, and add","type":"text"},{"text":" ","type":"text"},{"code":"Forge","type":"codeVoice"},{"text":" to your target.","type":"text"}]},{"anchor":"Simple-Setup","text":"Simple Setup","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Extend the built-in "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true},{"type":"text","text":" with your dependencies. The framework-provided"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":" typealias lets you inject them anywhere — no container class to write,"},{"type":"text","text":" "},{"type":"text","text":"no typealias to define, no setup code at all:"}]},{"syntax":"swift","type":"codeListing","code":["import Forge","","extension AppContainer {","    var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then inject anywhere:"}]},{"syntax":"swift","type":"codeListing","code":["final class LoginViewModel {","    @ObservationIgnored","    @Inject(\\.authService) private var authService","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"That’s it. No "},{"type":"codeVoice","code":"App.init()"},{"type":"text","text":", no manual wiring, no boilerplate."}]},{"anchor":"Modular-Setup","text":"Modular Setup","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"For apps with multiple SPM modules, create a container per module by subclassing"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"type":"text","text":" and conforming to "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","isActive":true},{"type":"text","text":". Add a module-local typealias"},{"type":"text","text":" "},{"type":"text","text":"to shadow the framework’s "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["import Forge","","\/\/ The module-local typealias shadows the framework-provided one","typealias Inject<T> = ContainerInject<AuthContainer, T>","","final class AuthContainer: Container, SharedContainer {","    static let shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    var tokenStorage: any TokenStorageProtocol {","        provide { KeychainTokenStorage() }","    }","}"]},{"anchor":"The-Module-Local-Typealias","text":"The Module-Local Typealias","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"typealias Inject<T> = ContainerInject<AuthContainer, T>","type":"codeVoice"},{"text":" line is placed ","type":"text"},{"inlineContent":[{"text":"in the","type":"text"},{"text":" ","type":"text"},{"text":"container file itself","type":"text"}],"type":"strong"},{"text":" — not in a separate file. This typealias shadows the framework’s","type":"text"},{"text":" ","type":"text"},{"text":"built-in ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"text":" within this module, so ","type":"text"},{"code":"@Inject(\\.authService)","type":"codeVoice"},{"text":" resolves from","type":"text"},{"text":" ","type":"text"},{"code":"AuthContainer","type":"codeVoice"},{"text":" instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["@Inject(\\.authService) private var auth"]},{"type":"paragraph","inlineContent":[{"text":"If you later rename or refactor the container, only the typealias needs updating.","type":"text"}]},{"anchor":"Choose-a-Scope","text":"Choose a Scope","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Every dependency has a lifecycle controlled by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","type":"reference"},{"text":":","type":"text"}]},{"rows":[[[{"inlineContent":[{"text":"Scope","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Behavior","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".transient","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"New instance every time (default)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".singleton","type"