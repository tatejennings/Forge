{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Forge is a lightweight dependency injection framework for Swift. This guide walks you"},{"type":"text","text":" "},{"type":"text","text":"through installation and registering your first dependencies. Forge offers two paths:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Simple Setup","type":"text"}],"type":"strong"},{"text":" — extend the built-in ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer"},{"text":" and use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"text":" immediately.","type":"text"},{"text":" ","type":"text"},{"text":"Best for single-target apps and getting started quickly.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Modular Setup","type":"text"}]},{"type":"text","text":" — create your own container per module with a local typealias."},{"type":"text","text":" "},{"type":"text","text":"Best for multi-module SPM architectures."}]}]}]},{"type":"heading","text":"Installation","level":2,"anchor":"Installation"},{"inlineContent":[{"type":"text","text":"Add Forge to your project via Swift Package Manager. In your "},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/tatejennings\/forge.git\", from: \"0.1.0\")","]"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Then add "},{"type":"codeVoice","code":"Forge"},{"type":"text","text":" to your target’s dependencies:"}],"type":"paragraph"},{"type":"codeListing","code":[".target(name: \"MyApp\", dependencies: [\"Forge\"])"],"syntax":"swift"},{"inlineContent":[{"text":"Or add it via Xcode: ","type":"text"},{"inlineContent":[{"text":"File > Add Packages","type":"text"}],"type":"strong"},{"text":", enter the repository URL, and add","type":"text"},{"text":" ","type":"text"},{"code":"Forge","type":"codeVoice"},{"text":" to your target.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Simple Setup","level":2,"anchor":"Simple-Setup"},{"inlineContent":[{"text":"Extend the built-in ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true},{"text":" with your dependencies. The framework-provided","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"text":" typealias lets you inject them anywhere — no container class to write,","type":"text"},{"text":" ","type":"text"},{"text":"no typealias to define, no setup code at all:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["import Forge","","extension AppContainer {","    var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"Then inject anywhere:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["final class LoginViewModel {","    @ObservationIgnored","    @Inject(\\.authService) private var authService","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"That’s it. No "},{"type":"codeVoice","code":"App.init()"},{"type":"text","text":", no manual wiring, no boilerplate."}],"type":"paragraph"},{"type":"heading","text":"Modular Setup","level":2,"anchor":"Modular-Setup"},{"inlineContent":[{"type":"text","text":"For apps with multiple SPM modules, create a container per module by subclassing"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" and conforming to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer"},{"type":"text","text":". Add a module-local typealias"},{"type":"text","text":" "},{"type":"text","text":"to shadow the framework’s "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["import Forge","","\/\/ The module-local typealias shadows the framework-provided one","typealias Inject<T> = ContainerInject<AuthContainer, T>","","final class AuthContainer: Container, SharedContainer {","    static var shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    var tokenStorage: any TokenStorageProtocol {","        provide { KeychainTokenStorage() }","    }","}"],"syntax":"swift"},{"type":"heading","text":"The Module-Local Typealias","level":3,"anchor":"The-Module-Local-Typealias"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"typealias Inject<T> = ContainerInject<AuthContainer, T>"},{"type":"text","text":" line is placed "},{"inlineContent":[{"text":"in the","type":"text"},{"text":" ","type":"text"},{"text":"container file itself","type":"text"}],"type":"strong"},{"type":"text","text":" — not in a separate file. This typealias shadows the framework’s"},{"type":"text","text":" "},{"type":"text","text":"built-in "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"type":"text","text":" within this module, so "},{"type":"codeVoice","code":"@Inject(\\.authService)"},{"type":"text","text":" resolves from"},{"type":"text","text":" "},{"type":"codeVoice","code":"AuthContainer"},{"type":"text","text":" instead of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["@Inject(\\.authService) private var auth"],"syntax":"swift"},{"inlineContent":[{"text":"If you later rename or refactor the container, only the typealias needs updating.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Choose a Scope","level":2,"anchor":"Choose-a-Scope"},{"inlineContent":[{"text":"Every dependency has a lifecycle controlled by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Scope","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Behavior","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".transient"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"New instance every time (default)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".singleton"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"One instance for the container’s lifetime"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".cached","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"One instance until "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetCached()","type":"reference","isActive":true},{"type":"text","text":" is called"}]}]]]},{"type":"codeListing","code":["var logger: any LoggerProtocol {","    provide(.transient) { ConsoleLogger() }   \/\/ Fresh each time","}","","var database: any DatabaseProtocol {","    provide(.singleton) { SQLiteDatabase() }  \/\/ Lives forever","}","","var session: any SessionProtocol {","    provide(.cached) { UserSession() }        \/\/ Resettable","}"],"syntax":"swift"},{"type":"heading","text":"Inject Dependencies","level":2,"anchor":"Inject-Dependencies"},{"type":"heading","text":"In classes (ViewModels, services)","level":3,"anchor":"In-classes-ViewModels-services"},{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"@Inject"},{"text":" with a key path to the container property:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    @Inject(\\.tokenStorage) private var tokens","","    func login(username: String, password: String) async {","        let user = try? await authService.login(","            username: username,","            password: password","        )","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Resolution is "},{"type":"strong","inlineContent":[{"type":"text","text":"lazy"}]},{"type":"text","text":" — the dependency is resolved on first access of the property,"},{"type":"text","text":" "},{"type":"text","text":"not when the object is created. This ensures overrides set after initialization"},{"type":"text","text":" "},{"type":"text","text":"(common in tests) are picked up correctly."}],"type":"paragraph"},{"type":"heading","text":"In SwiftUI views","level":3,"anchor":"In-SwiftUI-views"},{"inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","isActive":true,"type":"reference"},{"type":"text","text":" uses a "},{"code":"mutating get","type":"codeVoice"},{"type":"text","text":", which doesn’t work directly in SwiftUI"},{"type":"text","text":" "},{"type":"text","text":"view structs. Instead, resolve directly from the container:"}],"type":"paragraph"},{"type":"codeListing","code":["struct LoginView: View {","    @State private var viewModel = AppContainer.shared.loginViewModel","","    var body: some View {","        \/\/ use viewModel...","    }","}"],"syntax":"swift"},{"type":"heading","text":"Inline resolution","level":3,"anchor":"Inline-resolution"},{"inlineContent":[{"text":"You can also resolve dependencies directly without the property wrapper:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let service = AppContainer.shared.authService"],"syntax":"swift"},{"type":"heading","text":"Next Steps","level":2,"anchor":"Next-Steps"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","isActive":true},{"type":"text","text":" — organize containers across multiple modules"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","type":"reference","isActive":true},{"type":"text","text":" — mock dependencies in tests"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","isActive":true,"type":"reference"},{"text":" — provide preview-safe factories","type":"text"}],"type":"paragraph"}]}]}]}],"sections":[],"kind":"article","identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/GettingStarted","interfaceLanguage":"swift"},"metadata":{"role":"article","title":"Getting Started with Forge","roleHeading":"Article","modules":[{"name":"Forge"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"generated":true,"title":"Essentials","identifiers":["doc:\/\/Forge\/documentation\/Forge\/AppContainer","doc:\/\/Forge\/documentation\/Forge\/Forge","doc:\/\/Forge\/documentation\/Forge\/Container","doc:\/\/Forge\/documentation\/Forge\/Scope"],"anchor":"Essentials"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/gettingstarted"]}],"abstract":[{"type":"text","text":"Install Forge and register your first dependencies."}],"hierarchy":{"paths":[["doc:\/\/Forg