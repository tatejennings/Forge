{"kind":"article","abstract":[{"text":"Install Forge and register your first dependencies.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"anchor":"Essentials","title":"Essentials","generated":true,"identifiers":["doc:\/\/Forge\/documentation\/Forge\/AppContainer","doc:\/\/Forge\/documentation\/Forge\/Forge","doc:\/\/Forge\/documentation\/Forge\/Container","doc:\/\/Forge\/documentation\/Forge\/Scope"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Forge is a lightweight dependency injection framework for Swift. This guide walks you","type":"text"},{"text":" ","type":"text"},{"text":"through installation and registering your first dependencies. Forge offers two paths:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Simple Setup","type":"text"}],"type":"strong"},{"text":" — extend the built-in ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer"},{"text":" and use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"text":" immediately.","type":"text"},{"text":" ","type":"text"},{"text":"Best for single-target apps and getting started quickly.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Modular Setup"}]},{"type":"text","text":" — create your own container per module with a local typealias."},{"type":"text","text":" "},{"type":"text","text":"Best for multi-module SPM architectures."}]}]}]},{"text":"Installation","type":"heading","level":2,"anchor":"Installation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add Forge to your project via Swift Package Manager. In your "},{"code":"Package.swift","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/tatejennings\/forge.git\", from: \"0.1.0\")","]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then add "},{"type":"codeVoice","code":"Forge"},{"type":"text","text":" to your target’s dependencies:"}]},{"type":"codeListing","syntax":"swift","code":[".target(name: \"MyApp\", dependencies: [\"Forge\"])"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or add it via Xcode: "},{"type":"strong","inlineContent":[{"text":"File > Add Packages","type":"text"}]},{"type":"text","text":", enter the repository URL, and add"},{"type":"text","text":" "},{"type":"codeVoice","code":"Forge"},{"type":"text","text":" to your target."}]},{"text":"Simple Setup","type":"heading","level":2,"anchor":"Simple-Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Extend the built-in "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true,"type":"reference"},{"type":"text","text":" with your dependencies. The framework-provided"},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true,"type":"reference"},{"type":"text","text":" typealias lets you inject them anywhere — no container class to write,"},{"type":"text","text":" "},{"type":"text","text":"no typealias to define, no setup code at all:"}]},{"syntax":"swift","type":"codeListing","code":["import Forge","","extension AppContainer {","    var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Then inject anywhere:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["final class LoginViewModel {","    @ObservationIgnored","    @Inject(\\.authService) private var authService","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"That’s it. No "},{"type":"codeVoice","code":"App.init()"},{"type":"text","text":", no manual wiring, no boilerplate."}]},{"anchor":"Modular-Setup","type":"heading","text":"Modular Setup","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"For apps with multiple SPM modules, create a container per module by subclassing"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" and conforming to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer"},{"type":"text","text":". Add a module-local typealias"},{"type":"text","text":" "},{"type":"text","text":"to shadow the framework’s "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["import Forge","","\/\/ The module-local typealias shadows the framework-provided one","typealias Inject<T> = ContainerInject<AuthContainer, T>","","final class AuthContainer: Container, SharedContainer {","    static let shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    var tokenStorage: any TokenStorageProtocol {","        provide { KeychainTokenStorage() }","    }","}"]},{"anchor":"The-Module-Local-Typealias","type":"heading","text":"The Module-Local Typealias","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"typealias Inject<T> = ContainerInject<AuthContainer, T>"},{"type":"text","text":" line is placed "},{"inlineContent":[{"text":"in the","type":"text"},{"text":" ","type":"text"},{"text":"container file itself","type":"text"}],"type":"strong"},{"type":"text","text":" — not in a separate file. This typealias shadows the framework’s"},{"type":"text","text":" "},{"type":"text","text":"built-in "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference","isActive":true},{"type":"text","text":" within this module, so "},{"type":"codeVoice","code":"@Inject(\\.authService)"},{"type":"text","text":" resolves from"},{"type":"text","text":" "},{"type":"codeVoice","code":"AuthContainer"},{"type":"text","text":" instead of "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","type":"reference","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","code":["@Inject(\\.authService) private var auth"],"type":"codeListing"},{"inlineContent":[{"text":"If you later rename or refactor the container, only the typealias needs updating.","type":"text"}],"type":"paragraph"},{"anchor":"Choose-a-Scope","level":2,"text":"Choose a Scope","type":"heading"},{"inlineContent":[{"text":"Every dependency has a lifecycle controlled by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Scope","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Behavior"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".transient"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"New instance every time (default)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".singleton"}]}],[{"type":"paragraph","inlineContent":[{"text":"One instance for the container’s lifetime","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".cached"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"One instance un