entifier","text":"Scope"}],"title":"Scope","type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","url":"\/documentation\/forge\/scope"},"doc://Forge/documentation/Forge/Container/resetCached()":{"kind":"symbol","role":"symbol","title":"resetCached()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"resetCached"},{"kind":"text","text":"()"}],"type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetCached()","url":"\/documentation\/forge\/container\/resetcached()","abstract":[{"type":"text","text":"Clears only cached-scope values. Leaves singletons and overrides intact."}]},"doc://Forge/documentation/Forge":{"url":"\/documentation\/forge","identifier":"doc:\/\/Forge\/documentation\/Forge","kind":"symbol","abstract":[{"text":"A lightweight, compile-time safe dependency injection framework for Swift.","type":"text"}],"role":"collection","type":"topic","title":"Forge"},"doc://Forge/documentation/Forge/ModularArchitecture":{"type":"topic","url":"\/documentation\/forge\/modulararchitecture","kind":"article","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","title":"Modular Architecture","role":"article","abstract":[{"text":"Organize dependency injection across multiple Swift Package Manager modules.","type":"text"}]},"doc://Forge/documentation/Forge/Container":{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","kind":"symbol","type":"topic","abstract":[{"text":"The base class for all dependency containers in Forge.","type":"text"}],"navigatorTitle":[{"text":"Container","kind":"identifier"}],"title":"Container","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Container","kind":"identifier"}],"url":"\/documentation\/forge\/container","role":"symbol"},"doc://Forge/documentation/Forge/TestingWithForge":{"title":"Testing with Forge","type":"topic","abstract":[{"type":"text","text":"Mock dependencies in tests using s