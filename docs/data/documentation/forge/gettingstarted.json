{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/GettingStarted","interfaceLanguage":"swift"},"kind":"article","abstract":[{"type":"text","text":"Install Forge and register your first dependencies."}],"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/Forge\/documentation\/Forge\/AppContainer","doc:\/\/Forge\/documentation\/Forge\/Forge","doc:\/\/Forge\/documentation\/Forge\/Container","doc:\/\/Forge\/documentation\/Forge\/Scope"],"generated":true,"anchor":"Essentials"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/gettingstarted"]}],"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Forge is a lightweight dependency injection framework for Swift. This guide walks you","type":"text"},{"text":" ","type":"text"},{"text":"through installation and registering your first dependencies. Forge offers two paths:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Simple Setup","type":"text"}]},{"type":"text","text":" — extend the built-in "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true},{"type":"text","text":" and use "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":" immediately."},{"type":"text","text":" "},{"type":"text","text":"Best for single-target apps and getting started quickly."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Modular Setup","type":"text"}],"type":"strong"},{"text":" — create your own container per module with a local typealias.","type":"text"},{"text":" ","type":"text"},{"text":"Best for multi-module SPM architectures.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Installation","anchor":"Installation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Add Forge to your project via Swift Package Manager. In your ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"text":":","type":"text"}]},{"code":["dependencies: [","    .package(url: \"https:\/\/github.com\/tatejennings\/forge.git\", from: \"0.1.0\")","]"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then add "},{"type":"codeVoice","code":"Forge"},{"type":"text","text":" to your target’s dependencies:"}]},{"code":[".target(name: \"MyApp\", dependencies: [\"Forge\"])"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Or add it via Xcode: ","type":"text"},{"inlineContent":[{"type":"text","text":"File > Add Packages"}],"type":"strong"},{"text":", enter the repository URL, and add","type":"text"},{"text":" ","type":"text"},{"code":"Forge","type":"codeVoice"},{"text":" to your target.","type":"text"}]},{"text":"Simple Setup","anchor":"Simple-Setup","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Extend the built-in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer"},{"type":"text","text":" with your dependencies. The framework-provided"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"type":"text","text":" typealias lets you inject them anywhere — no container class to write,"},{"type":"text","text":" "},{"type":"text","text":"no typealias to define, no setup code at all:"}]},{"code":["import Forge","","extension AppContainer {","    var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Then inject anywhere:","type":"text"}]},{"code":["final class LoginViewModel {","    @ObservationIgnored","    @Inject(\\.authService) private var authService","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"That’s it. No "},{"type":"codeVoice","code":"App.init()"},{"type":"text","text":", no manual wiring, no boilerplate."}]},{"text":"Modular Setup","anchor":"Modular-Setup","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"For apps with multiple SPM modules, create a container per module by subclassing","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference"},{"text":" and conforming to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","type":"reference"},{"text":". Add a module-local typealias","type":"text"},{"text":" ","type":"text"},{"text":"to shadow the framework’s ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference"},{"text":":","type":"text"}]},{"code":["import Forge","","\/\/ The module-local typealias shadows the framework-provided one","typealias Inject<T> = ContainerInject<AuthContainer, T>","","final class AuthContainer: Container, SharedContainer {","    static var shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    var tokenStorage: any TokenStorageProtocol {","        provide { KeychainTokenStorage() }","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"The Module-Local Typealias","ancho