{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge is a lightweight dependency injection framework for Swift. This guide walks you"},{"type":"text","text":" "},{"type":"text","text":"through installation and registering your first dependencies. Forge offers two paths:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Simple Setup"}],"type":"strong"},{"type":"text","text":" — extend the built-in "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer"},{"type":"text","text":" and use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"type":"text","text":" immediately."},{"type":"text","text":" "},{"type":"text","text":"Best for single-target apps and getting started quickly."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Modular Setup","type":"text"}]},{"type":"text","text":" — create your own container per module with a local typealias."},{"type":"text","text":" "},{"type":"text","text":"Best for multi-module SPM architectures."}]}]}]},{"text":"Installation","anchor":"Installation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Add Forge to your project via Swift Package Manager. In your ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/tatejennings\/forge.git\", from: \"0.1.0\")","]"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then add "},{"type":"codeVoice","code":"Forge"},{"type":"text","text":" to your target’s dependencies:"}]},{"type":"codeListing","code":[".target(name: \"MyApp\", dependencies: [\"Forge\"])"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Or add it via Xcode: ","type":"text"},{"type":"strong","inlineContent":[{"text":"File > Add Packages","type":"text"}]},{"text":", enter the repository URL, and add","type":"text"},{"text":" ","type":"text"},{"code":"Forge","type":"codeVoice"},{"text":" to your target.","type":"text"}]},{"text":"Simple Setup","anchor":"Simple-Setup","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Extend the built-in ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer"},{"text":" with your dependencies. The framework-provided","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"text":" typealias lets you inject them anywhere — no container class to write,","type":"text"},{"text":" ","type":"text"},{"text":"no typealias to define, no setup code at all:","type":"text"}]},{"type":"codeListing","code":["import Forge","","extension AppContainer {","    var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Then inject anywhere:","type":"text"}]},{"type":"codeListing","code":["final class LoginViewModel {","    @ObservationIgnored","    @Inject(\\.authService) private var authService","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"That’s it. No "},{"code":"App.init()","type":"codeVoice"},{"type":"text","text":", no manual wiring, no boilerplate."}]},{"text":"Modular Setup","anchor":"Modular-Setup","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"For apps with multiple SPM modules, create a container per module by subclassing","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true,"type":"reference"},{"text":" and conforming to ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","isActive":true,"type":"reference"},{"text":". Add a module-local typealias","type":"text"},{"text":" ","type":"text"},{"text":"to shadow the framework’s ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"type":"codeListing","code":["import Forge","","\/\/ The module-local typealias shadows the framework-provided one","typealias Inject<T> = ContainerInject<AuthContainer, T>","","final class AuthContainer: Container, SharedContainer {","    static let shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    var tokenStorage: any TokenStorageProtocol {","        provide { KeychainTokenStorage() }","    }","}"],"syntax":"swift"},{"text":"The Module-Local Typealias","anchor":"The-Module-Local-Typealias","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"typealias Inject<T> = ContainerInject<AuthContainer, T>"},{"type":"text","text":" line is placed "},{"type":"strong","inlineContent":[{"text":"in the","type":"text"},{"text":" ","type":"text"},{"text":"container file itself","type":"text"}]},{"type":"text","text":" — not in a separate file. This typealias shadows the framework’s"},{"type":"text","text":" "},{"type":"text","text":"built-in "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":" within this module, so "},{"type":"codeVoice","code":"@Inject(\\.authService)"},{"type":"text","text":" resolves from"},{"type":"text","text":" "},{"type":"codeVoice","code":"AuthContainer"},{"type":"text","text":" instead of "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","code":["@Inject(\\.authService) private var auth"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you later rename or refactor the container, only the typealias needs updating."}]},{"text":"Choose a Scope","anchor":"Choose-a-Scope","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every dependency has a lifecycle controlled by "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","isActive":true,"type":"reference"},{"type":"text","text":":"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Scope","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Behavior","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".transient"}]}],[{"type":"paragraph","inlineContent":[{"text":"New instance every time (default)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".singleton"}]}],[{"type":"paragraph","inlineContent":[{"text":"One instance for the container’s lifetime","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".cached"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"One instance until "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetCached()"},{"type":"text","text":" is called"}]}]]]},{"type":"codeListing","code":["var logger: any LoggerProtocol {","    provide(.transient) { ConsoleLogger() }   \/\/ Fresh each time","}","","var database: any DatabaseProtocol {","    provide(.singleton) { SQLiteDatabase() }  \/\/ Lives forever","}","","var session: any SessionProtocol {","    provide(.cached) { UserSession() }        \/\/ Resettable","}"],"syntax":"swift"},{"text":"Inject Dependencies","anchor":"Inject-Dependencies","type":"heading","level":2},{"text":"In classes (ViewModels, services)","anchor":"In-classes-ViewModels-services","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"@Inject"},{"type":"text","text":" with a key path to the container property:"}]},{"type":"codeListing","code":["final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    @Inject(\\.tokenStorage) private var tokens","","    func login(username: String, password: String) async {","        let user = try? await authService.login(","            username: username,","            password: password","        )","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolution is "},{"type":"strong","inlineContent":[{"text":"lazy","type":"text"}]},{"type":"text","text":" — the dependency is resolved on first access of the property,"},{"type":"text","text":" "},{"type":"text","text":"not when the object is created. This ensures overrides set after initialization"},{"type":"text","text":" "},{"type":"text","text":"(common in tests) are picked up correctly."}]},{"text":"In SwiftUI views","anchor":"In-SwiftUI-views","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"type":"text","text":" uses a "},{"code":"mutating get","type":"codeVoice"},{"type":"text","text":", which doesn’t work directly in SwiftUI"},{"type":"text","text":" "},{"type":"text","text":"view structs. Instead, resolve directly from the container:"}]},{"type":"codeListing","code":["struct LoginView: View {","    @State private var viewModel = AppContainer.shared.loginViewModel","","    var body: some View {","        \/\/ use viewModel...","    }","}"],"syntax":"swift"},{"text":"Inline resolution","anchor":"Inline-resolution","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also resolve dependencies directly without the property wrapper:"}]},{"type":"codeListing","code":["let service = AppContainer.shared.authService"],"syntax":"swift"},{"text":"Next Steps","anchor":"Next-Steps","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture"},{"type":"text","text":" — organize containers across multiple modules"}]}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","isActive":true},{"text":" — mock dependencies in tests","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","isActive":true,"type":"reference"},{"text":" — provide preview-safe factories","type":"text"}]}]}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/GettingStarted"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/gettingstarted"]}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"article","abstract":[{"text":"Install Forge and register your first dependencies.","type":"text"}],"metadata":{"title":"Getting Started with Forge","role":"article","modules":[{"name":"Forge"}],"roleHeading":"Article"},"seeAlsoSections":[{"title":"Essentials","anchor":"Essentials","generated":true,"identifiers":["doc:\/\/Forge\/documentation\/Forge\/AppContainer","doc:\/\/Forge\/documentation\/Forge\/Forge","doc:\/\/Forge\/documentation\/Forge\/Container","doc:\/\/Forge\/docu