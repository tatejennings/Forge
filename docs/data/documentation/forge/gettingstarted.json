{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge is a lightweight dependency injection framework for Swift. This guide walks you"},{"type":"text","text":" "},{"type":"text","text":"through installation and registering your first dependencies. Forge offers two paths:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Simple Setup"}],"type":"strong"},{"text":" — extend the built-in ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer"},{"text":" and use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"text":" immediately.","type":"text"},{"text":" ","type":"text"},{"text":"Best for single-target apps and getting started quickly.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Modular Setup"}]},{"text":" — create your own container per module with a local typealias.","type":"text"},{"text":" ","type":"text"},{"text":"Best for multi-module SPM architectures.","type":"text"}]}]}]},{"type":"heading","level":2,"text":"Installation","anchor":"Installation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add Forge to your project via Swift Package Manager. In your "},{"code":"Package.swift","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/tatejennings\/forge.git\", from: \"0.1.0\")","]"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Then add ","type":"text"},{"type":"codeVoice","code":"Forge"},{"text":" to your target’s dependencies:","type":"text"}]},{"type":"codeListing","code":[".target(name: \"MyApp\", dependencies: [\"Forge\"])"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or add it via Xcode: "},{"type":"strong","inlineContent":[{"text":"File > Add Packages","type":"text"}]},{"type":"text","text":", enter the repository URL, and add"},{"type":"text","text":" "},{"type":"codeVoice","code":"Forge"},{"type":"text","text":" to your target."}]},{"type":"heading","level":2,"text":"Simple Setup","anchor":"Simple-Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Extend the built-in "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true},{"type":"text","text":" with your dependencies. The framework-provided"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":" typealias lets you inject them anywhere — no container class to write,"},{"type":"text","text":" "},{"type":"text","text":"no typealias to define, no setup code at all:"}]},{"syntax":"swift","code":["import Forge","","extension AppContainer {","    var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","","    var authService: any AuthServiceProtocol {","        provide(.singleton, preview: { MockAuthService() }) {","            AuthService(network: self.networkClient)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then inject anywhere:"}],"type":"paragraph"},{"syntax":"swift","code":["final class LoginViewModel {","    @ObservationIgnored","    @Inject(\\.authService) private var authService","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"That’s it. No "},{"code":"App.init()","type":"codeVoice"},{"type":"text","text":", no manual wiring, no boilerplate."}],"type":"paragraph"},{"anchor":"Modular-Setup","text":"Modular Setup","level":2,"type":"heading"},{"inlineContent":[{"text":"For apps with multiple SPM modules, create a container per module by subclassing","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"text":" and conforming to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer"},{"text":". Add a module-local typealias","type":"text"},{"text":" ","type":"text"},{"text":"to shadow the framework’s ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import Forge","","\/\/ The module-local typealias shadows the framework-provided one","typealias Inject<T> = ContainerInject<AuthContainer, T>","","final class AuthContainer: Container, SharedContainer {","    static var shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton, preview: { MockAuthService() }) {","            AuthService(network: self.networkClient)","        }","    }","","    var tokenStorage: any TokenStorageProtocol {","        provide { KeychainTokenStorage() }","    }","}"],"type":"codeListing"},{"anchor":"The-Module-Local-Typealias","text":"The Module-Local Typealias","level":3,"type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"typealias Inject<T> = ContainerInject<AuthContainer, T>","type":"codeVoice"},{"text":" line is placed ","type":"text"},{"inlineContent":[{"type":"text","text":"in the"},{"type":"text","text":" "},{"type":"text","text":"container file itself"}],"type":"strong"},{"text":" — not in a separate file. This typealias shadows the framework’s","type":"text"},{"text":" ","type":"text"},{"text":"built-in ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true,"type":"reference"},{"text":" within this module, so ","type":"text"},{"code":"@Inject(\\.authService)","type":"codeVoice"},{"text":" resolves from","type":"text"},{"text":" ","type":"text"},{"code":"AuthContainer","type":"codeVoice"},{"text":" instead of ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Inject(\\.authService) private var auth"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you later rename or refactor the container, only the typealias needs updating."}]},{"type":"heading","text":"Choose a Scope","anchor":"Choose-a-Scope","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every dependency has a lifecycle controlled by "},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","type":"reference"},{"type":"text","text":":"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Scope","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Behavior","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".transient","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"New instance every time (default)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".singleton"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"One instance for the container’s lifetime"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".cached"}],"type":"paragraph"}],[{"inlineContent":[{"text":"One instance until ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetCached()","isActive":true,"type":"reference"},{"text":" is called","type":"text"}],"type":"paragraph"}]]]},{"type":"codeListing","syntax":"swift","code":["var logger: any LoggerProtocol {","    provide(.transient) { ConsoleLogger() }   \/\/ Fresh each time","}","","var database: any DatabaseProtocol {","    provide(.singleton) { SQLiteDatabase() }  \/\/ Lives forever","}","","var session: any SessionProtocol {","    provide(.cached) { UserSession() }        \/\/ Resettable","}"]},{"type":"heading","text":"Inject Dependencies","anchor":"Inject-Dependencies","level":2},{"type":"heading","text":"In classes (ViewModels, services)","anchor":"In-classes-ViewModels-services","level":3},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"@Inject","type":"codeVoice"},{"text":" with a key path to the container property:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    @Inject(\\.tokenStorage) private var tokens","","    func login(username: String, password: String) async {","        let user = try? await authService.login(","            username: username,","            password: password","        )","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Resolution is ","type":"text"},{"inlineContent":[{"text":"lazy","type":"text"}],"type":"strong"},{"text":" — the dependency is resolved on first access of the property,","type":"text"},{"text":" ","type":"text"},{"text":"not when the object is created. This ensures overrides set after initialization","type":"text"},{"text":" ","type":"text"},{"text":"(common in tests) are picked up correctly.","type":"text"}]},{"type":"heading","text":"In SwiftUI views","anchor":"In-SwiftUI-views","level":3},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"type":"text","text":" uses a "},{"code":"mutating get","type":"codeVoice"},{"type":"text","text":", which doesn’t work directly in SwiftUI"},{"type":"text","text":" "},{"type":"text","text":"view structs. Instead, resolve directly from the container:"}]},{"type":"codeListing","syntax":"swift","code":["struct LoginView: View {","    @State private var viewModel = AppContainer.shared.loginViewModel","","    var body: some View {","        \/\/ use viewModel...","    }","}"]},{"type":"heading","text":"Inline resolution","anchor":"Inline-resolution","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also resolve dependencies directly without the property wrapper:"}]},{"type":"codeListing","syntax":"swift","code":["let service = AppContainer.shared.authService"]},{"type":"heading","text":"Next Steps","anchor":"Next-Steps","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","isActive":true,"type":"reference"},{"text":" — organize containers across multiple modules","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge","type":"reference"},{"text":" — mock dependencies in tests","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"},{"type":"text","text":" — provide preview-safe factories"}]}]}]}]}],"seeAlsoSections":[{"generated":true,"title":"Essentials","anchor":"Essentials","identifiers":["doc:\/\/Forge\/documentation\/Forge\/AppContainer","doc:\/\/Forge\/documentation\/Forge\/Forge","doc:\/\/Forge\/documentation\/Forge\/Container","doc:\/\/Forge\/documentation\/Forge\/Scope"]}],"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"Forge"}],"title":"Getting Started with Forge"},"sections":[],"abstract":[{"type":"text","text":"Install Forge and register your first dependencies."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"variants":[{"paths":["\/documentation\/forge\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/GettingStarted","interfaceLanguage":"swift"},"references":{"doc