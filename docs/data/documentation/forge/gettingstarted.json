{"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge is a lightweight dependency injection framework for Swift. This guide walks you"},{"type":"text","text":" "},{"type":"text","text":"through installation and registering your first dependencies. Forge offers two paths:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Simple Setup"}],"type":"strong"},{"type":"text","text":" — extend the built-in "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","type":"reference","isActive":true},{"type":"text","text":" and use "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference","isActive":true},{"type":"text","text":" immediately."},{"type":"text","text":" "},{"type":"text","text":"Best for single-target apps and getting started quickly."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Modular Setup","type":"text"}]},{"text":" — create your own container per module with a local typealias.","type":"text"},{"text":" ","type":"text"},{"text":"Best for multi-module SPM architectures.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Installation","type":"heading","level":2,"text":"Installation"},{"type":"paragraph","inlineContent":[{"text":"Add Forge to your project via Swift Package Manager. In your ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/tatejennings\/forge.git\", from: \"0.1.0\")","]"]},{"type":"paragraph","inlineContent":[{"text":"Then add ","type":"text"},{"code":"Forge","type":"codeVoice"},{"text":" to your target’s dependencies:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":[".target(name: \"MyApp\", dependencies: [\"Forge\"])"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or add it via Xcode: "},{"type":"strong","inlineContent":[{"type":"text","text":"File > Add Packages"}]},{"type":"text","text":", enter the repository URL, and add"},{"type":"text","text":" "},{"code":"Forge","type":"codeVoice"},{"type":"text","text":" to your target."}]},{"anchor":"Simple-Setup","type":"heading","level":2,"text":"Simple Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Extend the built-in "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true},{"type":"text","text":" with your dependencies. The framework-provided"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":" typealias lets you inject them anywhere — no container class to write,"},{"type":"text","text":" "},{"type":"text","text":"no typealias to define, no setup code at all:"}]},{"syntax":"swift","type":"codeListing","code":["import Forge","","extension AppContainer {","    var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Then inject anywhere:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["final class LoginViewModel {","    @ObservationIgnored","    @Inject(\\.authService) private var authService","}"]},{"type":"paragraph","inlineContent":[{"text":"That’s it. No ","type":"text"},{"code":"App.init()","type":"codeVoice"},{"text":", no manual wiring, no boilerplate.","type":"text"}]},{"anchor":"Modular-Setup","type":"heading","level":2,"text":"Modular Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For apps with multiple SPM modules, create a container per module by subclassing"},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference","isActive":true},{"type":"text","text":" and conforming to "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","type":"reference","isActive":true},{"type":"text","text":". Add a module-local typealias"},{"type":"text","text":" "},{"type":"text","text":"to shadow the framework’s "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["import Forge","","\/\/ The module-local typealias shadows the framework-provided one","typealias Inject<T> = ContainerInject<AuthContainer, T>","","final class AuthContainer: Container, SharedContainer {","    static let shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    var tokenStorage: any TokenStorageProtocol {","        provide { KeychainTokenStorage() }","    }","}"]},{"anchor":"The-Module-Local-Typealias","type":"heading","level":3,"text":"The Module-Local Typealias"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"typealias Inject<T> = ContainerInject<AuthContainer, T>","type":"codeVoice"},{"text":" line is placed ","type":"text"},{"inlineContent":[{"type":"text","text":"in the"},{"type":"text","text":" "},{"type":"text","text":"container file itself"}],"type":"strong"},{"text":" — not in a separate file. This typealias shadows the framework’s","type":"text"},{"text":" ","type":"text"},{"text":"built-in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference"},{"text":" within this module, so ","type":"text"},{"code":"@Inject(\\.authService)","type":"codeVoice"},{"text":" resolves from","type":"text"},{"text":" ","type":"text"},{"code":"AuthContainer","type":"codeVoice"},{"text":" instead of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","type":"reference"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["@Inject(\\.authService) private var auth"]},{"type":"paragraph","inlineContent":[{"text":"If you later rename or refactor the container, only the typealias needs updating.","type":"text"}]},{"anchor":"Choose-a-Scope","type":"heading","level":2,"text":"Choose a Scope"},{"type":"paragraph","inlineContent":[{"text":"Every dependency has a lifecycle controlled by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","type":"reference"},{"text":":","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Scope","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Behavior","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".transient","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"New instance every time (default)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".singleton"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"One instance for the container’s lifetime"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".cached"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"One instance until "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/resetCached()"},{"type":"text","text":" is called"}]}]]],"header":"row","type":"table"},{"syntax":"swift","type":"codeListing","code":["var logger: any LoggerProtocol {","    provide(.transient) { ConsoleLogger() }   \/\/ Fresh each time","}","","var database: any DatabaseProtocol {","    provide(.singleton) { SQLiteDatabase() }  \/\/ Lives forever","}","","var session: any SessionProtocol {","    provide(.cached) { UserSession() }        \/\/ Resettable","}"]},{"anchor":"Inject-Dependencies","type":"heading","level":2,"text":"Inject Dependencies"},{"anchor":"In-classes-ViewModels-services","type":"heading","level":3,"text":"In classes (ViewModels, services)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"@Inject"},{"type":"text","text":" with a key path to the container property:"}]},{"syntax":"swift","type":"codeListing","code":["final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    @Inject(\\.tokenStorage) private var tokens","","    func login(username: String, password: String) async {","        let user = try? await authService.login(","            username: username,","            password: password","        )","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolution is "},{"type":"strong","inlineContent":[{"type":"text","text":"lazy"}]},{"type":"text","text":" — the dependency is resolved on first access of the property,"},{"type":"text","text":" "},{"type":"text","text":"not when the object is created. This ensures overrides set after initialization"},{"type":"text","text":" "},{"type":"text","text":"(common in tests) are picked up correctly."}]},{"anchor":"In-SwiftUI-views","type":"heading","level":3,"text":"In SwiftUI views"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","isActive":true},{"type":"text","text":" uses a "},{"type":"codeVoice","code":"mutating get"},{"type":"text","text":", which doesn’t work directly in SwiftUI"},{"type":"text","text":" "},{"type":"text","text":"view structs. Instead, resolve directly from the container:"}]},{"syntax":"swift","type":"codeListing","code":["struct LoginView: View {","    @State private var viewModel = AppContainer.shared.loginViewModel","","    var body: some View {","        \/\/ use viewModel...","    }","}"]},{"anchor":"Inline-resolution","type":"heading","level":3,"text":"Inline resolution"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also resolve dependencies directly without the property wrapper:"}]},{"syntax":"swift","type":"codeListing","code":["let service = AppContainer.shared.authService"]},{"anchor":"Next-Steps","type":"heading","level":2,"text":"Next Steps"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture"},{"type":"text","text":" — organize containers across multiple modules"}]}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/TestingWithForge"},{"type":"text","text":" — mock dependencies in tests"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","type":"reference","isActive":true},{"type":"text","text":" — provide preview-safe factories"}]}]}],"type":"unorderedList"}]}],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/GettingStarted","interfaceLanguage":"swift"},"seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/AppContainer","doc:\/\/Forge\/documentation\/Forge\/Forge","doc:\/\/Forge\/documentation\/Forge\/Container","doc:\/\/Forge\/documentation\/Forge\/Scope"],"anchor":"Essentials","generated":true,"title":"Essentials"}],"abstract":[{"type":"text","text":"Install Forge and register your first dependencies."}],"variants":[{"paths":["\/documentation\/forge\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"metadata":{"roleHeading":"Article","modules":[{"name":"Forge"}],"title":"Getting Started with Forge","role":