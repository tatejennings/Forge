{"kind":"article","identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"abstract":[{"text":"How each SOLID principle maps to Forge usage, with practical Swift examples.","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"title":"Architecture and Best Practices","generated":true,"anchor":"Architecture-and-Best-Practices"}],"variants":[{"paths":["\/documentation\/forge\/solidprinciples"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"Forge is designed to make SOLID principles the path of least resistance. Each"},{"type":"text","text":" "},{"type":"text","text":"principle applies to both the framework’s internal design and how you structure"},{"type":"text","text":" "},{"type":"text","text":"your own code when using it."}],"type":"paragraph"},{"level":2,"anchor":"Single-Responsibility-Principle","type":"heading","text":"Single Responsibility Principle"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each type should have one reason to change."}]}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"text":" Every Forge type does one thing — ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"text":" manages","type":"text"},{"text":" ","type":"text"},{"text":"lifecycle and resolution, ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","isActive":true},{"text":" describes caching behavior,","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","isActive":true},{"text":" handles injection, ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","isActive":true},{"text":" handles test","type":"text"},{"text":" ","type":"text"},{"text":"configuration.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"In your code:","type":"text"}],"type":"strong"},{"text":" Each container should own dependencies for exactly one module.","type":"text"},{"text":" ","type":"text"},{"text":"If a container grows beyond its module’s concerns, that signals the module has","type":"text"},{"text":" ","type":"text"},{"text":"too many responsibilities.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Correct: one container per module","final class AuthContainer: Container, SharedContainer {","    static let shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) { AuthService() }","    }","}","","final class AnalyticsContainer: Container, SharedContainer {","    static let shared = AnalyticsContainer()","","    var tracker: any AnalyticsTrackerProtocol {","        provide(.singleton) { MixpanelTracker() }","    }","}"]},{"level":2,"anchor":"OpenClosed-Principle","type":"heading","text":"Open\/Closed Principle"},{"content":[{"inlineContent":[{"text":"Open for extension, closed for modification.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" is an "},{"type":"codeVoice","code":"open class"},{"type":"text","text":". New containers extend it"},{"type":"text","text":" "},{"type":"text","text":"by adding computed properties — you never modify the base class."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"In your code:","type":"text"}],"type":"strong"},{"type":"text","text":" Change behavior by overriding at the container boundary, not by"},{"type":"text","text":" "},{"type":"text","text":"modifying implementation types. A test that needs different behavior provides a"},{"type":"text","text":" "},{"type":"text","text":"different factory:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Correct: extend at the container boundary","try await AuthContainer.shared.withOverrides {","    $0.override(\\.authService) { MockAuthService() }","} run: {","    \/\/ test code...","}","","\/\/ Incorrect: adding test flags inside production types","class AuthService {","    var isTesting = false  \/\/ Don't do this","}"]},{"level":2,"anchor":"Liskov-Substitution-Principle","type":"heading","text":"Liskov Substitution Principle"},{"content":[{"inlineContent":[{"text":"Subtypes must be substitutable for their base types.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" subclasses are always valid containers. The"},{"type":"text","text":" "},{"type":"text","text":"base class API works identically on any subclass."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"text":" Always declare container properties using protocol return types.","type":"text"},{"text":" ","type":"text"},{"text":"This is what makes mocks substitutable for live implementations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Correct: protocol return type — mock is substitutable","public var authService: any AuthServiceProtocol {","    provide(.singleton) { AuthService() }","}","","\/\/ Incorrect: concrete type — cannot substitute a mock","public var authService: AuthService {","    provide(.singleton) { AuthService() }","}"]},{"inlineContent":[{"text":"When the return type is a protocol, any conforming type — live or mock — can be","type":"text"},{"text":" ","type":"text"},{"text":"swapped in without changing consuming code.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Interface-Segregation-Principle","type":"heading","text":"Interface Segregation Principle"},{"content":[{"inlineContent":[{"text":"Clients should not depend on interfaces they do not use.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In the framework:","type":"text"}]},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer"},{"text":" is a minimal protocol with a single","type":"text"},{"text":" ","type":"text"},{"text":"requirement (","type":"text"},{"type":"codeVoice","code":"static var shared { get }"},{"text":", satisfied by a ","type":"text"},{"type":"codeVoice","code":"static let"},{"text":"). ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"text":" does not conform to it by","type":"text"},{"text":" ","type":"text"},{"text":"default — you opt in only when you need the zero-argument ","type":"text"},{"type":"codeVoice","code":"@Inject"},{"text":" syntax.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"text":" Define narrow protocols for each dependency. A","type":"text"},{"text":" ","type":"text"},{"code":"NetworkClientProtocol","type":"codeVoice"},{"text":" should not carry authentication methods just because the","type":"text"},{"text":" ","type":"text"},{"text":"networking layer also handles auth:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Correct: narrow protocols","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","}","","protocol AuthTokenProviderProtocol {","    var currentToken: String? { get }","}","","\/\/ Incorrect: fat protocol","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","    var currentToken: String? { get }   \/\/ Not a networking concern","    func logout()                        \/\/ Definitely not networking","}"]},{"level":2,"anchor":"Dependency-Inversion-Principle","type":"heading","text":"Dependency Inversion Principle"},{"content":[{"type":"paragraph","inlineContent":[{"text":"High-level modules should not depend on low-level modules. Both should depend","type":"text"},{"text":" ","type":"text"},{"text":"on abstractions.","type":"text"}]}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"inlineContent":[{"text":"This is Forge’s entire purpose.","type":"text"}],"type":"strong"},{"text":" The container is the composition root — the","type":"text"},{"text":" ","type":"text"},{"text":"only place where abstractions are wired to concrete implementations. Everything","type":"text"},{"text":" ","type":"text"},{"text":"above it (ViewModels, services) depends only on protocols. Everything below it","type":"text"},{"text":" ","type":"text"},{"text":"(concrete implementations) knows nothing about the container.","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","Feature modules (depend on protocols, use Forge for wiring)","       ^","       |","App target (imports both, wires at startup)"]},{"inlineContent":[{"type":"text","text":"ViewModels and services never "},{"code":"import","type":"codeVoice"},{"type":"text","text":" a concrete implementation module directly."},{"type":"text","text":" "},{"type":"text","text":"They inject via protocol. The container handles the wiring:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ ViewModel depends only on the protocol","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    \/\/ LoginViewModel has no idea what AuthService is —","    \/\/ it only knows AuthServiceProtocol","}"]},{"level":2,"anchor":"Summary","type":"heading","text":"Summary"},{"rows":[[[{"inlineContent":[{"text":"Principle","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge Pattern"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Single Responsibility"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"One container per module"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Open\/Closed","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Override at the container, don’t modify types","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Liskov Substitution"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Protocol return types on all properties"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Interface Segregation"}]}],[{"type":"paragraph","inlineContent":[{"text":"Narrow protocols, opt-in ","type":"text"},{"code":"SharedContainer","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Dependency Inversion","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Container is the composition root","type":"text"}]}]]],"header":"row","type":"table"}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"SOLID Principles with Forge","modules":[{"name":"Forge"}],"role":"article","roleHeading":"Article"},"references":{"doc://Forge/documentation/Forge/Scope":{"kind":"symbol","abstract":[{"type":"text","text