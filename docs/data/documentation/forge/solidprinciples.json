{"metadata":{"roleHeading":"Article","role":"article","title":"SOLID Principles with Forge","modules":[{"name":"Forge"}]},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"abstract":[{"type":"text","text":"How each SOLID principle maps to Forge usage, with practical Swift examples."}],"variants":[{"paths":["\/documentation\/forge\/solidprinciples"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","sections":[],"seeAlsoSections":[{"generated":true,"title":"Architecture and Best Practices","anchor":"Architecture-and-Best-Practices","identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge is designed to make SOLID principles the path of least resistance. Each"},{"type":"text","text":" "},{"type":"text","text":"principle applies to both the framework’s internal design and how you structure"},{"type":"text","text":" "},{"type":"text","text":"your own code when using it."}]},{"anchor":"Single-Responsibility-Principle","type":"heading","level":2,"text":"Single Responsibility Principle"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each type should have one reason to change."}]}],"type":"aside","style":"note"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"In the framework:","type":"text"}]},{"type":"text","text":" Every Forge type does one thing — "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference","isActive":true},{"type":"text","text":" manages"},{"type":"text","text":" "},{"type":"text","text":"lifecycle and resolution, "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"type":"text","text":" describes caching behavior,"},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","isActive":true,"type":"reference"},{"type":"text","text":" handles injection, "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder"},{"type":"text","text":" handles test"},{"type":"text","text":" "},{"type":"text","text":"configuration."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In your code:","type":"text"}]},{"type":"text","text":" Each container should own dependencies for exactly one module."},{"type":"text","text":" "},{"type":"text","text":"If a container grows beyond its module’s concerns, that signals the module has"},{"type":"text","text":" "},{"text":"too many responsibilities.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Correct: one container per module","final class AuthContainer: Container, SharedContainer {","    static var shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) { AuthService() }","    }","}","","final class AnalyticsContainer: Container, SharedContainer {","    static var shared = AnalyticsContainer()","","    var tracker: any AnalyticsTrackerProtocol {","        provide(.singleton) { MixpanelTracker() }","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"OpenClosed-Principle","type":"heading","text":"Open\/Closed Principle"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open for extension, closed for modification."}]}],"name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"text":" is an ","type":"text"},{"code":"open class","type":"codeVoice"},{"type":"text","text":". New containers extend it"},{"text":" ","type":"text"},{"text":"by adding computed properties — you never modify the base class.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"In your code:","type":"text"}],"type":"strong"},{"type":"text","text":" Change behavior by overriding at the container boundary, not by"},{"type":"text","text":" "},{"type":"text","text":"modifying implementation types. A test that needs different behavior provides a"},{"type":"text","text":" "},{"type":"text","text":"different factory:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Correct: extend at the container boundary","try await AuthContainer.shared.withOverrides {","    $0.override(\"authService\") { MockAuthService() }","} run: {","    \/\/ test code...","}","","\/\/ Incorrect: adding test flags inside production types","class AuthService {","    var isTesting = false  \/\/ Don't do this","}"]},{"level":2,"text":"Liskov Substitution Principle","anchor":"Liskov-Substitution-Principle","type":"heading"},{"type":"aside","content":[{"inlineContent":[{"text":"Subtypes must be substitutable for their base types.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"In the framework:","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"type":"text","text":" subclasses are always valid containers. The"},{"text":" ","type":"text"},{"type":"text","text":"base class API works identically on any subclass."}]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"text":" Always declare container properties using protocol return types.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is what makes mocks substitutable for live implementations:"}],"type":"paragraph"},{"code":["\/\/ Correct: protocol return type — mock is substitutable","public var authService: any AuthServiceProtocol {","    provide(.singleton) { AuthService() }","}","","\/\/ Incorrect: concrete type — cannot substitute a mock","public var authService: AuthService {","    provide(.singleton) { AuthService() }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"When the return type is a protocol, any conforming type — live or mock — can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"swapped in without changing consuming code."}],"type":"paragraph"},{"anchor":"Interface-Segregation-Principle","type":"heading","text":"Interface Segregation Principle","level":2},{"content":[{"inlineContent":[{"type":"text","text":"Clients should not depend on interfaces they do not use."}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In the framework:"}],"type":"strong"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer"},{"type":"text","text":" is a minimal protocol with a single"},{"type":"text","text":" "},{"type":"text","text":"requirement ("},{"type":"codeVoice","code":"static var shared"},{"type":"text","text":"). "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" does not conform to it by"},{"type":"text","text":" "},{"type":"text","text":"default — you opt in only when you need the zero-argument "},{"type":"codeVoice","code":"@Inject"},{"text":" syntax.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"In your code:","type":"text"}],"type":"strong"},{"text":" Define narrow protocols for each dependency. A","type":"text"},{"text":" ","type":"text"},{"code":"NetworkClientProtocol","type":"codeVoice"},{"text":" should not carry authentication methods just because the","type":"text"},{"text":" ","type":"text"},{"text":"networking layer also handles auth:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Correct: narrow protocols","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","}","","protocol AuthTokenProviderProtocol {","    var currentToken: String? { get }","}","","\/\/ Incorrect: fat protocol","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","    var currentToken: String? { get }   \/\/ Not a networking concern","    func logout()                        \/\/ Definitely not networking","}"]},{"anchor":"Dependency-Inversion-Principle","type":"heading","text":"Dependency Inversion Principle","level":2},{"name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"High-level modules should not depend on low-level modules. Both should depend"},{"text":" ","type":"text"},{"type":"text","text":"on abstractions."}],"type":"paragraph"}],"type":"aside"},{"inlineContent":[{"inlineContent":[{"text":"This is Forge’s entire purpose.","type":"text"}],"type":"strong"},{"text":" The container is the composition root — the","type":"text"},{"text":" ","type":"text"},{"text":"only place where abstractions are wired to concrete implementations. Everything","type":"text"},{"text":" ","type":"text"},{"text":"above it (ViewModels, services) depends only on protocols. Everything below it","type":"text"},{"text":" ","type":"text"},{"text":"(concrete implementations) knows nothing about the container.","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","Feature modules (depend on protocols, use Forge for wiring)","       ^","       |","App target (imports both, wires at startup)"]},{"inlineContent":[{"type":"text","text":"ViewModels and services never "},{"code":"import","type":"codeVoice"},{"type":"text","text":" a concrete implementation module directly."},{"type":"text","text":" "},{"type":"text","text":"They inject via protocol. The container handles the wiring:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ ViewModel depends only on the protocol","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    \/\/ LoginViewModel has no idea what AuthService is —","    \/\/ it only knows AuthServiceProtocol","}"]},{"level":2,"text":"Summary","type":"heading","anchor":"Summary"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Principle"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Forge Pattern","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Single Responsibility"}],"type":"paragraph"}],[{"inlineContent":[{"text":"One container per module","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Open\/Closed"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Override at the container, don’t modify types"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Liskov Substitution"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Protocol return types on all properties","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Interface Segregation"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Narrow protocols, opt-in ","type":"text"},{"code":"SharedContainer","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Dependency Inversion","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Container is the composition root","type":"text"}],"type":"paragraph"}]]]}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","interfaceLanguage":"swift"},"references":{"doc://Forge/documentation/Forge/ContainerInject":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Container