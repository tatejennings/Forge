{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"metadata":{"modules":[{"name":"Forge"}],"roleHeading":"Article","role":"article","title":"SOLID Principles with Forge"},"abstract":[{"text":"How each SOLID principle maps to Forge usage, with practical Swift examples.","type":"text"}],"seeAlsoSections":[{"anchor":"Architecture-and-Best-Practices","title":"Architecture and Best Practices","identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"generated":true}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"Forge is designed to make SOLID principles the path of least resistance. Each","type":"text"},{"text":" ","type":"text"},{"text":"principle applies to both the framework’s internal design and how you structure","type":"text"},{"text":" ","type":"text"},{"text":"your own code when using it.","type":"text"}],"type":"paragraph"},{"anchor":"Single-Responsibility-Principle","text":"Single Responsibility Principle","level":2,"type":"heading"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"Each type should have one reason to change."}],"type":"paragraph"}],"style":"note","type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"text":" Every Forge type does one thing — ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" manages"},{"type":"text","text":" "},{"type":"text","text":"lifecycle and resolution, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"type":"text","text":" describes caching behavior,"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"type":"text","text":" handles injection, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder"},{"type":"text","text":" handles test"},{"type":"text","text":" "},{"type":"text","text":"configuration."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"text":" Each container should own dependencies for exactly one module.","type":"text"},{"text":" ","type":"text"},{"text":"If a container grows beyond its module’s concerns, that signals the module has","type":"text"},{"text":" ","type":"text"},{"text":"too many responsibilities.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: one container per module","final class AuthContainer: Container, SharedContainer {","    static let shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) { AuthService() }","    }","}","","final class AnalyticsContainer: Container, SharedContainer {","    static let shared = AnalyticsContainer()","","    var tracker: any AnalyticsTrackerProtocol {","        provide(.singleton) { MixpanelTracker() }","    }","}"],"type":"codeListing"},{"level":2,"anchor":"OpenClosed-Principle","text":"Open\/Closed Principle","type":"heading"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open for extension, closed for modification."}]}],"name":"Note","type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" is an "},{"type":"codeVoice","code":"open class"},{"type":"text","text":". New containers extend it"},{"type":"text","text":" "},{"type":"text","text":"by adding computed properties — you never modify the base class."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In your code:"}]},{"type":"text","text":" Change behavior by overriding at the container boundary, not by"},{"type":"text","text":" "},{"type":"text","text":"modifying implementation types. A test that needs different behavior provides a"},{"type":"text","text":" "},{"type":"text","text":"different factory:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: extend at the container boundary","try await AuthContainer.shared.withOverrides {","    $0.override(\\.authService) { MockAuthService() }","} run: {","    \/\/ test code...","}","","\/\/ Incorrect: adding test flags inside production types","class AuthService {","    var isTesting = false  \/\/ Don't do this","}"],"type":"codeListing"},{"level":2,"anchor":"Liskov-Substitution-Principle","text":"Liskov Substitution Principle","type":"heading"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"Subtypes must be substitutable for their base types."}],"type":"paragraph"}],"name":"Note","type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"text":" subclasses are always valid containers. The","type":"text"},{"text":" ","type":"text"},{"text":"base class API works identically on any subclass.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In your code:","type":"text"}]},{"text":" Always declare container properties using protocol return types.","type":"text"},{"text":" ","type":"text"},{"text":"This is what makes mocks substitutable for live implementations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: protocol return type — mock is substitutable","public var authService: any AuthServiceProtocol {","    provide(.singleton) { AuthService() }","}","","\/\/ Incorrect: concrete type — cannot substitute a mock","public var authService: AuthService {","    provide(.singleton) { AuthService() }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"When the return type is a protocol, any conforming type — live or mock — can be"},{"type":"text","text":" "},{"type":"text","text":"swapped in without changing consuming code."}],"type":"paragraph"},{"level":2,"anchor":"Interface-Segregation-Principle","text":"Interface Segregation Principle","type":"heading"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"Clients should not depend on interfaces they do not use."}],"type":"paragraph"}],"name":"Note","type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer"},{"type":"text","text":" is a minimal protocol with a single"},{"type":"text","text":" "},{"type":"text","text":"requirement ("},{"type":"codeVoice","code":"static var shared { get }"},{"type":"text","text":", satisfied by a "},{"type":"codeVoice","code":"static let"},{"type":"text","text":"). "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" does not conform to it by"},{"type":"text","text":" "},{"type":"text","text":"default — you opt in only when you need the zero-argument "},{"type":"codeVoice","code":"@Inject"},{"type":"text","text":" syntax."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In your code:"}]},{"type":"text","text":" Define narrow protocols for each dependency. A"},{"type":"text","text":" "},{"type":"codeVoice","code":"NetworkClientProtocol"},{"type":"text","text":" should not carry authentication methods just because the"},{"type":"text","text":" "},{"type":"text","text":"networking layer also handles auth:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Correct: narrow protocols","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","}","","protocol AuthTokenProviderProtocol {","    var currentToken: String? { get }","}","","\/\/ Incorrect: fat protocol","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","    var currentToken: String? { get }   \/\/ Not a networking concern","    func logout()                        \/\/ Definitely not networking","}"]},{"level":2,"text":"Dependency Inversion Principle","type":"heading","anchor":"Dependency-Inversion-Principle"},{"content":[{"type":"paragraph","inlineContent":[{"text":"High-level modules should not depend on low-level modules. Both should depend","type":"text"},{"text":" ","type":"text"},{"text":"on abstractions.","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"This is Forge’s entire purpose.","type":"text"}]},{"type":"text","text":" The container is the composition root — the"},{"type":"text","text":" "},{"type":"text","text":"only place where abstractions are wired to concrete implementations. Everything"},{"type":"text","text":" "},{"type":"text","text":"above it (ViewModels, services) depends only on protocols. Everything below it"},{"type":"text","text":" "},{"type":"text","text":"(concrete implementations) knows nothing about the container."}]},{"syntax":null,"type":"codeListing","code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","Feature modules (depend on protocols, use Forge for wiring)","       ^","       |","App target (imports both, wires at startup)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"ViewModels and services never "},{"type":"codeVoice","code":"import"},{"type":"text","text":" a concrete implementation module directly."},{"type":"text","text":" "},{"type":"text","text":"They inject via protocol. The container handles the wiring:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ ViewModel depends only on the protocol","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    \/\/ LoginViewModel has no idea what AuthService is —","    \/\/ it only knows AuthServiceProtocol","}"]},{"level":2,"text":"Summary","type":"heading","anchor":"Summary"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Principle"}]}],[{"inlineContent":[{"type":"text","text":"Forge Pattern"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Single Responsibility","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"One container per module"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Open\/Closed"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Override at the container, don’t modify types"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Liskov Substitution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Protocol return types on all properties","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Interface Segregation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Narrow protocols, opt-in ","type":"text"},{"code":"SharedContainer","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Dependency Inversion"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Container is the composition root"}],"type":"paragraph"}]]],"type":"table"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"},"variants":[{"paths":["\/documentation\/forge\/solidprinciples"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","references":{"doc://Forge/documentation/Forge/Scope":{"abstract":[{"text":"Defines the lifecycle of a 