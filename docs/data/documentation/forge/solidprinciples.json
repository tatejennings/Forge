{"metadata":{"modules":[{"name":"Forge"}],"title":"SOLID Principles with Forge","roleHeading":"Article","role":"article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"seeAlsoSections":[{"anchor":"Architecture-and-Best-Practices","title":"Architecture and Best Practices","identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"generated":true}],"abstract":[{"text":"How each SOLID principle maps to Forge usage, with practical Swift examples.","type":"text"}],"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/solidprinciples"]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Forge is designed to make SOLID principles the path of least resistance. Each"},{"type":"text","text":" "},{"type":"text","text":"principle applies to both the framework’s internal design and how you structure"},{"type":"text","text":" "},{"type":"text","text":"your own code when using it."}],"type":"paragraph"},{"anchor":"Single-Responsibility-Principle","level":2,"text":"Single Responsibility Principle","type":"heading"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Each type should have one reason to change.","type":"text"}]}],"type":"aside"},{"inlineContent":[{"inlineContent":[{"text":"In the framework:","type":"text"}],"type":"strong"},{"text":" Every Forge type does one thing — ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"text":" manages","type":"text"},{"text":" ","type":"text"},{"text":"lifecycle and resolution, ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"text":" describes caching behavior,","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"text":" handles injection, ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder"},{"text":" handles test","type":"text"},{"text":" ","type":"text"},{"text":"configuration.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"text":" Each container should own dependencies for exactly one module.","type":"text"},{"text":" ","type":"text"},{"text":"If a container grows beyond its module’s concerns, that signals the module has","type":"text"},{"text":" ","type":"text"},{"text":"too many responsibilities.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: one container per module","final class AuthContainer: Container, SharedContainer {","    static let shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) { AuthService() }","    }","}","","final class AnalyticsContainer: Container, SharedContainer {","    static let shared = AnalyticsContainer()","","    var tracker: any AnalyticsTrackerProtocol {","        provide(.singleton) { MixpanelTracker() }","    }","}"],"type":"codeListing"},{"anchor":"OpenClosed-Principle","level":2,"text":"Open\/Closed Principle","type":"heading"},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Open for extension, closed for modification."}],"type":"paragraph"}],"type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In the framework:","type":"text"}]},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" is an "},{"code":"open class","type":"codeVoice"},{"type":"text","text":". New containers extend it"},{"type":"text","text":" "},{"type":"text","text":"by adding computed properties — you never modify the base class."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"type":"text","text":" Change behavior by overriding at the container boundary, not by"},{"type":"text","text":" "},{"type":"text","text":"modifying implementation types. A test that needs different behavior provides a"},{"type":"text","text":" "},{"type":"text","text":"different factory:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: extend at the container boundary","try await AuthContainer.shared.withOverrides {","    $0.override(\\.authService) { MockAuthService() }","} run: {","    \/\/ test code...","}","","\/\/ Incorrect: adding test flags inside production types","class AuthService {","    var isTesting = false  \/\/ Don't do this","}"],"type":"codeListing"},{"anchor":"Liskov-Substitution-Principle","level":2,"text":"Liskov Substitution Principle","type":"heading"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Subtypes must be substitutable for their base types."}]}],"type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference"},{"type":"text","text":" subclasses are always valid containers. The"},{"type":"text","text":" "},{"type":"text","text":"base class API works identically on any subclass."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In your code:","type":"text"}]},{"type":"text","text":" Always declare container properties using protocol return types."},{"type":"text","text":" "},{"type":"text","text":"This is what makes mocks substitutable for live implementations:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: protocol return type — mock is substitutable","public var authService: any AuthServiceProtocol {","    provide(.singleton) { AuthService() }","}","","\/\/ Incorrect: concrete type — cannot substitute a mock","public var authService: AuthService {","    provide(.singleton) { AuthService() }","}"],"type":"codeListing"},{"inlineContent":[{"text":"When the return type is a protocol, any conforming type — live or mock — can be","type":"text"},{"text":" ","type":"text"},{"text":"swapped in without changing consuming code.","type":"text"}],"type":"paragraph"},{"anchor":"Interface-Segregation-Principle","level":2,"text":"Interface Segregation Principle","type":"heading"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Clients should not depend on interfaces they do not use.","type":"text"}]}],"type":"aside"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In the framework:"}],"type":"strong"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer"},{"text":" is a minimal protocol with a single","type":"text"},{"text":" ","type":"text"},{"text":"requirement (","type":"text"},{"type":"codeVoice","code":"static var shared { get }"},{"text":", satisfied by a ","type":"text"},{"type":"codeVoice","code":"static let"},{"text":"). ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"text":" does not conform to it by","type":"text"},{"text":" ","type":"text"},{"text":"default — you opt in only when you need the zero-argument ","type":"text"},{"type":"codeVoice","code":"@Inject"},{"text":" syntax.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In your code:","type":"text"}]},{"type":"text","text":" Define narrow protocols for each dependency. A"},{"type":"text","text":" "},{"type":"codeVoice","code":"NetworkClientProtocol"},{"type":"text","text":" should not carry authentication methods just because the"},{"type":"text","text":" "},{"type":"text","text":"networking layer also handles auth:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: narrow protocols","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","}","","protocol AuthTokenProviderProtocol {","    var currentToken: String? { get }","}","","\/\/ Incorrect: fat protocol","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","    var currentToken: String? { get }   \/\/ Not a networking concern","    func logout()                        \/\/ Definitely not networking","}"],"type":"codeListing"},{"anchor":"Dependency-Inversion-Principle","level":2,"text":"Dependency Inversion Principle","type":"heading"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"High-level modules should not depend on low-level modules. Both should depend","type":"text"},{"text":" ","type":"text"},{"text":"on abstractions.","type":"text"}]}],"type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"This is Forge’s entire purpose.","type":"text"}]},{"type":"text","text":" The container is the composition root — the"},{"type":"text","text":" "},{"type":"text","text":"only place where abstractions are wired to concrete implementations. Everything"},{"type":"text","text":" "},{"type":"text","text":"above it (ViewModels, services) depends only on protocols. Everything below it"},{"type":"text","text":" "},{"type":"text","text":"(concrete implementations) knows nothing about the container."}],"type":"paragraph"},{"syntax":null,"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","Feature modules (depend on protocols, use Forge for wiring)","       ^","       |","App target (imports both, wires at startup)"],"type":"codeListing"},{"inlineContent":[{"text":"ViewModels and services never ","type":"text"},{"code":"import","type":"codeVoice"},{"text":" a concrete implementation module directly.","type":"text"},{"text":" ","type":"text"},{"text":"They inject via protocol. The container handles the wiring:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ ViewModel depends only on the protocol","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    \/\/ LoginViewModel has no idea what AuthService is —","    \/\/ it only knows AuthServiceProtocol","}"],"type":"codeListing"},{"anchor":"Summary","level":2,"text":"Summary","type":"heading"},{"rows":[[[{"inlineContent":[{"text":"Principle","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Forge Pattern","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Single Responsibility","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"One container per module"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Open\/Closed"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Override at the container, don’t modify types"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Liskov Substitution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Protocol return types on all properties","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Interface Segregation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Narrow protocols, opt-in "},{"type":"codeVoice","code":"SharedContainer"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Dependency Inversion","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Container is the composition root","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"}]}],"sections":[],"references":{"doc://Forge/documentation/Forge/ModularArchitecture":{"kind":"article","role":"article",