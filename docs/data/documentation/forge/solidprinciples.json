{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge is designed to make SOLID principles the path of least resistance. Each"},{"type":"text","text":" "},{"type":"text","text":"principle applies to both the framework’s internal design and how you structure"},{"type":"text","text":" "},{"type":"text","text":"your own code when using it."}]},{"type":"heading","level":2,"text":"Single Responsibility Principle","anchor":"Single-Responsibility-Principle"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each type should have one reason to change."}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"In the framework:","type":"text"}],"type":"strong"},{"text":" Every Forge type does one thing — ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"text":" manages","type":"text"},{"text":" ","type":"text"},{"text":"lifecycle and resolution, ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"text":" describes caching behavior,","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"text":" handles injection, ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder"},{"text":" handles test","type":"text"},{"text":" ","type":"text"},{"text":"configuration.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"In your code:","type":"text"}],"type":"strong"},{"text":" Each container should own dependencies for exactly one module.","type":"text"},{"text":" ","type":"text"},{"text":"If a container grows beyond its module’s concerns, that signals the module has","type":"text"},{"text":" ","type":"text"},{"text":"too many responsibilities.","type":"text"}]},{"syntax":"swift","code":["\/\/ Correct: one container per module","final class AuthContainer: Container, SharedContainer {","    static var shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) { AuthService() }","    }","}","","final class AnalyticsContainer: Container, SharedContainer {","    static var shared = AnalyticsContainer()","","    var tracker: any AnalyticsTrackerProtocol {","        provide(.singleton) { MixpanelTracker() }","    }","}"],"type":"codeListing"},{"type":"heading","level":2,"text":"Open\/Closed Principle","anchor":"OpenClosed-Principle"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Open for extension, closed for modification.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"In the framework:","type":"text"}]},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference","isActive":true},{"type":"text","text":" is an "},{"type":"codeVoice","code":"open class"},{"type":"text","text":". New containers extend it"},{"type":"text","text":" "},{"type":"text","text":"by adding computed properties — you never modify the base class."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"In your code:","type":"text"}]},{"type":"text","text":" Change behavior by overriding at the container boundary, not by"},{"type":"text","text":" "},{"type":"text","text":"modifying implementation types. A test that needs different behavior provides a"},{"type":"text","text":" "},{"type":"text","text":"different factory:"}]},{"syntax":"swift","code":["\/\/ Correct: extend at the container boundary","try await AuthContainer.shared.withOverrides {","    $0.override(\"authService\") { MockAuthService() }","} run: {","    \/\/ test code...","}","","\/\/ Incorrect: adding test flags inside production types","class AuthService {","    var isTesting = false  \/\/ Don't do this","}"],"type":"codeListing"},{"type":"heading","level":2,"text":"Liskov Substitution Principle","anchor":"Liskov-Substitution-Principle"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"Subtypes must be substitutable for their base types.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference","isActive":true},{"type":"text","text":" subclasses are always valid containers. The"},{"type":"text","text":" "},{"type":"text","text":"base class API works identically on any subclass."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"type":"text","text":" Always declare container properties using protocol return types."},{"type":"text","text":" "},{"type":"text","text":"This is what makes mocks substitutable for live implementations:"}]},{"syntax":"swift","code":["\/\/ Correct: protocol return type — mock is substitutable","public var authService: any AuthServiceProtocol {","    provide(.singleton) { AuthService() }","}","","\/\/ Incorrect: concrete type — cannot substitute a mock","public var authService: AuthService {","    provide(.singleton) { AuthService() }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the return type is a protocol, any conforming type — live or mock — can be"},{"type":"text","text":" "},{"type":"text","text":"swapped in without changing consuming code."}]},{"type":"heading","level":2,"text":"Interface Segregation Principle","anchor":"Interface-Segregation-Principle"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Clients should not depend on interfaces they do not use.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In the framework:"}],"type":"strong"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","isActive":true,"type":"reference"},{"text":" is a minimal protocol with a single","type":"text"},{"text":" ","type":"text"},{"text":"requirement (","type":"text"},{"code":"static var shared","type":"codeVoice"},{"text":"). ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true,"type":"reference"},{"text":" does not conform to it by","type":"text"},{"text":" ","type":"text"},{"text":"default — you opt in only when you need the zero-argument ","type":"text"},{"code":"@Inject","type":"codeVoice"},{"text":" syntax.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"In your code:","type":"text"}],"type":"strong"},{"text":" Define narrow protocols for each dependency. A","type":"text"},{"text":" ","type":"text"},{"code":"NetworkClientProtocol","type":"codeVoice"},{"text":" should not carry authentication methods just because the","type":"text"},{"text":" ","type":"text"},{"text":"networking layer also handles auth:","type":"text"}]},{"syntax":"swift","code":["\/\/ Correct: narrow protocols","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","}","","protocol AuthTokenProviderProtocol {","    var currentToken: String? { get }","}","","\/\/ Incorrect: fat protocol","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","    var currentToken: String? { get }   \/\/ Not a networking concern","    func logout()                        \/\/ Definitely not networking","}"],"type":"codeListing"},{"type":"heading","level":2,"text":"Dependency Inversion Principle","anchor":"Dependency-Inversion-Principle"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"High-level modules should not depend on low-level modules. Both should depend","type":"text"},{"text":" ","type":"text"},{"text":"on abstractions.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"This is Forge’s entire purpose.","type":"text"}]},{"text":" The container is the composition root — the","type":"text"},{"text":" ","type":"text"},{"text":"only place where abstractions are wired to concrete implementations. Everything","type":"text"},{"text":" ","type":"text"},{"text":"above it (ViewModels, services) depends only on protocols. Everything below it","type":"text"},{"text":" ","type":"text"},{"text":"(concrete implementations) knows nothing about the container.","type":"text"}]},{"syntax":null,"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","Feature modules (depend on protocols, use Forge for wiring)","       ^","       |","App target (imports both, wires at startup)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"ViewModels and services never ","type":"text"},{"type":"codeVoice","code":"import"},{"text":" a concrete implementation module directly.","type":"text"},{"text":" ","type":"text"},{"text":"They inject via protocol. The container handles the wiring:","type":"text"}]},{"syntax":"swift","code":["\/\/ ViewModel depends only on the protocol","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    \/\/ LoginViewModel has no idea what AuthService is —","    \/\/ it only knows AuthServiceProtocol","}"],"type":"codeListing"},{"type":"heading","level":2,"text":"Summary","anchor":"Summary"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Principle"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge Pattern"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Single Responsibility"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"One container per module"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Open\/Closed","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Override at the container, don’t modify types"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Liskov Substitution"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Protocol return types on all properties"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Interface Segregation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Narrow protocols, opt-in "},{"type":"codeVoice","code":"SharedContainer"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dependency Inversion"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Container is the composition root"}]}]]],"header":"row"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"},"metadata":{"modules":[{"name":"Forge"}],"role":"article","title":"SOLID Principles with Forge","roleHeading":"Article"},"seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"generated":true,"title":"Architecture and Best Practices","anchor":"Architecture-and-Best-Practices"}],"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"abstract":[{"type":"text","text":"How each SOLID principle maps to Forge usage, with practical Swift examples."}],"variants":[{"paths":["\/documentation\/forge\/solidprinciples"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"references":{"doc://Forge/documentation/Forge/Container":{"type":"topic","url":"\/documentation\/forge\/container","navigatorTitle":[{"text":"Container","kind":"identifier"}],"role":"symbol","a