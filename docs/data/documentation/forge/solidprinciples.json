{"metadata":{"title":"SOLID Principles with Forge","roleHeading":"Article","role":"article","modules":[{"name":"Forge"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge is designed to make SOLID principles the path of least resistance. Each"},{"type":"text","text":" "},{"type":"text","text":"principle applies to both the framework’s internal design and how you structure"},{"type":"text","text":" "},{"type":"text","text":"your own code when using it."}]},{"level":2,"type":"heading","anchor":"Single-Responsibility-Principle","text":"Single Responsibility Principle"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each type should have one reason to change."}]}],"type":"aside"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"In the framework:","type":"text"}],"type":"strong"},{"type":"text","text":" Every Forge type does one thing — "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference","isActive":true},{"type":"text","text":" manages"},{"type":"text","text":" "},{"type":"text","text":"lifecycle and resolution, "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","type":"reference","isActive":true},{"type":"text","text":" describes caching behavior,"},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","type":"reference","isActive":true},{"type":"text","text":" handles injection, "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","type":"reference","isActive":true},{"type":"text","text":" handles test"},{"type":"text","text":" "},{"type":"text","text":"configuration."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"In your code:","type":"text"}],"type":"strong"},{"type":"text","text":" Each container should own dependencies for exactly one module."},{"type":"text","text":" "},{"type":"text","text":"If a container grows beyond its module’s concerns, that signals the module has"},{"type":"text","text":" "},{"type":"text","text":"too many responsibilities."}]},{"type":"codeListing","code":["\/\/ Correct: one container per module","final class AuthContainer: Container, SharedContainer {","    static var shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) { AuthService() }","    }","}","","final class AnalyticsContainer: Container, SharedContainer {","    static var shared = AnalyticsContainer()","","    var tracker: any AnalyticsTrackerProtocol {","        provide(.singleton) { MixpanelTracker() }","    }","}"],"syntax":"swift"},{"level":2,"type":"heading","anchor":"OpenClosed-Principle","text":"Open\/Closed Principle"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open for extension, closed for modification."}]}],"type":"aside"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"In the framework:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" is an "},{"code":"open class","type":"codeVoice"},{"type":"text","text":". New containers extend it"},{"type":"text","text":" "},{"type":"text","text":"by adding computed properties — you never modify the base class."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In your code:"}]},{"type":"text","text":" Change behavior by overriding at the container boundary, not by"},{"type":"text","text":" "},{"type":"text","text":"modifying implementation types. A test that needs different behavior provides a"},{"type":"text","text":" "},{"type":"text","text":"different factory:"}]},{"type":"codeListing","code":["\/\/ Correct: extend at the container boundary","try await AuthContainer.shared.withOverrides {","    $0.override(\\.authService) { MockAuthService() }","} run: {","    \/\/ test code...","}","","\/\/ Incorrect: adding test flags inside production types","class AuthService {","    var isTesting = false  \/\/ Don't do this","}"],"syntax":"swift"},{"level":2,"type":"heading","anchor":"Liskov-Substitution-Principle","text":"Liskov Substitution Principle"},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"Subtypes must be substitutable for their base types.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In the framework:"}],"type":"strong"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true,"type":"reference"},{"text":" subclasses are always valid containers. The","type":"text"},{"text":" ","type":"text"},{"text":"base class API works identically on any subclass.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"text":" Always declare container properties using protocol return types.","type":"text"},{"text":" ","type":"text"},{"text":"This is what makes mocks substitutable for live implementations:","type":"text"}]},{"type":"codeListing","code":["\/\/ Correct: protocol return type — mock is substitutable","public var authService: any AuthServiceProtocol {","    provide(.singleton) { AuthService() }","}","","\/\/ Incorrect: concrete type — cannot substitute a mock","public var authService: AuthService {","    provide(.singleton) { AuthService() }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the return type is a protocol, any conforming type — live or mock — can be"},{"type":"text","text":" "},{"type":"text","text":"swapped in without changing consuming code."}]},{"level":2,"type":"heading","anchor":"Interface-Segregation-Principle","text":"Interface Segregation Principle"},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"Clients should not depend on interfaces they do not use.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer"},{"type":"text","text":" is a minimal protocol with a single"},{"type":"text","text":" "},{"type":"text","text":"requirement ("},{"type":"codeVoice","code":"static var shared"},{"type":"text","text":"). "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" does not conform to it by"},{"type":"text","text":" "},{"type":"text","text":"default — you opt in only when you need the zero-argument "},{"type":"codeVoice","code":"@Inject"},{"type":"text","text":" syntax."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In your code:"}]},{"type":"text","text":" Define narrow protocols for each dependency. A"},{"type":"text","text":" "},{"type":"codeVoice","code":"NetworkClientProtocol"},{"type":"text","text":" should not carry authentication methods just because the"},{"type":"text","text":" "},{"type":"text","text":"networking layer also handles auth:"}]},{"type":"codeListing","code":["\/\/ Correct: narrow protocols","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","}","","protocol AuthTokenProviderProtocol {","    var currentToken: String? { get }","}","","\/\/ Incorrect: fat protocol","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","    var currentToken: String? { get }   \/\/ Not a networking concern","    func logout()                        \/\/ Definitely not networking","}"],"syntax":"swift"},{"level":2,"type":"heading","anchor":"Dependency-Inversion-Principle","text":"Dependency Inversion Principle"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"High-level modules should not depend on low-level modules. Both should depend"},{"type":"text","text":" "},{"type":"text","text":"on abstractions."}]}],"type":"aside"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"This is Forge’s entire purpose.","type":"text"}]},{"text":" The container is the composition root — the","type":"text"},{"text":" ","type":"text"},{"text":"only place where abstractions are wired to concrete implementations. Everything","type":"text"},{"text":" ","type":"text"},{"text":"above it (ViewModels, services) depends only on protocols. Everything below it","type":"text"},{"text":" ","type":"text"},{"text":"(concrete implementations) knows nothing about the container.","type":"text"}]},{"type":"codeListing","code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","Feature modules (depend on protocols, use Forge for wiring)","       ^","       |","App target (imports both, wires at startup)"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"ViewModels and services never "},{"type":"codeVoice","code":"import"},{"type":"text","text":" a concrete implementation module directly."},{"type":"text","text":" "},{"type":"text","text":"They inject via protocol. The container handles the wiring:"}]},{"type":"codeListing","code":["\/\/ ViewModel depends only on the protocol","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    \/\/ LoginViewModel has no idea what AuthService is —","    \/\/ it only knows AuthServiceProtocol","}"],"syntax":"swift"},{"level":2,"type":"heading","anchor":"Summary","text":"Summary"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Principle","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Forge Pattern"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Single Responsibility","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"One container per module"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Open\/Closed"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Override at the container, don’t modify types","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Liskov Substitution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Protocol return types on all properties","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Interface Segregation"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Narrow protocols, opt-in ","type":"text"},{"code":"SharedContainer","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Dependency Inversion"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Container is the composition root","type":"text"}],"type":"paragraph"}]]]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/forge\/solidprinciples"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","abstract":[{"type":"text","text":"How each SOLID principle maps to Forge usage, with practical Swift examples."}],"seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"title":"Architecture and Best Practices","generated":true,"anchor":"Architecture-and-Best-Practices"}],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","interfaceLanguage":"swift"},"sections":[],"references":{"doc://Forge/documentation/Forge/Container":{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","kind":"symbol","type":"topic","abstract":[{"text":"The base class for all dependency containers in Forge.","type":"text"}],"navigatorTitle":[{"text":"Container","kind":"identifier"}],"title":"Container","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Container","kind":"identifier"}],"url":"\/documentation\/forge\/container","role":"symbol"},"doc://Forge/documentation/Forge/XcodePreviewSupport":{"type":"topic","title":"Xcode Preview Support","abstract":[{"type":"text","text":"Provide preview-safe mock factories that activate automatically in Xcode Previews."}],"role":"article","identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","kind":"article","url":"\/documentation\/forge\/xcodepreviewsupport"},"doc://Forge/documentation/Forge/ContainerInject":{"navigatorTitle":[{"text":"ContainerInject","kind":"identifier"}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","url":"\/documentation\/forge\/containerinject","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ContainerInject","kind":"identifier"}],"type":"topic","title":"ContainerInject","abstract":[{"type":"text","text":"A property wrapper that lazily resolves a dependency from a "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference","isActive":true},{"type":"text","text":"."}]},"doc://Forge/documentation/Forge/SharedContainer":{"navigatorTitle":[{"text":"SharedContainer","kind":"identifier"}],"url":"\/documentation\/forge\/sharedcontainer","kind":"symbol","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","role":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SharedContainer","kind":"identifier"}],"abstract":[{"type":"text","text":"A container that provides a shared static instance for convenient access."}],"title":"SharedContainer"},"doc://Forge/documentation/Forge/OverrideBuilder":{"kind":"symbol","url":"\/documentation\/forge\/overridebuilder","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OverrideBuilder","kind":"identifier"}],"title":"OverrideBuilder","role":"symbol","navigatorTitle":[{"text":"OverrideBuilder","kind":"identifier"}],"abstract":[{"type":"text","text":"Accumulates override registrations for use with "},{"type":"codeVoice","code":"Container\/withOverrides(_:run:)-3qdpl"},{"type":"text","text":"."}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder"},"doc://Forge/documentation/Forge":{"url":"\/documentation\/forge","identifier":"doc:\/\/Forge\/documentation\/Forge","kind":"symbol","abstract":[{"text":"A lightweight, compile-time safe dependency injection framework for Swift.","type":"text"}],"role":"collection","type":"topic","title":"Forge"},"doc://Forge/documentation/Forge/ModularArchitecture":{"type":"topic","url":"\/documentation\/forge\/modulararchitecture","kind":"article","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","title":"Modular Architecture","role":"article","abstract":[{"text":"Organize dependency injection across multiple Swift Package Manager modules.","type":"text"}]},"doc://Forge/documentation/Forge/Scope":{"kind":"symbol","abstract":[{"type":"text","text":"Defines the lifecycle of a dependency managed by a "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Scope"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Scope"}],"title":"Scope","type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","url":"\/documentation\/forge\/scope"}}}