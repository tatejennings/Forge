{"abstract":[{"text":"How each SOLID principle maps to Forge usage, with practical Swift examples.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"variants":[{"paths":["\/documentation\/forge\/solidprinciples"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"},"sections":[],"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"Forge"}],"title":"SOLID Principles with Forge"},"seeAlsoSections":[{"title":"Architecture and Best Practices","generated":true,"anchor":"Architecture-and-Best-Practices","identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"]}],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge is designed to make SOLID principles the path of least resistance. Each"},{"type":"text","text":" "},{"type":"text","text":"principle applies to both the framework’s internal design and how you structure"},{"type":"text","text":" "},{"type":"text","text":"your own code when using it."}]},{"anchor":"Single-Responsibility-Principle","type":"heading","text":"Single Responsibility Principle","level":2},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each type should have one reason to change."}]}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" Every Forge type does one thing — "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference","isActive":true},{"type":"text","text":" manages"},{"type":"text","text":" "},{"type":"text","text":"lifecycle and resolution, "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","type":"reference","isActive":true},{"type":"text","text":" describes caching behavior,"},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","type":"reference","isActive":true},{"type":"text","text":" handles injection, "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","isActive":true,"type":"reference"},{"text":" handles test","type":"text"},{"text":" ","type":"text"},{"text":"configuration.","type":"text"}]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"text":" Each container should own dependencies for exactly one module.","type":"text"},{"text":" ","type":"text"},{"text":"If a container grows beyond its module’s concerns, that signals the module has","type":"text"},{"text":" ","type":"text"},{"text":"too many responsibilities.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Correct: one container per module","final class AuthContainer: Container, SharedContainer {","    static var shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) { AuthService() }","    }","}","","final class AnalyticsContainer: Container, SharedContainer {","    static var shared = AnalyticsContainer()","","    var tracker: any AnalyticsTrackerProtocol {","        provide(.singleton) { MixpanelTracker() }","    }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"OpenClosed-Principle","text":"Open\/Closed Principle","type":"heading"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open for extension, closed for modification."}]}],"name":"Note","style":"note","type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In the framework:","type":"text"}]},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" is an "},{"type":"codeVoice","code":"open class"},{"type":"text","text":". New containers extend it"},{"type":"text","text":" "},{"type":"text","text":"by adding computed properties — you never modify the base class."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In your code:"}]},{"type":"text","text":" Change behavior by overriding at the container boundary, not by"},{"type":"text","text":" "},{"type":"text","text":"modifying implementation types. A test that needs different behavior provides a"},{"type":"text","text":" "},{"type":"text","text":"different factory:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: extend at the container boundary","try await AuthContainer.shared.withOverrides {","    $0.override(\"authService\") { MockAuthService() }","} run: {","    \/\/ test code...","}","","\/\/ Incorrect: adding test flags inside production types","class AuthService {","    var isTesting = false  \/\/ Don't do this","}"],"type":"codeListing"},{"text":"Liskov Substitution Principle","level":2,"anchor":"Liskov-Substitution-Principle","type":"heading"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Subtypes must be substitutable for their base types."}]}],"type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In the framework:","type":"text"}]},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" subclasses are always valid containers. The"},{"type":"text","text":" "},{"type":"text","text":"base class API works identically on any subclass."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In your code:"}]},{"text":" Always declare container properties using protocol return types.","type":"text"},{"text":" ","type":"text"},{"text":"This is what makes mocks substitutable for live implementations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: protocol return type — mock is substitutable","public var authService: any AuthServiceProtocol {","    provide(.singleton) { AuthService() }","}","","\/\/ Incorrect: concrete type — cannot substitute a mock","public var authService: AuthService {","    provide(.singleton) { AuthService() }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"When the return type is a protocol, any conforming type — live or mock — can be"},{"type":"text","text":" "},{"type":"text","text":"swapped in without changing consuming code."}],"type":"paragraph"},{"text":"Interface Segregation Principle","level":2,"anchor":"Interface-Segregation-Principle","type":"heading"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Clients should not depend on interfaces they do not use.","type":"text"}]}],"type":"aside"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","type":"reference","isActive":true},{"type":"text","text":" is a minimal protocol with a single"},{"type":"text","text":" "},{"type":"text","text":"requirement ("},{"code":"static var shared","type":"codeVoice"},{"type":"text","text":"). "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"text":" does not conform to it by","type":"text"},{"text":" ","type":"text"},{"text":"default — you opt in only when you need the zero-argument ","type":"text"},{"type":"codeVoice","code":"@Inject"},{"text":" syntax.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In your code:"}]},{"text":" Define narrow protocols for each dependency. A","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NetworkClientProtocol"},{"type":"text","text":" should not carry authentication methods just because the"},{"type":"text","text":" "},{"type":"text","text":"networking layer also handles auth:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Correct: narrow protocols","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","}","","protocol AuthTokenProviderProtocol {","    var currentToken: String? { get }","}","","\/\/ Incorrect: fat protocol","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","    var currentToken: String? { get }   \/\/ Not a networking concern","    func logout()                        \/\/ Definitely not networking","}"]},{"text":"Dependency Inversion Principle","type":"heading","anchor":"Dependency-Inversion-Principle","level":2},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"High-level modules should not depend on low-level modules. Both should depend"},{"type":"text","text":" "},{"type":"text","text":"on abstractions."}]}],"type":"aside","name":"Note"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"This is Forge’s entire purpose."}],"type":"strong"},{"text":" The container is the composition root — the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"only place where abstractions are wired to concrete implementations. Everything"},{"type":"text","text":" "},{"text":"above it (ViewModels, services) depends only on protocols. Everything below it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(concrete implementations) knows nothing about the container."}],"type":"paragraph"},{"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","Feature modules (depend on protocols, use Forge for wiring)","       ^","       |","App target (imports both, wires at startup)"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"ViewModels and services never ","type":"text"},{"type":"codeVoice","code":"import"},{"text":" a concrete implementation module directly.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"They inject via protocol. The container handles the wiring:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ ViewModel depends only on the protocol","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    \/\/ LoginViewModel has no idea what AuthService is —","    \/\/ it only knows AuthServiceProtocol","}"],"type":"codeListing"},{"text":"Summary","type":"heading","anchor":"Summary","level":2},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Principle","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Forge Pattern","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Single Responsibility"}]}],[{"inlineContent":[{"type":"text","text":"One container per module"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Open\/Closed","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Override at the container, don’t modify types"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Liskov Substitution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Protocol return types on all properties","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Interface Segregation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Narrow protocols, opt-in "},{"code":"SharedContainer","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Dependency Inversion","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Container is the composition root","type":"text"}],"type":"paragraph"}]]],"type":"table"}],"kind":"content"}],"references":{"doc://Forge/documentation/Forge/Container":{"kind":"symbol","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","abstract":[{"type":"text","text":"The base class for all dependency containers in Forge."}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Container"}],"url":"\/documentation\/forge\/container","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Container"}],"title":"Container"},"doc://Forge/documentation/Forge":{"type":"topic","abstract":[{"type":"text","text":"A lightweight, compile-time safe dependency injection framework for Swift."}],"kind":"symbol","url":"\/documentation\/forge","identifier":"doc:\/\/Forge\/documentation\/Forge","title":"Forge","role":"collection"},"doc://Forge/documentation/Forge/XcodePreviewSupport":{"title":"Xcode Preview Support","identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","url":"\/documentation\/forge\/xcodepreviewsupport","type":"topic","kind":"article","abstract":[{"text":"Provide preview-safe mock factories that activate automatically in Xcode Previews.","type":"text"}],"role":"article"},"doc://Forge/documentation/Forge/Container/withOverrides(_:run:)-3qdpl":{"title":"withOverrides(_:run:)","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container\/withOverrides(_:run:)-3qdpl","url":"\/documentation\/forge\/container\/withoverrides(_:run:)-3qdpl","type":"topic","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withOverrides","kind":"identifier"},{"kind":"text","text":"(("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:5Forge15OverrideBuilderV","text":"OverrideBuilder"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"text":", ","kind":"text"},{"text":"run","kind":"externalParam"},{"text":": () ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":") "},{"text":"rethrows","kind":"keyword"}],"abstr