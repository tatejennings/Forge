{"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"sections":[],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"Forge is designed to make SOLID principles the path of least resistance. Each"},{"type":"text","text":" "},{"type":"text","text":"principle applies to both the framework’s internal design and how you structure"},{"type":"text","text":" "},{"type":"text","text":"your own code when using it."}],"type":"paragraph"},{"anchor":"Single-Responsibility-Principle","level":2,"type":"heading","text":"Single Responsibility Principle"},{"style":"note","content":[{"inlineContent":[{"text":"Each type should have one reason to change.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In the framework:"}],"type":"strong"},{"type":"text","text":" Every Forge type does one thing — "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" manages"},{"type":"text","text":" "},{"type":"text","text":"lifecycle and resolution, "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"type":"text","text":" describes caching behavior,"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"type":"text","text":" handles injection, "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder"},{"type":"text","text":" handles test"},{"type":"text","text":" "},{"type":"text","text":"configuration."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In your code:","type":"text"}]},{"text":" Each container should own dependencies for exactly one module.","type":"text"},{"text":" ","type":"text"},{"text":"If a container grows beyond its module’s concerns, that signals the module has","type":"text"},{"text":" ","type":"text"},{"text":"too many responsibilities.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: one container per module","final class AuthContainer: Container, SharedContainer {","    static let shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) { AuthService() }","    }","}","","final class AnalyticsContainer: Container, SharedContainer {","    static let shared = AnalyticsContainer()","","    var tracker: any AnalyticsTrackerProtocol {","        provide(.singleton) { MixpanelTracker() }","    }","}"],"type":"codeListing"},{"anchor":"OpenClosed-Principle","level":2,"type":"heading","text":"Open\/Closed Principle"},{"style":"note","content":[{"inlineContent":[{"text":"Open for extension, closed for modification.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In the framework:","type":"text"}]},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true,"type":"reference"},{"text":" is an ","type":"text"},{"type":"codeVoice","code":"open class"},{"text":". New containers extend it","type":"text"},{"text":" ","type":"text"},{"text":"by adding computed properties — you never modify the base class.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"type":"text","text":" Change behavior by overriding at the container boundary, not by"},{"type":"text","text":" "},{"type":"text","text":"modifying implementation types. A test that needs different behavior provides a"},{"type":"text","text":" "},{"type":"text","text":"different factory:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: extend at the container boundary","try await AuthContainer.shared.withOverrides {","    $0.override(\\.authService) { MockAuthService() }","} run: {","    \/\/ test code...","}","","\/\/ Incorrect: adding test flags inside production types","class AuthService {","    var isTesting = false  \/\/ Don't do this","}"],"type":"codeListing"},{"anchor":"Liskov-Substitution-Principle","level":2,"type":"heading","text":"Liskov Substitution Principle"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Subtypes must be substitutable for their base types.","type":"text"}]}],"type":"aside","name":"Note"},{"inlineContent":[{"inlineContent":[{"text":"In the framework:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference","isActive":true},{"type":"text","text":" subclasses are always valid containers. The"},{"type":"text","text":" "},{"type":"text","text":"base class API works identically on any subclass."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"text":" Always declare container properties using protocol return types.","type":"text"},{"text":" ","type":"text"},{"text":"This is what makes mocks substitutable for live implementations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: protocol return type — mock is substitutable","public var authService: any AuthServiceProtocol {","    provide(.singleton) { AuthService() }","}","","\/\/ Incorrect: concrete type — cannot substitute a mock","public var authService: AuthService {","    provide(.singleton) { AuthService() }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"When the return type is a protocol, any conforming type — live or mock — can be"},{"type":"text","text":" "},{"type":"text","text":"swapped in without changing consuming code."}],"type":"paragraph"},{"anchor":"Interface-Segregation-Principle","level":2,"type":"heading","text":"Interface Segregation Principle"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Clients should not depend on interfaces they do not use."}]}],"type":"aside","name":"Note"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","isActive":true},{"type":"text","text":" is a minimal protocol with a single"},{"type":"text","text":" "},{"type":"text","text":"requirement ("},{"type":"codeVoice","code":"static var shared { get }"},{"type":"text","text":", satisfied by a "},{"type":"codeVoice","code":"static let"},{"type":"text","text":"). "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"type":"text","text":" does not conform to it by"},{"type":"text","text":" "},{"type":"text","text":"default — you opt in only when you need the zero-argument "},{"type":"codeVoice","code":"@Inject"},{"type":"text","text":" syntax."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In your code:"}]},{"type":"text","text":" Define narrow protocols for each dependency. A"},{"type":"text","text":" "},{"code":"NetworkClientProtocol","type":"codeVoice"},{"type":"text","text":" should not carry authentication methods just because the"},{"type":"text","text":" "},{"type":"text","text":"networking layer also handles auth:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Correct: narrow protocols","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","}","","protocol AuthTokenProviderProtocol {","    var currentToken: String? { get }","}","","\/\/ Incorrect: fat protocol","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","    var currentToken: String? { get }   \/\/ Not a networking concern","    func logout()                        \/\/ Definitely not networking","}"],"type":"codeListing"},{"anchor":"Dependency-Inversion-Principle","level":2,"type":"heading","text":"Dependency Inversion Principle"},{"style":"note","content":[{"inlineContent":[{"text":"High-level modules should not depend on low-level modules. Both should depend","type":"text"},{"text":" ","type":"text"},{"text":"on abstractions.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"This is Forge’s entire purpose."}]},{"type":"text","text":" The container is the composition root — the"},{"type":"text","text":" "},{"type":"text","text":"only place where abstractions are wired to concrete implementations. Everything"},{"type":"text","text":" "},{"type":"text","text":"above it (ViewModels, services) depends only on protocols. Everything below it"},{"type":"text","text":" "},{"type":"text","text":"(concrete implementations) knows nothing about the container."}],"type":"paragraph"},{"syntax":null,"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","Feature modules (depend on protocols, use Forge for wiring)","       ^","       |","App target (imports both, wires at startup)"],"type":"codeListing"},{"inlineContent":[{"text":"ViewModels and services never ","type":"text"},{"code":"import","type":"codeVoice"},{"text":" a concrete implementation module directly.","type":"text"},{"text":" ","type":"text"},{"text":"They inject via protocol. The container handles the wiring:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ ViewModel depends only on the protocol","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    \/\/ LoginViewModel has no idea what AuthService is —","    \/\/ it only knows AuthServiceProtocol","}"],"type":"codeListing"},{"anchor":"Summary","level":2,"type":"heading","text":"Summary"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Principle","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge Pattern"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Single Responsibility","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"One container per module"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open\/Closed"}]}],[{"type":"paragraph","inlineContent":[{"text":"Override at the container, don’t modify types","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Liskov Substitution"}]}],[{"type":"paragraph","inlineContent":[{"text":"Protocol return types on all properties","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Interface Segregation"}]}],[{"type":"paragraph","inlineContent":[{"text":"Narrow protocols, opt-in ","type":"text"},{"type":"codeVoice","code":"SharedContainer"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dependency Inversion"}]}],[{"type":"paragraph","inlineContent":[{"text":"Container is the composition root","type":"text"}]}]]]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/forge\/solidprinciples"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Article","modules":[{"name":"Forge"}],"title":"SOLID Principles with Forge","role":"article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"},"abstract":[{"text":"How each SOLID principle maps to Forge usage, with practical Swift examples.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","seeAlsoSections":[{"anchor":"Architecture-and-Best-Practices","title":"Architecture and Best Practices","generated":true,"identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"]}],"references":{"doc://Forge/documentation/Forge/SharedContainer":{"title":"SharedContainer","url":"\/documentation\/forge\/sharedcontainer","kind":"symbol","abstract":[{"text":"A container that provides a shared static instance for convenient access.","type":"text"}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SharedContainer"}],"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedContainer"}]},"doc://Forge/documentation/Forge/ModularArchitecture":{"abstract":[{"text":"Organize dependency injection across multiple Swift Package Manager modules.","type":"text"}],"type":"topic","kind":"article","url":"\/documentation\/forge\/modulararchitecture","identifier":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","role":"article","title":"Modular Architecture"},"doc://Forge/documentation/Forge":{"kind":"symbol","abstract":[{"text":"A lightweight dependency injection framework for Swift — compile-time-safe at the call site, with loud, fail-fast runtime checks underneath.","type":"text"}],"type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge","title":"Forge","role":"collection","url":"\/documentation\/forge"},"doc://Forge/documentation/Forge/Container":{"title":"Container","role":"symbol","navigatorTitle":[{"text":"Container","kind":"identifier"}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Container","kind":"identifier"}],"type":"topic","url":"\/documentation\/forge\/container","abstract":[{"text":"The base class for all dependency containers in Forge.","type":"text"}]},"doc://Forge/documentation/Forge/OverrideBuilder":{"title":"OverrideBuilder","role":"symbol","identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","url":"\/documentation\/forge\/overridebuilder","abstract":[{"text":"Accumulates override registrations for use with ","type":"text"},{"code":"Container\/withOverrides(_:run:)-3qdpl","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","navigatorTitle":[{"text":"OverrideBuilder","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OverrideBuilder","kind":"identifier"}]},"doc://Forge/documentation/Forge/Scope":{"role":"symbol","abstract":[{"type":"text","text":"Defines the lifecycle of a dependency managed by a "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"type":"text","text":"."}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Scope"}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope","navigatorTitle":[{"kind":"identifier","text":"Scope"}],"title":"Scope","url":"\/documentation\/forge\/scope"},"doc://Forge/documentation/Forge/ContainerInject":{"title":"ContainerInject","role":"symbol","type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ContainerInject"}],"url":"\/documentation\/forge\/containerinject","kind":"symbol","abstract":[{"text":"A property wrapper that lazily resolves a dependency from a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference"},{"text":".","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"ContainerInject"}]},"doc://Forge/documentation/Forge/XcodePreviewSupport":{"title":"Xcode Preview Support","kind":"article","type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","url":"\/documentation\/forge\/xcodepreviewsupport","abstract":[{"text":"Provide preview-safe mock factories that activate automatically in Xcode Previews.","type":"text"}],"role":"article"}}}