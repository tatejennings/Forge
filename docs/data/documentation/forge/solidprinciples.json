{"kind":"article","hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"abstract":[{"text":"How each SOLID principle maps to Forge usage, with practical Swift examples.","type":"text"}],"seeAlsoSections":[{"anchor":"Architecture-and-Best-Practices","generated":true,"title":"Architecture and Best Practices","identifiers":["doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Forge is designed to make SOLID principles the path of least resistance. Each","type":"text"},{"text":" ","type":"text"},{"text":"principle applies to both the framework’s internal design and how you structure","type":"text"},{"text":" ","type":"text"},{"text":"your own code when using it.","type":"text"}]},{"level":2,"type":"heading","anchor":"Single-Responsibility-Principle","text":"Single Responsibility Principle"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"Each type should have one reason to change.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"In the framework:","type":"text"}]},{"text":" Every Forge type does one thing — ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true,"type":"reference"},{"type":"text","text":" manages"},{"type":"text","text":" "},{"type":"text","text":"lifecycle and resolution, "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Scope"},{"text":" describes caching behavior,","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"text":" handles injection, ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverrideBuilder","isActive":true,"type":"reference"},{"text":" handles test","type":"text"},{"text":" ","type":"text"},{"text":"configuration.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"In your code:","type":"text"}]},{"type":"text","text":" Each container should own dependencies for exactly one module."},{"type":"text","text":" "},{"type":"text","text":"If a container grows beyond its module’s concerns, that signals the module has"},{"type":"text","text":" "},{"type":"text","text":"too many responsibilities."}]},{"type":"codeListing","code":["\/\/ Correct: one container per module","final class AuthContainer: Container, SharedContainer {","    static var shared = AuthContainer()","","    var authService: any AuthServiceProtocol {","        provide(.singleton) { AuthService() }","    }","}","","final class AnalyticsContainer: Container, SharedContainer {","    static var shared = AnalyticsContainer()","","    var tracker: any AnalyticsTrackerProtocol {","        provide(.singleton) { MixpanelTracker() }","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"OpenClosed-Principle","text":"Open\/Closed Principle","level":2},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Open for extension, closed for modification."}],"type":"paragraph"}],"name":"Note"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In the framework:"}],"type":"strong"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" is an "},{"code":"open class","type":"codeVoice"},{"type":"text","text":". New containers extend it"},{"type":"text","text":" "},{"type":"text","text":"by adding computed properties — you never modify the base class."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"type":"text","text":" Change behavior by overriding at the container boundary, not by"},{"type":"text","text":" "},{"type":"text","text":"modifying implementation types. A test that needs different behavior provides a"},{"type":"text","text":" "},{"type":"text","text":"different factory:"}]},{"type":"codeListing","code":["\/\/ Correct: extend at the container boundary","try await AuthContainer.shared.withOverrides {","    $0.override(\"authService\") { MockAuthService() }","} run: {","    \/\/ test code...","}","","\/\/ Incorrect: adding test flags inside production types","class AuthService {","    var isTesting = false  \/\/ Don't do this","}"],"syntax":"swift"},{"type":"heading","anchor":"Liskov-Substitution-Principle","text":"Liskov Substitution Principle","level":2},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Subtypes must be substitutable for their base types."}]}],"name":"Note"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true,"type":"reference"},{"text":" subclasses are always valid containers. The","type":"text"},{"text":" ","type":"text"},{"text":"base class API works identically on any subclass.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"In your code:","type":"text"}]},{"text":" Always declare container properties using protocol return types.","type":"text"},{"text":" ","type":"text"},{"text":"This is what makes mocks substitutable for live implementations:","type":"text"}]},{"type":"codeListing","code":["\/\/ Correct: protocol return type — mock is substitutable","public var authService: any AuthServiceProtocol {","    provide(.singleton) { AuthService() }","}","","\/\/ Incorrect: concrete type — cannot substitute a mock","public var authService: AuthService {","    provide(.singleton) { AuthService() }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"When the return type is a protocol, any conforming type — live or mock — can be","type":"text"},{"text":" ","type":"text"},{"text":"swapped in without changing consuming code.","type":"text"}]},{"type":"heading","anchor":"Interface-Segregation-Principle","text":"Interface Segregation Principle","level":2},{"content":[{"type":"paragraph","inlineContent":[{"text":"Clients should not depend on interfaces they do not use.","type":"text"}]}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In the framework:"}]},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/SharedContainer","isActive":true},{"type":"text","text":" is a minimal protocol with a single"},{"type":"text","text":" "},{"type":"text","text":"requirement ("},{"type":"codeVoice","code":"static var shared"},{"type":"text","text":"). "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" does not conform to it by"},{"type":"text","text":" "},{"text":"default — you opt in only when you need the zero-argument ","type":"text"},{"type":"codeVoice","code":"@Inject"},{"type":"text","text":" syntax."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In your code:"}],"type":"strong"},{"type":"text","text":" Define narrow protocols for each dependency. A"},{"type":"text","text":" "},{"type":"codeVoice","code":"NetworkClientProtocol"},{"type":"text","text":" should not carry authentication methods just because the"},{"type":"text","text":" "},{"type":"text","text":"networking layer also handles auth:"}]},{"type":"codeListing","code":["\/\/ Correct: narrow protocols","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","}","","protocol AuthTokenProviderProtocol {","    var currentToken: String? { get }","}","","\/\/ Incorrect: fat protocol","protocol NetworkClientProtocol {","    func request<T: Decodable>(_ endpoint: Endpoint) async throws -> T","    var currentToken: String? { get }   \/\/ Not a networking concern","    func logout()                        \/\/ Definitely not networking","}"],"syntax":"swift"},{"text":"Dependency Inversion Principle","anchor":"Dependency-Inversion-Principle","type":"heading","level":2},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"High-level modules should not depend on low-level modules. Both should depend","type":"text"},{"text":" ","type":"text"},{"text":"on abstractions.","type":"text"}]}],"name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"This is Forge’s entire purpose.","type":"text"}]},{"type":"text","text":" The container is the composition root — the"},{"type":"text","text":" "},{"type":"text","text":"only place where abstractions are wired to concrete implementations. Everything"},{"type":"text","text":" "},{"type":"text","text":"above it (ViewModels, services) depends only on protocols. Everything below it"},{"type":"text","text":" "},{"type":"text","text":"(concrete implementations) knows nothing about the container."}]},{"type":"codeListing","syntax":null,"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","Feature modules (depend on protocols, use Forge for wiring)","       ^","       |","App target (imports both, wires at startup)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"ViewModels and services never "},{"type":"codeVoice","code":"import"},{"text":" a concrete implementation module directly.","type":"text"},{"type":"text","text":" "},{"text":"They inject via protocol. The container handles the wiring:","type":"text"}]},{"type":"codeListing","code":["\/\/ ViewModel depends only on the protocol","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var authService","    \/\/ LoginViewModel has no idea what AuthService is —","    \/\/ it only knows AuthServiceProtocol","}"],"syntax":"swift"},{"type":"heading","anchor":"Summary","text":"Summary","level":2},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Principle"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Forge Pattern"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Single Responsibility"}]}],[{"type":"paragraph","inlineContent":[{"text":"One container per module","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open\/Closed"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Override at the container, don’t modify types"}]}]],[[{"inlineContent":[{"type":"text","text":"Liskov Substitution"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Protocol return types on all properties","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Interface Segregation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Narrow protocols, opt-in "},{"code":"SharedContainer","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dependency Inversion"}]}],[{"type":"paragraph","inlineContent":[{"text":"Container is the composition root","type":"text"}]}]]]}]}],"variants":[{"paths":["\/documentation\/forge\/solidprinciples"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"},"metadata":{"roleHeading":"Article","title":"SOLID Principles with Forge","modules":[{"name":"Forge"}],"role":"article"},"sections":[],"references":{"doc://Forge/documentation/Forge/Container/withOverrides(_:run:)-3qdpl":{"abstract":[{"text":"Registers overrides for the duration of a closure, then automatically restores","type"