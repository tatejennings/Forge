ntainer","kind":"identifier"}],"title":"Container","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Container","kind":"identifier"}],"url":"\/documentation\/forge\/container","role":"symbol"},"doc://Forge/documentation/Forge/OverridableContainer/override(_:with:)":{"title":"override(_:with:)","identifier":"doc:\/\/Forge\/documentation\/Forge\/OverridableContainer\/override(_:with:)","abstract":[{"type":"text","text":"Overrides the dependency at the given KeyPath with the provided factory."}],"url":"\/documentation\/forge\/overridablecontainer\/override(_:with:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"override"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"text":"KeyPath","kind":"typeIdentifier","preciseIdentifier":"s:s7KeyPathC"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"with","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":")","kind":"text"}],"role":"symbol","type":"topic"},"doc://Forge/documentation/Forge/SOLIDPrinciples":{"url":"\/documentation\/forge\/solidprinciples","kind":"article","abstract":[{"type":"text","text":"How each SOLID principle maps to Forge usage, with practical Swift examples."}],"role":"article","type":"topic","title":"SOLID Principles with Forge","identifier":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples"}}}