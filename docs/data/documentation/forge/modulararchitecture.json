{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"In a modular codebase, each SPM module owns its own ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true,"type":"reference"},{"text":" subclass. This","type":"text"},{"text":" ","type":"text"},{"text":"keeps dependency boundaries clean, makes modules independently testable, and","type":"text"},{"text":" ","type":"text"},{"text":"prevents accidental cross-module coupling.","type":"text"}],"type":"paragraph"},{"text":"One Container per Module","anchor":"One-Container-per-Module","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Each module defines exactly one container that manages all dependencies for that"},{"type":"text","text":" "},{"type":"text","text":"module. The container file includes the module-local typealias:"}],"type":"paragraph"},{"code":["\/\/ FeatureAuth\/Sources\/AuthContainer.swift","","import Forge","import CoreProtocols","","typealias Inject<T> = ContainerInject<AuthContainer, T>","","public final class AuthContainer: Container, SharedContainer {","    public static var shared = AuthContainer()","","    public var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    public var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"All "},{"code":"@Inject","type":"codeVoice"},{"type":"text","text":" usages within the module use the bare syntax — no container name visible:"}],"type":"paragraph"},{"code":["\/\/ FeatureAuth\/Sources\/LoginViewModel.swift","","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var auth","}"],"syntax":"swift","type":"codeListing"},{"text":"Cross-Module Proxying","anchor":"Cross-Module-Proxying","type":"heading","level":2},{"inlineContent":[{"text":"Feature modules must not import other feature modules directly. If a module needs a","type":"text"},{"text":" ","type":"text"},{"text":"dependency owned by another module, it ","type":"text"},{"inlineContent":[{"type":"text","text":"proxies"}],"type":"strong"},{"text":" the dependency through its own","type":"text"},{"text":" ","type":"text"},{"text":"container using ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true,"type":"reference"},{"text":" as the default factory. The app target","type":"text"},{"text":" ","type":"text"},{"text":"wires the real implementation at startup via ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverridableContainer\/override(_:with:)","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["\/\/ FeatureSearch\/Sources\/SearchContainer.swift","","import Forge","","public final class SearchContainer: Container, SharedContainer {","    public static var shared = SearchContainer()","","    \/\/ Wired by the app target — crashes if not overridden","    public var analytics: any AnalyticsProtocol {","        provide(.singleton) {","            unimplemented(\"analytics\")","        } preview: {","            MockAnalytics()","        }","    }","","    public var searchService: any SearchServiceProtocol {","        provide(.singleton) {","            SearchService(analytics: self.analytics)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Using ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true},{"text":" here means that if the composition root forgets","type":"text"},{"text":" ","type":"text"},{"text":"to wire ","type":"text"},{"code":"analytics","type":"codeVoice"},{"text":", the app crashes on launch with a clear message instead of","type":"text"},{"text":" ","type":"text"},{"text":"silently running on mock data.","type":"text"}],"type":"paragraph"},{"anchor":"Benefits-of-Proxying","level":3,"type":"heading","text":"Benefits of Proxying"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Fail-fast safety","type":"text"}],"type":"strong"},{"type":"text","text":" — "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","type":"reference","isActive":true},{"type":"text","text":" catches missing wiring immediately"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Test isolation"}],"type":"strong"},{"text":" — override ","type":"text"},{"type":"codeVoice","code":"analytics"},{"text":" on ","type":"text"},{"type":"codeVoice","code":"SearchContainer"},{"text":" directly, without","type":"text"},{"text":" ","type":"text"},{"text":"touching another module’s container","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Clean dependency graph"}]},{"type":"text","text":" — each module’s DI surface is fully within its own container"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Swappability"}],"type":"strong"},{"type":"text","text":" — if the analytics provider changes, only the override needs updating"}]}]}]},{"anchor":"The-Composition-Root","level":2,"type":"heading","text":"The Composition Root"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app target is the "},{"inlineContent":[{"text":"composition root","type":"text"}],"type":"strong"},{"type":"text","text":" — the only place where all modules are"},{"type":"text","text":" "},{"type":"text","text":"imported and containers are wired together:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ App\/Sources\/AppDelegate.swift","","import FeatureAuth","import FeatureSearch","import CoreAnalytics","","class AppDelegate: UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        \/\/ Wire containers","        AuthContainer.shared = AuthContainer()","        SearchContainer.shared = SearchContainer()","        CoreAnalyticsContainer.shared = CoreAnalyticsContainer()","        return true","    }","}"]},{"anchor":"Import-Dependency-Graph","level":2,"type":"heading","text":"Import Dependency Graph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The correct architecture follows this pattern:"}]},{"type":"codeListing","syntax":null,"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","  Feature modules (each has its own Container)","       ^","       |","  App target (imports all modules, wires containers)"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Key rules:"}]}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Protocol modules define abstractions only — no Forge dependency needed"}]}]},{"content":[{"inlineContent":[{"text":"Feature modules import protocol modules and Forge","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"ViewModels and services never "},{"type":"codeVoice","code":"import"},{"type":"text","text":" a concrete service module directly"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The app target is the only place that imports both protocol and concrete modules","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Best-Practices","text":"Best Practices","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keep containers "},{"type":"strong","inlineContent":[{"text":"module-scoped","type":"text"}]},{"type":"text","text":" — if a container grows beyond its module’s"},{"type":"text","text":" "},{"type":"text","text":"concerns, the module has too many responsibilities"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Make dependency properties "},{"type":"strong","inlineContent":[{"type":"text","text":"public"}]},{"type":"text","text":" — they are the module’s DI surface"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"inlineContent":[{"type":"text","text":"protocol return types"}],"type":"strong"},{"text":" on all dependency properties","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Proxy cross-module dependencies rather than importing other feature modules"}],"type":"paragraph"}]}]}]}],"abstract":[{"type":"text","text":"Organize dependency injection across multiple Swift Package Manager modules."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"Forge"}],"title":"Modular Architecture","roleHeading":"Article","role":"article"},"seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"title":"Architecture and Best Practices","generated":true,"anchor":"Architecture-and-Best-Practices"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/modulararchitecture"]}],"sections":[],"kind":"article","hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"references":{"doc://Forge/documentation/Forge":{"url":"\/documentation\/forge","identifier":"doc:\/\/Forge\/documentation\/Forge","kind":"symbol","abstract":[{"text":"A lightweight, compile-time safe dependency injection framework for Swift.","type":"text"}],"rol