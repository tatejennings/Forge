{"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Article","modules":[{"name":"Forge"}],"title":"Modular Architecture","role":"article"},"seeAlsoSections":[{"anchor":"Architecture-and-Best-Practices","title":"Architecture and Best Practices","identifiers":["doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"generated":true}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/modulararchitecture"]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In a modular codebase, each SPM module owns its own "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" subclass. This"},{"type":"text","text":" "},{"type":"text","text":"keeps dependency boundaries clean, makes modules independently testable, and"},{"type":"text","text":" "},{"type":"text","text":"prevents accidental cross-module coupling."}]},{"anchor":"One-Container-per-Module","type":"heading","level":2,"text":"One Container per Module"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each module defines exactly one container that manages all dependencies for that"},{"type":"text","text":" "},{"type":"text","text":"module. The container file includes the module-local typealias:"}]},{"code":["\/\/ FeatureAuth\/Sources\/AuthContainer.swift","","import Forge","import CoreProtocols","","typealias Inject<T> = ContainerInject<AuthContainer, T>","","public final class AuthContainer: Container, SharedContainer {","    public static let shared = AuthContainer()","","    public var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    public var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All "},{"type":"codeVoice","code":"@Inject"},{"type":"text","text":" usages within the module use the bare syntax — no container name visible:"}]},{"code":["\/\/ FeatureAuth\/Sources\/LoginViewModel.swift","","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var auth","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Cross-Module-Proxying","type":"heading","level":2,"text":"Cross-Module Proxying"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Feature modules must not import other feature modules directly. If a module needs a"},{"type":"text","text":" "},{"type":"text","text":"dependency owned by another module, it "},{"type":"strong","inlineContent":[{"type":"text","text":"proxies"}]},{"type":"text","text":" the dependency through its own"},{"type":"text","text":" "},{"text":"container using ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","type":"reference","isActive":true},{"text":" as the default factory. The app target","type":"text"},{"text":" ","type":"text"},{"text":"wires the real implementation at startup via ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverridableContainer\/override(_:with:)","type":"reference","isActive":true},{"text":":","type":"text"}]},{"code":["\/\/ FeatureSearch\/Sources\/SearchContainer.swift","","import Forge","","public final class SearchContainer: Container, SharedContainer {","    public static let shared = SearchContainer()","","    \/\/ Wired by the app target — crashes if not overridden","    public var analytics: any AnalyticsProtocol {","        provide(.singleton) {","            unimplemented(\"analytics\")","        } preview: {","            MockAnalytics()","        }","    }","","    public var searchService: any SearchServiceProtocol {","        provide(.singleton) {","            SearchService(analytics: self.analytics)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"},{"text":" here means that if the composition root forgets","type":"text"},{"text":" ","type":"text"},{"text":"to wire ","type":"text"},{"code":"analytics","type":"codeVoice"},{"text":", the app crashes on launch with a clear message instead of","type":"text"},{"text":" ","type":"text"},{"text":"silently running on mock data.","type":"text"}]},{"anchor":"Benefits-of-Proxying","level":3,"text":"Benefits of Proxying","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Fail-fast safety"}]},{"text":" — ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","type":"reference","isActive":true},{"text":" catches missing wiring immediately","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Test isolation"}]},{"type":"text","text":" — override "},{"type":"codeVoice","code":"analytics"},{"type":"text","text":" on "},{"type":"codeVoice","code":"SearchContainer"},{"type":"text","text":" directly, without"},{"type":"text","text":" "},{"type":"text","text":"touching another module’s container"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Clean dependency graph","type":"text"}]},{"type":"text","text":" — each module’s DI surface is fully within its own container"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Swappability"}],"type":"strong"},{"text":" — if the analytics provider changes, only the override needs updating","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"The-Composition-Root","level":2,"text":"The Composition Root","type":"heading"},{"inlineContent":[{"text":"The app target is the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"composition root"}]},{"text":" — the only place where all modules are","type":"text"},{"text":" ","type":"text"},{"text":"imported and containers are wired together:","type":"text"}],"type":"paragraph"},{"code":["\/\/ App\/Sources\/AppDelegate.swift","","import FeatureAuth","import FeatureSearch","import CoreAnalytics","","class AppDelegate: UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        \/\/ Wire each feature module's `unimplemented` proxies to the real","        \/\/ cross-module implementations. Containers are stable `let` singletons —","        \/\/ wire them with `override`, never by reassigning `shared`.","        SearchContainer.shared.override(\\.analytics) {","            CoreAnalyticsContainer.shared.analytics","        }","        return true","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Import-Dependency-Graph","level":2,"text":"Import Dependency Graph","type":"heading"},{"inlineContent":[{"type":"text","text":"The correct architecture follows this pattern:"}],"type":"paragraph"},{"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","  Feature modules (each has its own Container)","       ^","       |","  App target (imports all modules, wires containers)"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Key rules:"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Protocol modules define abstractions only — no Forge dependency needed","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Feature modules import protocol modules and Forge"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"ViewModels and services never ","type":"text"},{"code":"import","type":"codeVoice"},{"text":" a concrete service module directly","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The app target is the only place that imports both protocol and concrete modules","type":"text"}]}]}],"type":"orderedList"},{"text":"Best Practices","anchor":"Best-Practices","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"Keep containers ","type":"text"},{"inlineContent":[{"type":"text","text":"module-scoped"}],"type":"strong"},{"text":" — if a container grows beyond its module’s","type":"text"},{"text":" ","type":"text"},{"text":"concerns, the module has too many responsibilities","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Make dependency properties ","type":"text"},{"inlineContent":[{"type":"text","text":"public"}],"type":"strong"},{"text":" — they are the module’s DI surface","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"strong","inlineContent":[{"type":"text","text":"protocol return types"}]},{"type":"text","text":" on all dependency properties"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Proxy cross-module dependencies rather than importing other feature modules","type":"text"}]}]}],"type":"unorderedList"}]}],"identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Organize dependency injection across multiple Swift Package Manager modules."}],"sections":[],"references":{"doc://Forge/documentation/Forge/Container":{"title":"Container","role":"symbol","navigat