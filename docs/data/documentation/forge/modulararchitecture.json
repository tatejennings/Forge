{"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"In a modular codebase, each SPM module owns its own "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true,"type":"reference"},{"type":"text","text":" subclass. This"},{"type":"text","text":" "},{"type":"text","text":"keeps dependency boundaries clean, makes modules independently testable, and"},{"type":"text","text":" "},{"type":"text","text":"prevents accidental cross-module coupling."}],"type":"paragraph"},{"anchor":"One-Container-per-Module","level":2,"text":"One Container per Module","type":"heading"},{"inlineContent":[{"type":"text","text":"Each module defines exactly one container that manages all dependencies for that"},{"type":"text","text":" "},{"type":"text","text":"module. The container file includes the module-local typealias:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ FeatureAuth\/Sources\/AuthContainer.swift","","import Forge","import CoreProtocols","","typealias Inject<T> = ContainerInject<AuthContainer, T>","","public final class AuthContainer: Container, SharedContainer {","    public static let shared = AuthContainer()","","    public var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    public var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"All "},{"code":"@Inject","type":"codeVoice"},{"type":"text","text":" usages within the module use the bare syntax — no container name visible:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ FeatureAuth\/Sources\/LoginViewModel.swift","","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var auth","}"],"type":"codeListing"},{"anchor":"Cross-Module-Proxying","level":2,"text":"Cross-Module Proxying","type":"heading"},{"inlineContent":[{"type":"text","text":"Feature modules must not import other feature modules directly. If a module needs a"},{"type":"text","text":" "},{"type":"text","text":"dependency owned by another module, it "},{"type":"strong","inlineContent":[{"type":"text","text":"proxies"}]},{"type":"text","text":" the dependency through its own"},{"type":"text","text":" "},{"type":"text","text":"container using "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"},{"type":"text","text":" as the default factory. The app target"},{"type":"text","text":" "},{"type":"text","text":"wires the real implementation at startup via "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverridableContainer\/override(_:with:)"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ FeatureSearch\/Sources\/SearchContainer.swift","","import Forge","","public final class SearchContainer: Container, SharedContainer {","    public static let shared = SearchContainer()","","    \/\/ Wired by the app target — crashes if not overridden","    public var analytics: any AnalyticsProtocol {","        provide(.singleton) {","            unimplemented(\"analytics\")","        } preview: {","            MockAnalytics()","        }","    }","","    public var searchService: any SearchServiceProtocol {","        provide(.singleton) {","            SearchService(analytics: self.analytics)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Using "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true},{"type":"text","text":" here means that if the composition root forgets"},{"type":"text","text":" "},{"type":"text","text":"to wire "},{"code":"analytics","type":"codeVoice"},{"type":"text","text":", the app crashes on launch with a clear message instead of"},{"type":"text","text":" "},{"type":"text","text":"silently running on mock data."}],"type":"paragraph"},{"anchor":"Benefits-of-Proxying","level":3,"text":"Benefits of Proxying","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Fail-fast safety"}]},{"type":"text","text":" — "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true},{"type":"text","text":" catches missing wiring immediately"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Test isolation"}],"type":"strong"},{"text":" — override ","type":"text"},{"type":"codeVoice","code":"analytics"},{"text":" on ","type":"text"},{"type":"codeVoice","code":"SearchContainer"},{"text":" directly, without","type":"text"},{"text":" ","type":"text"},{"text":"touching another module’s container","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Clean dependency graph","type":"text"}],"type":"strong"},{"text":" — each module’s DI surface is fully within its own container","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Swappability"}]},{"type":"text","text":" — if the analytics provider changes, only the override needs updating"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"The-Composition-Root","level":2,"text":"The Composition Root","type":"heading"},{"inlineContent":[{"type":"text","text":"The app target is the "},{"type":"strong","inlineContent":[{"text":"composition root","type":"text"}]},{"type":"text","text":" — the only place where all modules are"},{"type":"text","text":" "},{"type":"text","text":"imported and containers are wired together:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ App\/Sources\/AppDelegate.swift","","import FeatureAuth","import FeatureSearch","import CoreAnalytics","","class AppDelegate: UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        \/\/ Wire each feature module's `unimplemented` proxies to the real","        \/\/ cross-module implementations. Containers are stable `let` singletons —","        \/\/ wire them with `override`, never by reassigning `shared`.","        SearchContainer.shared.override(\\.analytics) {","            CoreAnalyticsContainer.shared.analytics","        }","        return true","    }","}"],"type":"codeListing"},{"anchor":"Consuming-a-Module-Container-from-the-App-Target","level":2,"text":"Consuming a Module Container from the App Target","type":"heading"},{"inlineContent":[{"text":"Inside a feature module, ","type":"text"},{"type":"codeVoice","code":"@Inject(\\.x)"},{"text":" works because the module’s local","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference","isActive":true},{"text":" typealias (","type":"text"},{"type":"codeVoice","code":"typealias Inject<T> = ContainerInject<XContainer, T>"},{"text":") is in","type":"text"},{"text":" ","type":"text"},{"text":"scope. That typealias is internal to the module, so ","type":"text"},{"type":"strong","inlineContent":[{"text":"at the app target the bare","type":"text"},{"text":" ","type":"text"},{"code":"@Inject(\\.x)","type":"codeVoice"},{"text":" resolves only from ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true,"type":"reference"}]},{"text":" — it cannot reach a feature","type":"text"},{"text":" ","type":"text"},{"text":"container.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You do not need "},{"type":"codeVoice","code":"SomeContainer.shared.dependency"},{"type":"text","text":" to bridge that gap. Use"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"type":"text","text":"’s explicit-container initializer, which is fully type-inferred:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ App target — e.g. an app-level coordinator that needs a feature's service","final class RootCoordinator {","    @ContainerInject(TaskContainer.shared, \\.taskService) private var taskService","}"],"type":"codeListing"},{"inlineContent":[{"text":"For repeated use, declare a per-container typealias at the app target, mirroring the","type":"text"},{"text":" ","type":"text"},{"text":"in-module idiom:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["typealias TasksInject<T> = ContainerInject<TaskContainer, T>","","@TasksInject(\\.taskService) private var taskService"],"type":"codeListing"},{"inlineContent":[{"text":"Both forms give the same lazy resolution, caching, and override-awareness as the","type":"text"},{"text":" ","type":"text"},{"text":"bare ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference"},{"text":". This is ","type":"text"},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"text":" a layering violation — the app target is the","type":"text"},{"text":" ","type":"text"},{"text":"composition root and already imports every module.","type":"text"}],"type":"paragraph"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The bare "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":" is intentionally bound to a single container. Resolving"},{"type":"text","text":" "},{"type":"codeVoice","code":"@Inject(\\.x)"},{"type":"text","text":" across containers would require runtime cross-container lookup"},{"type":"text","text":" "},{"type":"text","text":"(a service locator), which Forge does not do — the fixed-container typealias is"},{"type":"text","text":" "},{"type":"text","text":"what makes resolution compile-time-safe. Prefer registering app-level needs on"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true},{"type":"text","text":"; reach into a feature container only when the app genuinely needs"},{"type":"text","text":" "},{"type":"text","text":"something that feature owns."}]}],"type":"aside"},{"anchor":"Import-Dependency-Graph","level":2,"text":"Import Dependency Graph","type":"heading"},{"inlineContent":[{"type":"text","text":"The correct architecture follows this pattern:"}],"type":"paragraph"},{"syntax":null,"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","  Feature modules (each has its own Container)","       ^","       |","  App target (imports all modules, wires containers)"],"type":"codeListing"},{"inlineContent":[{"inlineContent":[{"text":"Key rules:","type":"text"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Protocol modules define abstractions only — no Forge dependency needed","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Feature modules import protocol modules and Forge"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"ViewModels and services never ","type":"text"},{"type":"codeVoice","code":"import"},{"text":" a concrete service module directly","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The app target is the only place that imports both protocol and concrete modules"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Best-Practices","level":2,"text":"Best Practices","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Keep containers "},{"type":"strong","inlineContent":[{"type":"text","text":"module-scoped"}]},{"type":"text","text":" — if a container grows beyond its module’s"},{"type":"text","text":" "},{"type":"text","text":"concerns, the module has too many responsibilities"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Make dependency properties ","type":"text"},{"inlineContent":[{"type":"text","text":"public"}],"type":"strong"},{"text":" — they are the module’s DI surface","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"inlineContent":[{"type":"text","text":"protocol return types"}],"type":"strong"},{"type":"text","text":" on all dependency properties"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Proxy cross-module dependencies rather than importing other feature modules","type":"text"}]}]}],"type":"unorderedList"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/forge\/modulararchitecture"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture"},"seeAlsoSections":[{"generated":true,"title":"Architecture and Best Practices","identifiers":["doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"anchor":"Architecture-and-Best-Practices"}],"kind":"article","metadata":{"role":"article","roleHeading":"Article","title":"Modular Architecture","modules":[{"name":"Forge"}]},"sections":[],"abstract":[{"text":"Organize dependency injection across multiple Swift Package Manager modules.","type":"text"}],"references":{"doc://Forge/documentation/Forge/unimplemented(_:file:line:)":{"title":"unimplemented(_:file:line:)","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"unimplemented"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"file"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s12StaticStringV","text":"StaticString"},{"kind":"text","text":", "},{"kind":"externalParam","text":"line"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Su","text":"UInt"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"T"}],"url":"\/documentation\/forge\/unimplemented(_:file:line:)","role":"symbol","abstract":[{"type":"text","text":"Returns a value of type "},{"type":"codeVoice","code":"T"},{"type":"text","text":" that will never actually be produced — calling this"},{"type":"text","text":" "},{"type":"text","text":"function always terminates via "},{"type":"codeVoice","code":"fatalError"},{"type":"text","text":"."}],"kind":"symbol"},"doc://Forge/documentation/Forge/OverridableContainer/override(_:with:)":{"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverridableContainer\/override(_:with:)","url":"\/documentation\/forge\/overridablecontainer\/override(_:with:)","kind":"symbol","title":"override(_:with:)","abstract":[{"text":"Overrides the dependency at the given KeyPath with the provided factory.","type":"text"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"override","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:s7KeyPathC","text":"KeyPath","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"with"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":")"}],"type":"topic"},"doc://Forge/documentation/Forge/Container":{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","title":"Container","url":"\/documentation\/forge\/container","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Container"}],"navigatorTitle":[{"kind":"identifier","text":"Container"}],"kind":"symbol","type":"topic","role":"symbol","abstract":[{"text":"The base class for all dependency containers in Forge.","type":"text"}]},"doc://Forge/documentation/Forge":{"abstract":[{"text":"A lightweight dependency injection framework for Swift — compile-time-safe at the call site, with loud, fail-fast runtime checks underneath.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/Forge\/documentation\/Forge","url":"\/documentation\/forge","title":"Forge","role":"collection","type":"topic"},"doc://Forge/documentation/Forge/ContainerInject":{"abstract":[{"text":"A property wrapper that lazily resolves a dependency from a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","type":"reference"},{"text":".","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ContainerInject"}],"navigatorTitle":[{"kind":"identifier","text":"ContainerInject"}],"url":"\/documentation\/forge\/containerinject","kind":"symbol","role":"symbol","title":"ContainerInject","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},"doc://Forge/documentation/Forge/AppContainer":{"abstract":[{"type":"text","text":"A ready-to-use container provided by Forge for simple single-container apps."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AppContainer","kind":"identifier"}],"title":"AppContainer","url":"\/documentation\/forge\/appcontainer","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"AppContainer","kind":"identifier"}],"type":"topic"},"doc://Forge/documentation/Forge/XcodePreviewSupport":{"kind":"article","role":"article","abstract":[{"text":"Provide preview-safe mock factories that activate automatically in Xcode Previews.","type":"text"}],"url":"\/documentation\/forge\/xcodepreviewsupport","type":"topic","identifier":"doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport","title":"Xcode Preview Support"},"doc://Forge/documentation/Forge/SOLIDPrinciples":{"type":"topic","kind":"article","title":"SOLID Principles with Forge","role":"article","abstract":[{"type":"text","text":"How each SOLID principle maps to Forge usage, with practical Swift examples."}],"identifier":"doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","url":"\/documentation\/forge\/solidprinciples"},"doc://Forge/documentation/Forge/Inject":{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Inject"}],"title":"Inject","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"Inject"}],"abstract":[{"type":"text","text":"A convenience typealias for injecting dependencies from "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true},{"type":"text","text":"."}],"url":"\/documentation\/forge\/inject"}}}