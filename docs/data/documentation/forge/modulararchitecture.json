{"metadata":{"role":"article","modules":[{"name":"Forge"}],"roleHeading":"Article","title":"Modular Architecture"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"text":"In a modular codebase, each SPM module owns its own ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true,"type":"reference"},{"text":" subclass. This","type":"text"},{"text":" ","type":"text"},{"text":"keeps dependency boundaries clean, makes modules independently testable, and","type":"text"},{"text":" ","type":"text"},{"text":"prevents accidental cross-module coupling.","type":"text"}],"type":"paragraph"},{"text":"One Container per Module","type":"heading","level":2,"anchor":"One-Container-per-Module"},{"inlineContent":[{"text":"Each module defines exactly one container that manages all dependencies for that","type":"text"},{"text":" ","type":"text"},{"text":"module. The container file includes the module-local typealias:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ FeatureAuth\/Sources\/AuthContainer.swift","","import Forge","import CoreProtocols","","typealias Inject<T> = ContainerInject<AuthContainer, T>","","public final class AuthContainer: Container, SharedContainer {","    public static var shared = AuthContainer()","","    public var authService: any AuthServiceProtocol {","        provide(.singleton, preview: { MockAuthService() }) {","            AuthService(network: self.networkClient)","        }","    }","","    public var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","}"]},{"inlineContent":[{"type":"text","text":"All "},{"type":"codeVoice","code":"@Inject"},{"type":"text","text":" usages within the module use the bare syntax — no container name visible:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ FeatureAuth\/Sources\/LoginViewModel.swift","","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var auth","}"]},{"text":"Cross-Module Proxying","type":"heading","level":2,"anchor":"Cross-Module-Proxying"},{"inlineContent":[{"type":"text","text":"Feature modules must not import other feature modules directly. If a module needs a"},{"type":"text","text":" "},{"type":"text","text":"dependency owned by another module, it "},{"type":"strong","inlineContent":[{"text":"proxies","type":"text"}]},{"type":"text","text":" the dependency through its own"},{"type":"text","text":" "},{"type":"text","text":"container:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ FeatureSearch\/Sources\/SearchContainer.swift","","import Forge","import CoreAnalytics","","public final class SearchContainer: Container, SharedContainer {","    public static var shared = SearchContainer()","","    \/\/ Proxy — delegates to another module's container","    public var analytics: any AnalyticsProtocol {","        provide { CoreAnalyticsContainer.shared.analytics }","    }","","    public var searchService: any SearchServiceProtocol {","        provide(.singleton) {","            SearchService(analytics: self.analytics)","        }","    }","}"]},{"text":"Benefits of Proxying","type":"heading","level":3,"anchor":"Benefits-of-Proxying"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Test isolation","type":"text"}],"type":"strong"},{"text":" — override ","type":"text"},{"code":"analytics","type":"codeVoice"},{"text":" on ","type":"text"},{"code":"SearchContainer","type":"codeVoice"},{"text":" directly, without","type":"text"},{"text":" ","type":"text"},{"text":"touching ","type":"text"},{"code":"CoreAnalyticsContainer","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Clean dependency graph"}]},{"text":" — each module’s DI surface is fully within its own container","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Swappability"}],"type":"strong"},{"text":" — if ","type":"text"},{"type":"codeVoice","code":"CoreAnalytics"},{"text":" is replaced, only the proxy property needs updating","type":"text"}]}]}]},{"type":"heading","level":2,"anchor":"The-Composition-Root","text":"The Composition Root"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app target is the "},{"type":"strong","inlineContent":[{"text":"composition root","type":"text"}]},{"type":"text","text":" — the only place where all modules are"},{"type":"text","text":" "},{"type":"text","text":"imported and containers are wired together:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ App\/Sources\/AppDelegate.swift","","import FeatureAuth","import FeatureSearch","import CoreAnalytics","","class AppDelegate: UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        \/\/ Wire containers","        AuthContainer.shared = AuthContainer()","        SearchContainer.shared = SearchContainer()","        CoreAnalyticsContainer.shared = CoreAnalyticsContainer()","        return true","    }","}"]},{"type":"heading","anchor":"Import-Dependency-Graph","level":2,"text":"Import Dependency Graph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The correct architecture follows this pattern:"}]},{"syntax":null,"type":"codeListing","code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","  Feature modules (each has its own Container)","       ^","       |","  App target (imports all modules, wires containers)"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Key rules:"}],"type":"strong"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Protocol modules define abstractions only — no Forge dependency needed"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Feature modules import protocol modules and Forge"}]}]},{"content":[{"inlineContent":[{"text":"ViewModels and services never ","type":"text"},{"code":"import","type":"codeVoice"},{"text":" a concrete service module directly","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The app target is the only place that imports both protocol and concrete modules","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"heading","anchor":"Best-Practices","level":2,"text":"Best Practices"},{"items":[{"content":[{"inlineContent":[{"text":"Keep containers ","type":"text"},{"inlineContent":[{"text":"module-scoped","type":"text"}],"type":"strong"},{"text":" — if a container grows beyond its module’s","type":"text"},{"text":" ","type":"text"},{"text":"concerns, the module has too many responsibilities","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Make dependency properties ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"public"}]},{"text":" — they are the module’s DI surface","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"strong","inlineContent":[{"text":"protocol return types","type":"text"}]},{"type":"text","text":" on all dependency properties"}]}]},{"content":[{"inlineContent":[{"text":"Proxy cross-module dependencies rather than importing other feature modules","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"generated":true,"title":"Architecture and Best Practices","anchor":"Architecture-and-Best-Practices"}],"h