{","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    public var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"All ","type":"text"},{"code":"@Inject","type":"codeVoice"},{"text":" usages within the module use the bare syntax — no container name visible:","type":"text"}]},{"code":["\/\/ FeatureAuth\/Sources\/LoginViewModel.swift","","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var auth","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Cross-Module-Proxying","type":"heading","level":2,"text":"Cross-Module Proxying"},{"type":"paragraph","inlineContent":[{"text":"Feature modules must not import other feature modules directly. If a module needs a","type":"text"},{"text":" ","type":"text"},{"text":"dependency owned by another module, it ","type":"text"},{"inlineContent":[{"text":"proxies","type":"text"}],"type":"strong"},{"text":" the dependency through its own","type":"text"},{"text":" ","type":"text"},{"text":"container using ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","type":"reference"},{"text":" as the default factory. The app target","type":"text"},{"text":" ","type":"text"},{"text":"wires the real implementation at startup via ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverridableContainer\/override(_:with:)","type":"reference"},{"text":":","type":"text"}]},{"code":["\/\/ FeatureSearch\/Sources\/SearchContainer.swift","","import Forge","","public final class SearchContainer: Container, SharedContainer {","    public static let shared = SearchContainer()","","    \/\/ Wired by the app target — crashes if not overridden","    public var analytics: any AnalyticsProtocol {","        provide(.singleton) {","            unimplemented(\"analytics\")","        } preview: {","            MockAnalytics()","        }","    }","","    public var searchService: any SearchServiceProtocol {","        provide(.singleton) {","            SearchService(analytics: self.analytics)","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Using ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","type":"reference","isActive":true},{"text":" here means that if the composition root forgets","type":"text"},{"text":" ","type":"text"},{"text":"to wire ","type":"text"},{"code":"analytics","type":"codeVoice"},{"text":", the app crashes on launch with a clear message instead of","type":"text"},{"text":" ","type":"text"},{"text":"silently running on mock data.","type":"text"}]},{"anchor":"Benefits-of-Proxying","type":"heading","level":3,"text":"Benefits of Proxying"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Fail-fast safety"}]},{"text":" — ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"},{"text":" catches missing wiring immediately","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Test isolation"}],"type":"strong"},{"text":" — override ","type":"text"},{"code":"analytics","type":"codeVoice"},{"text":" on ","type":"text"},{"code":"SearchContainer","type":"codeVoice"},{"text":" directly, without","type":"text"},{"text":" ","type":"text"},{"text":"touching another module’s container","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Clean dependency graph","type":"text"}],"type":"strong"},{"text":" — each module’s DI surface is fully within its own container","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Swappability"}],"type":"strong"},{"text":" — if the analytics provider changes, only the override needs updating","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"The-Composition-Root","type":"heading","level":2,"text":"The Composition Root"},{"type":"paragraph","inlineContent":[{"text":"The app target is the ","type":"text"},{"type":"strong","inlineContent":[{"text":"composition root","type":"text"}]},{"text":" — the only place where all modules are","type":"text"},{"text":" ","type":"text"},{"text":"imported and containers are wired together. Put the wiring in a dedicated","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CompositionRoot.swift"},{"text":" as a ","type":"text"},{"type":"strong","inlineContent":[{"text":"standalone ","type":"text"},{"type":"codeVoice","code":"wireContainers()"},{"text":" function","type":"text"}]},{"text":" (not a method","type":"text"},{"text":" ","type":"text"},{"text":"on ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true,"type":"reference"},{"text":"), and call it once from ","type":"text"},{"type":"codeVoice","code":"App.init()"},{"text":":","type":"text"}]},{"code":["\/\/ App\/Sources\/CompositionRoot.swift","","import Forge","import FeatureAuth","import FeatureSearch","import CoreAnalytics","","\/\/ MARK: - Target-level services (OPTIONAL)","\/\/ Only if the app target itself owns dependencies that live in no module. A thin app","\/\/ target omits this entirely — then `AppContainer` never appears.","\/\/","\/\/   extension AppContainer {","\/\/       var someAppService: any SomeProtocol { provide(.singleton) { SomeService() } }","\/\/   }","","\/\/ MARK: - Composition root — wire feature proxies once, at launch","func wireContainers() {","    \/\/ Wire each feature module's `unimplemented` proxy to the real implementation,","    \/\/ read from the module container that owns it. Containers are stable singletons —","    \/\/ wire with `override`, never by reassigning `shared`.","    let analytics = CoreAnalyticsContainer.shared.analytics","    SearchContainer.shared.override(\\.analytics) { analytics }","}"],"type":"codeListing","syntax":"swift"},{"code":["\/\/ App\/Sources\/MyApp.swift","@main","struct MyApp: App {","    init() { wireContainers() }","    var body: some Scene { WindowGroup { RootView() } }","}"],"type":"codeListing","syntax":"swift"},{"name":"Important","style":"important","type":"aside","content":[{"inlineContent":[{"text":"The real implementations live in the module that owns them (here,","type":"text"},{"text":" ","type":"text"},{"code":"CoreAnalytics","type":"codeVoice"},{"text":"’s own container) — not on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","type":"reference"},{"text":". ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","type":"reference"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"optional","type":"text"}],"type":"strong"},{"text":" in a modular app: use it only for genuine ","type":"text"},{"inlineContent":[{"text":"target-level","type":"text"}],"type":"emphasis"},{"text":" services the","type":"text"},{"text":" ","type":"text"},{"text":"app itself owns. A thin app target whose modules own everything never touches it.","type":"text"},{"text":" ","type":"text"},{"text":"And keep the wiring a free function — making it a method on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","type":"reference"},{"text":" makes","type":"text"},{"text":" ","type":"text"},{"text":"the composition root read like the Simple path.","type":"text"}],"type":"paragraph"}]},{"anchor":"Consuming-a-Module-Container-from-the-App-Target","type":"heading","level":2,"text":"Consuming a Module Container from the App Target"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Inside a feature module, "},{"type":"codeVoice","code":"@Inject(\\.x)"},{"type":"text","text":" works because the module’s local"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":" typealias ("},{"type":"codeVoice","code":"typealias Inject<T> = ContainerInject<XContainer, T>"},{"type":"text","text":") is in"},{"type":"text","text":" "},{"type":"text","text":"scope. That typealias is internal to the module, so "},{"type":"strong","inlineContent":[{"type":"text","text":"at the app target the bare"},{"type":"text","text":" "},{"type":"codeVoice","code":"@Inject(\\.x)"},{"type":"text","text":" resolves only from "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","isActive":true}]},{"type":"text","text":" — it cannot reach a feature"},{"type":"text","text":" "},{"type":"text","text":"container."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You do not need "},{"code":"SomeContainer.shared.dependency","type":"codeVoice"},{"type":"text","text":" to bridge that gap. Use"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/ContainerInject"},{"type":"text","text":"’s explicit-container initializer, which is fully type-inferred:"}]},{"code":["\/\/ App target — e.g. an app-level coordinator that needs a feature's service","final class RootCoordinator {","    @ContainerInject(TaskContainer.shared, \\.taskService) private var taskService","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For repeated use, declare a per-container typealias at the app target, mirroring the"},{"type":"text","text":" "},{"type":"text","text":"in-module idiom:"}]},{"code":["typealias TasksInject<T> = ContainerInject<TaskContainer, T>","","@TasksInject(\\.taskService) private var taskService"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both forms give the same lazy resolution, caching, and override-awareness as the"},{"type":"text","text":" "},{"type":"text","text":"bare "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","isActive":true},{"type":"text","text":". This is "},{"inlineContent":[{"type":"text","text":"not"}],"type":"strong"},{"type":"text","text":" a layering violation — the app target is the"},{"type":"text","text":" "},{"type":"text","text":"composition root and already imports every module."}]},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"text":"The bare ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/Inject","type":"reference","isActive":true},{"text":" is intentionally bound to a single container. Resolving","type":"text"},{"text":" ","type":"text"},{"code":"@Inject(\\.x)","type":"codeVoice"},{"text":" across containers would require runtime cross-container lookup","type":"text"},{"text":" ","type":"text"},{"text":"(a service locator), which Forge does not do — the fixed-container typealias is","type":"text"},{"text":" ","type":"text"},{"text":"what makes resolution compile-time-safe. Prefer registering app-level needs on","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/AppContainer","type":"reference","isActive":true},{"text":"; reach into a feature container only when the app genuinely needs","type":"text"},{"text":" ","type":"text"},{"text":"something that feature owns.","type":"text"}],"type":"paragraph"}]},{"anchor":"Import-Dependency-Graph","type":"heading","level":2,"text":"Import Dependency Graph"},{"type":"paragraph","inlineContent":[{"text":"The correct architecture follows this pattern:","type":"text"}]},{"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","  Feature modules (each has its own Container)","       ^","       |","  App target (imports all modules, wires containers)"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Key rules:"}]}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Protocol modules define abstractions only — no Forge dependency needed"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Feature modules import protocol modules and Forge"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"ViewModels and services never ","type":"text"},{"type":"codeVoice","code":"import"},{"text":" a concrete service module directly","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The app target is the only place that imports both protocol and concrete modules"}]}]}],"type":"orderedList"},{"anchor":"Best-Practices","type":"heading","level":2,"text":"Best Practices"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keep containers "},{"type":"strong","inlineContent":[{"text":"module-scoped","type":"text"}]},{"type":"text","text":" — if a container grows beyond its module’s"},{"type":"text","text":" "},{"type":"text","text":"concerns, the module has too many responsibilities"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Make dependency properties "},{"inlineContent":[{"text":"public","type":"text"}],"type":"strong"},{"type":"text","text":" — they are the module’s DI surface"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"strong","inlineContent":[{"text":"protocol return types","type":"text"}]},{"type":"text","text":" on all dependency properties"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Proxy cross-module dependencies rather than importing other feature modules","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"variants":[{"traits":[