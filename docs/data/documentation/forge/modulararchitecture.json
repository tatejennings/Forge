{"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture"},"abstract":[{"type":"text","text":"Organize dependency injection across multiple Swift Package Manager modules."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"role":"article","modules":[{"name":"Forge"}],"roleHeading":"Article","title":"Modular Architecture"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"In a modular codebase, each SPM module owns its own "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/Container"},{"type":"text","text":" subclass. This"},{"type":"text","text":" "},{"type":"text","text":"keeps dependency boundaries clean, makes modules independently testable, and"},{"type":"text","text":" "},{"type":"text","text":"prevents accidental cross-module coupling."}],"type":"paragraph"},{"text":"One Container per Module","level":2,"anchor":"One-Container-per-Module","type":"heading"},{"inlineContent":[{"type":"text","text":"Each module defines exactly one container that manages all dependencies for that"},{"type":"text","text":" "},{"type":"text","text":"module. The container file includes the module-local typealias:"}],"type":"paragraph"},{"code":["\/\/ FeatureAuth\/Sources\/AuthContainer.swift","","import Forge","import CoreProtocols","","typealias Inject<T> = ContainerInject<AuthContainer, T>","","public final class AuthContainer: Container, SharedContainer {","    public static let shared = AuthContainer()","","    public var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    public var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"All "},{"type":"codeVoice","code":"@Inject"},{"type":"text","text":" usages within the module use the bare syntax — no container name visible:"}],"type":"paragraph"},{"code":["\/\/ FeatureAuth\/Sources\/LoginViewModel.swift","","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var auth","}"],"syntax":"swift","type":"codeListing"},{"text":"Cross-Module Proxying","level":2,"anchor":"Cross-Module-Proxying","type":"heading"},{"inlineContent":[{"type":"text","text":"Feature modules must not import other feature modules directly. If a module needs a"},{"type":"text","text":" "},{"type":"text","text":"dependency owned by another module, it "},{"type":"strong","inlineContent":[{"text":"proxies","type":"text"}]},{"type":"text","text":" the dependency through its own"},{"type":"text","text":" "},{"type":"text","text":"container using "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true},{"type":"text","text":" as the default factory. The app target"},{"type":"text","text":" "},{"type":"text","text":"wires the real implementation at startup via "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/OverridableContainer\/override(_:with:)","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"code":["\/\/ FeatureSearch\/Sources\/SearchContainer.swift","","import Forge","","public final class SearchContainer: Container, SharedContainer {","    public static let shared = SearchContainer()","","    \/\/ Wired by the app target — crashes if not overridden","    public var analytics: any AnalyticsProtocol {","        provide(.singleton) {","            unimplemented(\"analytics\")","        } preview: {","            MockAnalytics()","        }","    }","","    public var searchService: any SearchServiceProtocol {","        provide(.singleton) {","            SearchService(analytics: self.analytics)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Using "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","type":"reference","isActive":true},{"type":"text","text":" here means that if the composition root forgets"},{"type":"text","text":" "},{"type":"text","text":"to wire "},{"code":"analytics","type":"codeVoice"},{"type":"text","text":", the app crashes on launch with a clear message instead of"},{"type":"text","text":" "},{"type":"text","text":"silently running on mock data."}],"type":"paragraph"},{"text":"Benefits of Proxying","level":3,"anchor":"Benefits-of-Proxying","type":"heading"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Fail-fast safety"}],"type":"strong"},{"type":"text","text":" — "},{"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true,"type":"reference"},{"type":"text","text":" catches missing wiring immediately"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Test isolation"}],"type":"strong"},{"text":" — override ","type":"text"},{"code":"analytics","type":"codeVoice"},{"text":" on ","type":"text"},{"code":"SearchContainer","type":"codeVoice"},{"text":" directly, without","type":"text"},{"text":" ","type":"text"},{"text":"touching another module’s container","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Clean dependency graph","type":"text"}]},{"type":"text","text":" — each module’s DI surface is fully within its own container"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Swappability","type":"text"}]},{"type":"text","text":" — if the analytics provider changes, only the override needs updating"}]}]}]},{"text":"The Composition Root","level":2,"anchor":"The-Composition-Root","type":"heading"},{"inlineContent":[{"text":"The app target is the ","type":"text"},{"inlineContent":[{"text":"composition root","type":"text"}],"type":"strong"},{"text":" — the only place where all modules are","type":"text"},{"text":" ","type":"text"},{"text":"imported and containers are wired together:","type":"text"}],"type":"paragraph"},{"code":["\/\/ App\/Sources\/AppDelegate.swift","","import FeatureAuth","import FeatureSearch","import CoreAnalytics","","class AppDelegate: UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        \/\/ Wire each feature module's `unimplemented` proxies to the real","        \/\/ cross-module implementations. Containers are stable `let` singletons —","        \/\/ wire them with `override`, never by reassigning `shared`.","        SearchContainer.shared.override(\\.analytics) {","            CoreAnalyticsContainer.shared.analytics","        }","        return true","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"Import Dependency Graph","level":2,"anchor":"Import-Dependency-Graph","type":"heading"},{"inlineContent":[{"text":"The correct architecture follows this pattern:","type":"text"}],"type":"paragraph"},{"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","  Feature modules (each has its own Container)","       ^","       |","  App target (imports all modules, wires containers)"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Key rules:"}],"type":"strong"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Protocol modules define abstractions only — no Forge dependency needed"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Feature modules import protocol modules and Forge","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"ViewModels and services never "},{"type":"codeVoice","code":"import"},{"type":"text","text":" a concrete service module directly"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The app target is the only place that imports both protocol and concrete modules","type":"text"}]}]}]},{"text":"Best Practices","level":2,"anchor":"Best-Practices","type":"heading"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keep containers "},{"type":"strong","inlineContent":[{"text":"module-scoped","type":"text"}]},{"type":"text","text":" — if a container grows beyond its module’s"},{"type":"text","text":" "},{"type":"text","text":"concerns, the module has too many responsibilities"}]}]},{"content":[{"inlineContent":[{"text":"Make dependency properties ","type":"text"},{"inlineContent":[{"type":"text","text":"public"}],"type":"strong"},{"text":" — they are the module’s DI surface","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"strong","inlineContent":[{"text":"protocol return types","type":"text"}]},{"type":"text","text":" on all dependency properties"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Proxy cross-module dependencies rather than importing other feature modules"}],"type":"paragraph"}]}]}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"generated":true,"anchor":"Architecture-and-Best-Practices","title":"Architecture and Best Practices"}],"kind":"article","variants":[{"paths":["\/documentation\/forge\/modulararchitecture"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://Forge/documentation/Forge/XcodePreviewSupport":{"title":"Xcode Preview Support","k