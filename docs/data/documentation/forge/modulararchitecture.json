{"seeAlsoSections":[{"identifiers":["doc:\/\/Forge\/documentation\/Forge\/SOLIDPrinciples","doc:\/\/Forge\/documentation\/Forge\/XcodePreviewSupport"],"anchor":"Architecture-and-Best-Practices","title":"Architecture and Best Practices","generated":true}],"metadata":{"roleHeading":"Article","title":"Modular Architecture","modules":[{"name":"Forge"}],"role":"article"},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/Forge\/documentation\/Forge"]]},"kind":"article","identifier":{"url":"doc:\/\/Forge\/documentation\/Forge\/ModularArchitecture","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Organize dependency injection across multiple Swift Package Manager modules."}],"variants":[{"paths":["\/documentation\/forge\/modulararchitecture"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"In a modular codebase, each SPM module owns its own ","type":"text"},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/Container","isActive":true},{"text":" subclass. This","type":"text"},{"text":" ","type":"text"},{"text":"keeps dependency boundaries clean, makes modules independently testable, and","type":"text"},{"text":" ","type":"text"},{"text":"prevents accidental cross-module coupling.","type":"text"}],"type":"paragraph"},{"text":"One Container per Module","level":2,"anchor":"One-Container-per-Module","type":"heading"},{"inlineContent":[{"type":"text","text":"Each module defines exactly one container that manages all dependencies for that"},{"type":"text","text":" "},{"type":"text","text":"module. The container file includes the module-local typealias:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ FeatureAuth\/Sources\/AuthContainer.swift","","import Forge","import CoreProtocols","","typealias Inject<T> = ContainerInject<AuthContainer, T>","","public final class AuthContainer: Container, SharedContainer {","    public static let shared = AuthContainer()","","    public var authService: any AuthServiceProtocol {","        provide(.singleton) {","            AuthService(network: self.networkClient)","        } preview: {","            MockAuthService()","        }","    }","","    public var networkClient: any NetworkClientProtocol {","        provide(.singleton) { URLSessionNetworkClient() }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"All ","type":"text"},{"code":"@Inject","type":"codeVoice"},{"text":" usages within the module use the bare syntax — no container name visible:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ FeatureAuth\/Sources\/LoginViewModel.swift","","final class LoginViewModel: ObservableObject {","    @Inject(\\.authService) private var auth","}"],"type":"codeListing"},{"text":"Cross-Module Proxying","level":2,"anchor":"Cross-Module-Proxying","type":"heading"},{"inlineContent":[{"text":"Feature modules must not import other feature modules directly. If a module needs a","type":"text"},{"text":" ","type":"text"},{"text":"dependency owned by another module, it ","type":"text"},{"inlineContent":[{"text":"proxies","type":"text"}],"type":"strong"},{"text":" the dependency through its own","type":"text"},{"text":" ","type":"text"},{"text":"container using ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","type":"reference"},{"text":" as the default factory. The app target","type":"text"},{"text":" ","type":"text"},{"text":"wires the real implementation at startup via ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Forge\/documentation\/Forge\/OverridableContainer\/override(_:with:)","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ FeatureSearch\/Sources\/SearchContainer.swift","","import Forge","","public final class SearchContainer: Container, SharedContainer {","    public static let shared = SearchContainer()","","    \/\/ Wired by the app target — crashes if not overridden","    public var analytics: any AnalyticsProtocol {","        provide(.singleton) {","            unimplemented(\"analytics\")","        } preview: {","            MockAnalytics()","        }","    }","","    public var searchService: any SearchServiceProtocol {","        provide(.singleton) {","            SearchService(analytics: self.analytics)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Using ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)"},{"text":" here means that if the composition root forgets","type":"text"},{"text":" ","type":"text"},{"text":"to wire ","type":"text"},{"type":"codeVoice","code":"analytics"},{"text":", the app crashes on launch with a clear message instead of","type":"text"},{"text":" ","type":"text"},{"text":"silently running on mock data.","type":"text"}],"type":"paragraph"},{"text":"Benefits of Proxying","level":3,"anchor":"Benefits-of-Proxying","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Fail-fast safety","type":"text"}]},{"type":"text","text":" — "},{"type":"reference","identifier":"doc:\/\/Forge\/documentation\/Forge\/unimplemented(_:file:line:)","isActive":true},{"type":"text","text":" catches missing wiring immediately"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Test isolation","type":"text"}]},{"type":"text","text":" — override "},{"type":"codeVoice","code":"analytics"},{"type":"text","text":" on "},{"type":"codeVoice","code":"SearchContainer"},{"type":"text","text":" directly, without"},{"type":"text","text":" "},{"type":"text","text":"touching another module’s container"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Clean dependency graph","type":"text"}]},{"text":" — each module’s DI surface is fully within its own container","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Swappability","type":"text"}]},{"type":"text","text":" — if the analytics provider changes, only the override needs updating"}]}]}],"type":"unorderedList"},{"text":"The Composition Root","level":2,"anchor":"The-Composition-Root","type":"heading"},{"inlineContent":[{"type":"text","text":"The app target is the "},{"type":"strong","inlineContent":[{"text":"composition root","type":"text"}]},{"type":"text","text":" — the only place where all modules are"},{"type":"text","text":" "},{"type":"text","text":"imported and containers are wired together:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ App\/Sources\/AppDelegate.swift","","import FeatureAuth","import FeatureSearch","import CoreAnalytics","","class AppDelegate: UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        \/\/ Wire each feature module's `unimplemented` proxies to the real","        \/\/ cross-module implementations. Containers are stable `let` singletons —","        \/\/ wire them with `override`, never by reassigning `shared`.","        SearchContainer.shared.override(\\.analytics) {","            CoreAnalyticsContainer.shared.analytics","        }","        return true","    }","}"],"type":"codeListing"},{"text":"Import Dependency Graph","level":2,"anchor":"Import-Dependency-Graph","type":"heading"},{"inlineContent":[{"type":"text","text":"The correct architecture follows this pattern:"}],"type":"paragraph"},{"syntax":null,"code":["CoreProtocols (protocols only — no Forge import)","       ^","       |","  Feature modules (each has its own Container)","       ^","       |","  App target (imports all modules, wires containers)"],"type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Key rules:"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Protocol modules define abstractions only — no Forge dependency needed"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Feature modules import protocol modules and Forge"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"ViewModels and services never "},{"type":"codeVoice","code":"import"},{"type":"text","text":" a concrete service module directly"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The app target is the only place that imports both protocol and concrete modules"}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"Best Practices","level":2,"anchor":"Best-Practices","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Keep containers "},{"inlineContent":[{"type":"text","text":"module-scoped"}],"type":"strong"},{"type":"text","text":" — if a container grows beyond its module’s"},{"type":"text","text":" "},{"type":"text","text":"concerns, the module has too many responsibilities"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Make dependency properties "},{"type":"strong","inlineContent":[{"text":"public","type":"text"}]},{"type":"text","text":" — they are the module’s DI surface"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"strong","inlineContent":[{"text":"protocol return types","type":"text"}]},{"text":" on all dependency properties","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Proxy cross-module dependencies rather than importing other feature modules"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"references":{"doc://Forge/documentation/Forge/XcodePreviewSupport":{"identifier":"doc:\/\/Forge\/docum